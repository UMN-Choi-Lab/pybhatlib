library bhatlib;  

#include gradients MVN.ext 

/** The File Header must accompany all files using any portion, in whole or in part, of this source
** code.
******************************************************************************************************************************************/


/*
** pdfrectn.src ; most general procedure for multivariate normal that combines continuous variates, singly truncated variates,
   and doubly truncated variates
**
** Purpose: Develops the partial cumulative multivariate normal distribution function of the form:
            (Integral from X2=-inf to x2) (Integral from X3=x3 to inf) (Integral from X4 = x4low to x4up) 
                of  { multivariate density {X1=x1,X2,X3,X4 } } dX4 dX3 dX2;
            If there are no rectangular integrals (i.e., all integrals are one-sided), but there are some continuous variables without integration,
              this procedure collapses to pdfcdfn.
            If integrals are a mix of one-sided and rectangular, and there are no continuous variables,
              this procedure collapses to cdorrectmvn.
            If all integrals are one-sided, with some upper truncated and others lower truncated, and there are no continuous variables, 
              this procedure collapses to cdfmvnanlpluscomp.
            If all integrals are one-sided, with all variables upper truncated (-inf to a), and there are no continuous variables, 
              this procedure collapses to cdfmvnanl.
            If there are no integrals at all, this procedure collapses to pdfmvnanl;
**
** Format:      { F,s1 } = pdfrectn(mu,cova,xg,xlow,xup,s,indxone,indxcomp,indxeq)
**
** Input:        mu is the (Kx1) vector of means
               cova is the KXK correlation matrix or KxK covariance matrix
                 xg represents (Kx1) points of abssissae for equality conditions or (lower or upper) truncation points for one-sided orthant integrals 
                    (whenever indxeq has a one OR indxone has a one, xg must have a 
                    corresponding value; when indxeq AND indxone have a zero, corresponding element of xg is immaterial (put zero for example);
               xlow represents (Kx1) points of lower truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x1 must have a corresponding value.
               xup  represents (Kx1) points of upper truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x2 must have a corresponding value.                    
                 s  is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898
           indxone  is (Kx1) vector of 1s and 0s, with a 1 for a variable to be integrated one-sided (orthant)
                     and 0 for a variable to be integrated two-sided (rectangular integration); if a variable has an equality 
                     condition, then put 0 value as corresponding element in indxone (and corresponding indxeq element should be 1).
                     { 1  This means first and third variables are to be integrated one-sided and second is a rectangular integration, 
                       0  assuming all three elements of indxeq are zero; if all elements are ones, and all elements of 
                       1  indxeq are zero, then same as cdfmvnanlpluscomp
          indxcomp  is a (Kx1) vector of 1s and 0s, with a 1 if one-sided integral is truncation from below as in a to infinity, and 0 if 
                    truncation is from above as in -infinity to a; if a variable has an equality condition, then put zero value as 
                    corresponding element in indxcomp (and corresponding indxeq element should be 1).
                    = { 0     This means third variable integration is a complement integral (b to infinity integration), 
                        0     and first/second variable integration is truncation from above (-infinity to a), assuming all three elements have a zero in indxeq; 
                        1  }; if a zero in indxone, should have a corresponding zero in indxcomp.  
           indxeq   is a Kx1 vector, where there is a one for variables with equality conditions and zero for truncated variables 
                    (if no truncations, put all elements of indxeq=1 -- results in probability density function;
                     if all truncations, put all elements of indxeq=0 -- results in an orthant/rectangular probability function);
                    when indxeq to 1, corresponding elements of indxone and indxcomp MUST be zero and vice versa;
                    when indxone equal to zero, indxcomp MUST be zero;
 
**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)   
                  
** Inputs:      mu   = { mu1,
                         mu2,
                         mu3,
                         mu4};

            cova   =   { sig11    sig12   sig13    sig14,        Cov can be a covariance or a correlation matrix
                         sig12    sig22   sig23    sig24,                                
                         sig13    sig23   sig33    sig34,
                         sig14    sig24   sig34    sig44 };                   
     
              xg   =   {  x1                   xlow =   { 0                    xup = { 0
                          x2                              0                            0
                          x3                              0                            0
                           0 };                           xl }                        xu };

           indxeq  =   { 1     This means first abscissae is equality condition at x1 , 
                         0     and second/third/fourth variables represent truncation elements
                         0 
                         0 };
                        
           indxone =   { 0     In combination with indxeq, this means second and third are single truncations, and the last is a rectangular integral
                         1
                         1
                         0 }

          indxcomp =   { 0     In combination with indxeq and indxone, this means that second variable is truncated from above (integral from -infinity to x2), 
                         0     and third variable is truncated from below (x3 to infinity); 
                         1
                         0 };
 
Output:        F   =  (Integral from X2=-inf to x2) (Integral from X3=x3 to inf) of  { multivariate density {X1=x1,X2,X3 } } dX3 dX2
              s1   =  New seed coming out of procedure for use in SSJ integration (if SSJ is used) when dimensionality of integration>4. 

Global:  The global below is applicable only when the dimensionalityof integration (number of zeros in indxeq) exceeds four. 
         _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                         "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                         "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                         "OVUS"                    - One-variate univariate screening approach
                         "OVBS"                    - One-variate bivariate screening approach
                         "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                         "BME"                     - Bivariate ME approach
                         "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS   */

                                     
proc (2) = pdfrectn(mu,cova,xg,xlow,xup,s,indxone,indxcomp,indxeq);
    local e1,indxfull,x,s10,cov,ee,indeq,indx,indx1,indxcov,s15,p,newxg,newx1,newx2,newxg1,newxg2,newx12,newx22,indxcompnew,noncdfn2,mu1,
          F,mu2condcov,indneq,x1,x2,X11,X12,X22,invX11,mu2,X22condcov,newm2,X22condcor,e2,newindxone,newindxcomp;
    e1 = rows(mu);
    if (sumc(indxeq)) == 0;
        { F,s15 } = cdorrectmvn(mu,cova,xg,xlow,xup,s,indxone,indxcomp); 
        retp(F,s15);
    elseif (sumc(indxeq))!=0 and (sumc(indxone))==e1-(sumc(indxeq));
        { F,s15 } = pdfcdfn(mu,cova,xg,s,indxcomp,indxeq);        
        retp(F,s15);
    else;  
       indxfull = seqa(1,1,e1);
       indeq = selif(indxfull,indxeq);
       indneq = selif(indxfull,(1-indxeq));
       indx = indxcomp+indxcomp';    
       indx1 = ((-1)^indxcomp);
       indxcov = ((-1)^indx);
       newxg = indx1.*(xg-mu);
       newx1 = xlow-mu;
       newx2 = xup-mu;
       cov = indxcov.*cova;   
       newxg1 = newxg[indeq];
       ee = rows(newxg1);
       newxg2 = newxg[indneq];
       newx12 = newx1[indneq];
       newx22 = newx2[indneq];
       e2 = rows(newxg2);
       X11 = cov[indeq,indeq];
       X12 = cov[indneq,indeq];
       X22 = cov[indneq,indneq];
       invX11 = invpd(X11);
       mu2condcov = X12*invX11*newxg1;
       X22condcov = X22-X12*invX11*X12'; 
       newindxone = indxone[indneq];
       newindxcomp = zeros(e2,1);
       { noncdfn2,s15 } = cdorrectmvn(mu2condcov,X22condcov,newxg2,newx12,newx22,s,newindxone,newindxcomp);
       P = (pdfmvnanl(zeros(ee,1),X11,newxg1))*noncdfn2;
       retp(P,s15);
    endif;
endp;


/* { F,gmu,gcov,gxg,gx1,gx2,s15 } = gradpdfrectn(mu,cova,xg,xlow,xup,s,indxone,indxcomp,indxeq) : Gradients of partial cumulative multivariate normal distribution function

Input:          Same as pdfrectn; 
                                     
** Global        _covarr = 1 means cova is a covariance matrix; _covarr=0 means cova is actually a correlation matrix   
                 _Cholesky = 1 if you want gradients with respect to Cholesky of cova and not cova
                 NOTE: IF YOU HAVE A UNIVARIATE CASE (K=1), MUST ALWAYS PUT _COVARR=1, AND THEN YOU CAN IGNORE GCOV if scale is fixed to 1

** Output:       F is the value of pdfrectn procedure, the actual partial cumulative MVN value
                 gmu is the (Kx1) gradient vector of F with respect to the vector of means
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the correlation matrix elements if _covarr=0 and _cholesky=0 (K>1)
                     is the Kx(K+1)/2 gradient vector of F with respect to the covariance matrix elements if _covarr=1 and _cholesky=0; (K>1)
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to variance if _covarr=1; if _covarr=0, ignore gcov;
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the cholesky of the correlation matrix elements if _covarr=0 and _cholesky=1
                     is the Kx(K+1)/2 gradient vector of F with respect to the cholesky of the covariance matrix elements if _covarr=1 and _cholesky=1;
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to standard deviation if _covarr=1; if _covarr=0, ignore gcov;                 gx represents the (Kx1) gradient vector of F with respect to the points of truncation from below (integrals are x to infinity)
                 gx - K x 1 matrix of gradients of nonpdfcdfmvn(=F) with respect to x
                 s1 is a new seed value that is relevant only for the SSJ method (and for dimension of x>4);

                 mu  = {  mu1   
                          mu2   
                          mu3 };

                 if _covarr=1;

                cova = { sig11    sig12   sig13,        if _cholesky=0;  chol(cova)  =  { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

                 if _covarr=0;

                cova = {   1      rho12   rho13,        if _cholesky=0;  chol(cova) = {   1       S12         S13,                     if _cholesky=1
                         rho12       1    rho23,                                          0   sqrt(1-S12^2)   S23,
                         rho13    rho23      1   };                                       0         0        sqrt(1-S13^2-S23^2)  }

                gmu  =  { dF/dmu1,
                          dF/dmu2,
                          dF/dmu3 };
                         
                gcov  =  { dF/dsig11,   if _cholesky=0 and __covarr=1;         
                           dF/dsig12,                               
                           dF/dsig13,                                
                         dF/dsig22,                                
                         dF/dsig23,                                      
                         dF/disg33 };                                       

                gcov  =  { dF/drho12,   if _cholesky=0 and __covarr=0;                                       
                           dF/drho13,                                                                
                           dF/drho23  };  

                gcov  =  { dF/dS11,   if _cholesky=1 and __covarr=1;         
                           dF/dS12,                               
                           dF/dS13,                                
                           dF/dS22,                                
                           dF/dS23,                                      
                           dF/dS33 };                                       

                gcov  =  { dF/dS12,   if _cholesky=1 and __covarr=0;                                       
                           dF/dS13,                                                                
                           dF/dS23  };
                        
                gxg   =   { dF/dx1,
                            dF/dx2,
                            dF/dx3
                            0 }     
                          
                gx1   =   { 0,
                            0,
                            0,
                            dF/dxl };
                          
                gx2   =   { 0,
                            0,
                            0,
                            dF/dxu };                             */

proc (7) = gradpdfrectn(mu,cova,xg,xlow,xup,s,indxone,indxcomp,indxeq);
    local e1,e,e10,mm,mm1,e11,Xcov,gX11reorder,gsigma,mu2condcov,mu1,nonpdf1,gmu2condcov,gx,gcov,pdf1,noncdfn2,gnewxg1,gnewg2,s15,s10,P,gX11,gY,gmu,gmu2,
           gX22condcov,gX1new,gX2new,gmu1,indxfull,indeq,indneq,indxcompnew,X11,X12,X22,invX11,mu2,X22condcov,newm2,X22condcor,e2,gnewxg1cond,newindxone,newindxcomp,
           gmucond,gmucond1,gxg,gx1,gx2,gmucond2,gx1cond,indx,x,cov,indx1,indxcov,newxg,newxg1,newxg2,gxg2,gx12,gx22,gx22newx1,newx1,newx2,newx11,newx21,newx12,newx22,x2;
    e = rows(xg);
    mm = _covarr;
    mm1 = _cholesky;
    if (sumc(indxeq)) == 0;
        _cholesky=0;
        { P,gmu,gcov,gxg,gx1,gx2,s15 } = gradcdorrectmvn(mu,cova,xg,xlow,xup,s,indxone,indxcomp); 
    elseif (sumc(indxeq))!=0 and (sumc(indxone))==e-(sumc(indxeq));
        _cholesky=0;
        gx1 = zeros(e,1); gx2 = gx1;
        { P,gmu,gcov,gxg,s15 } = gradpdfcdfn(mu,cova,xg,s,indxcomp,indxeq);
    else;
       indxfull = seqa(1,1,e);
       indeq = selif(indxfull,indxeq);
       indneq = selif(indxfull,(1-indxeq));
       indx = indxcomp+indxcomp';    
       indx1 = ((-1)^indxcomp);
       indxcov = ((-1)^indx);
       newxg = indx1.*(xg-mu);
       newx1 = xlow-mu;
       newx2 = xup-mu;
       cov = indxcov.*cova;   
       newxg1 = newxg[indeq];
       e1 = rows(newxg1);
       e10 = e1*(e1+1)/2;
       e11 = e*(e+1)/2;
       newxg2 = newxg[indneq];
       newx12 = newx1[indneq];
       newx22 = newx2[indneq];
       e2 = rows(newxg2);
       X11 = cov[indeq,indeq];
       X12 = cov[indneq,indeq];
       X22 = cov[indneq,indneq];
       Xcov = (X11~X12')|(X12~X22);
       invX11 = invpd(X11);
       mu2condcov = X12*invX11*newxg1;
       X22condcov = X22-X12*invX11*X12'; 
       newindxone = indxone[indneq];
       newindxcomp = zeros(e2,1);
       
       gxg = zeros(e,1); gx1=gxg;  gx2 = gxg;
       gmu = zeros(e,1);
       gcov = zeros(e11,1);
       _cholesky=0;
       { nonpdf1,gmu1,gX11,gnewxg1 } = gradpdfmvnanl(zeros(e1,1),X11,newxg1);
       if mm==0;
          _condcov=0;
       else;
          _condcov=1;
       endif;
       { gY, gmucond, gX1new } = gcondmean(eye(e2),zeros(e,1),Xcov,newxg1); 
       gmucond1 = gmucond[1:e1,.];   gmucond2 = gmucond[e1+1:e,.];      gnewxg1cond = -gmucond1;
       { gY, gX2new } = gcondcov(eye(e2),Xcov);

       if (((diag(x22condcov))==ones(e2,1)) and mm==0);
/*       if ((diag(x22condcov))==ones(e2,1));  */
          _covarr=0;
       else;
          _covarr=1;
       endif;
 
       _cholesky=0;
       { noncdfn2,gmu2condcov,gX22condcov,gxg2,gx12,gx22,s15 } = gradcdorrectmvn(mu2condcov,X22condcov,newxg2,newx12,newx22,s,newindxone,newindxcomp);       
       P = nonpdf1*noncdfn2;
       gxg[indeq] = gnewxg1*noncdfn2+nonpdf1*(gnewxg1cond*gmu2condcov);
       gxg[indneq] = nonpdf1*gxg2;  gxg=indx1.*gxg;
       gx1[indneq] = nonpdf1*gx12;  /* gx1 = indx1.*gx1;  */
       gx2[indneq] = nonpdf1*gx22;  /* gx2 = indx1.*gx2; */   
        
       gmu=-gxg-gx1-gx2;
       if mm==1;  
          gX11reorder = (matdupfull(gX11)~zeros(e1,e2))|(zeros(e2,e1)~zeros(e2,e2));
          gX11reorder = (vecdup(gX11reorder));
          gcov=gX11reorder*noncdfn2+nonpdf1*(gX1new*gmu2condcov+gX2new*gX22condcov);
          gcov = matdupfull(gcov);
          gcov[indeq|indneq,indeq|indneq]=gcov; 
          gcov = vecdup(indxcov.*gcov);   
       else;
          if e2 == e-1;
             gcov=nonpdf1*(gX1new*gmu2condcov+gX2new*gX22condcov);
          else;
             gX11reorder = (matndupdiagonefull(gX11)~zeros(e1,e2))|(zeros(e2,e1)~zeros(e2,e2));
             gX11reorder = (vecndup(gX11reorder));
             gcov=gX11reorder*noncdfn2+nonpdf1*(gX1new*gmu2condcov+gX2new*gX22condcov);
          endif;
          gcov = matndupdiagzerofull(gcov);
          gcov[indeq|indneq,indeq|indneq]=gcov;  
          gcov = vecndup(indxcov.*gcov);           
       endif;
    endif;
    if mm1==1;
       if mm==1;
          gcov = (gcholeskycov(cova))*gcov;
       else;
          gcov = (gcholeskycor(cova))*gcov;
       endif;
       if e==1;
          gcov = (2*sqrt(cova))*gcov;
       endif;
    endif;
    retp(P,gmu,gcov,gxg,gx1,gx2,s15);
endp;
 

/*
** pdfcdfn.src 
**
** Purpose: Develops the following partial cumulative multivariate normal distribution function:
            (Integral from X2=-inf to x2) (Integral from X3=x3 to inf) of  { multivariate density {X1=x1,X2,X3 } } dX3 dX2

**
** Format:      { F,s1 } = pdfcdfn(mu,cova,xa,s,indxcomp,indxeq)

Input:       
            mu - Kx1 vector of means of the K random variates
          cova - K x K matrix of covariance parameters 
            xa - Kx1 vector of abscissae for equality conditions and truncation limits (from above or below) for inequality conditions
             s - seed for SSJ computation if dimensionality of integration > 4 and using the SSJ method
      indxcomp - Kx1 vector of random variates that are to be integrated from b to infinity (truncation from below)
        indxeq - Kx1 vector, where there is a one for variables with equality conditions and zero for truncated variables 
                 (if no truncations, put all elements of indxeq=1 -- results in probability density function;
                  if all truncations, put all elements of indxeq=0 -- results in a cumulative probability function);
        NOTE: Analyst has to ensure that indxcomp elements are zero when corresponding indxeq elements take a value of 1.         
 
              mu   = { mu1,
                       mu2,
                       mu3 };

            cova   =   { sig11    sig12   sig13,        Cov can be a covariance or a correlation matrix
                         sig12    sig22   sig23,                                
                         sig13    sig23   sig33   };                   
     
              xa   = {  x1   
                        x2   
                        x3 };   say three abscissae 

           indxeq  =  { 1     This means first abscissae is equality condition at x1 , 
                        0     and second/third variables represent truncation elements
                        0  };

           indxcomp (Kx1) =       { 0     This means that second variable is truncated from above (integral from -infinity to x2), 
                                    0     and third variable is truncated from below (x3 to infinity); 
                                    1  };
 
Output:        F   =  (Integral from X2=-inf to x2) (Integral from X3=x3 to inf) of  { multivariate density {X1=x1,X2,X3 } } dX3 dX2
              s1   =  New seed coming out of procedure for use in SSJ integration (if SSJ is used) when dimensionality of integration>4. 

Global:  The global below is applicable only when the dimensionalityof integration (number of zeros in indxeq) exceeds four. 
         _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                         "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                         "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                         "OVUS"                    - One-variate univariate screening approach
                         "OVBS"                    - One-variate bivariate screening approach
                         "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                         "BME"                     - Bivariate ME approach
                         "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS   */

                                     
proc (2) = pdfcdfn(mu,cova,xa,s,indxcomp,indxeq);
    local e1,indxfull,x,s10,cov,ee,indeq,indx,indx1,indxcov,s15,p,indxcompnew,noncdfn2,mu1,
          F,mu2condcov,indneq,x1,x2,X11,X12,X22,invX11,mu2,X22condcov,newm2,X22condcor,e2;
    e1 = rows(xa);
    if (sumc(indxeq)) == 0;
       { F,s15 } = cdfmvnanlpluscomp(mu,cova,xa,s,indxcomp);
       retp(F,s15);
    elseif (sumc(indxeq))==e1;
       s15 = s;
       retp((pdfmvnanl(mu,cova,xa)),s15);
    else;  
       indxfull = seqa(1,1,e1);
       indeq = selif(indxfull,indxeq);
       indneq = selif(indxfull,(1-indxeq));
       indx = indxcomp+indxcomp';    
       indx1 = ((-1)^indxcomp);
       indxcov = ((-1)^indx);
       x = indx1.*(xa-mu);
       cov = indxcov.*cova;   
       x1 = x[indeq];
       ee = rows(x1);
       x2 = x[indneq];
       e2 = rows(x2);
       X11 = cov[indeq,indeq];
       X12 = cov[indneq,indeq];
       X22 = cov[indneq,indneq];
       invX11 = invpd(X11);
       mu2condcov = X12*invX11*x1;
       X22condcov = X22-X12*invX11*X12'; 
       { noncdfn2,s15 } = cdfmvnanl(mu2condcov,X22condcov,x2,s);
       P = (pdfmvnanl(zeros(ee,1),X11,x1))*noncdfn2;
       retp(P,s15);
    endif;
endp;


/* { P,gmu,gcov,gx,s1 } = gradpdfcdfn(mu,cova,xa,s,indxcomp,indxeq) : Gradients of partial cumulative multivariate normal distribution function

Input:       
            mu - Kx1 vector of means of the K random variates
          cova - K x K matrix of covariance parameters 
            xa - Kx1 vector of absiccae for equality conditions and truncation from above for inequality conditions             s - seed for SSJ computation if dimensionality of integration > 4 and using the SSJ method
      indxcomp - Kx1 vector of random variates that are to be integrated from b to infinity (truncation from below)
        indxeq - Kx1 vector, where there is a one for abscissae for equality conditions and zero for truncation from above               
        NOTE: Analyst has to ensure that indxcomp elements are zero when corresponding indxeq elements take a value of 1.  

           indxcomp (Kx1) =       { 0     This means that second variable is truncated from above (integral from -infinity to x2), 
                                    0     and third variable is truncated from below (x3 to infinity); 
                                    1  };
 
           indxeq  =  { 1     This means first and third abscissae are equality conditions, 
                        0     and second abscissa is truncation from above; cannot have all zeros (equivalent to multivariate cumulative distribution)
                        1  }; or cannot have all ones (equivalent to multivariate density function); use cdfmvn and pdfmvn in these cases.  
                         
** Global        _covarr = 1 means cov is a covariance matrix; _covarr=0 means cov is actually a correlation matrix   
                 _Cholesky = 1 if you want gradients with respect to Cholesky of cov and not cov
                 NOTE: IF YOU HAVE A UNIVARIATE CASE (K=1), MUST ALWAYS PUT _COVARR=1, AND THEN YOU CAN IGNORE GCOV

** Output:       P is the value of the partial cumulative distribution function
                 gmu is the (Kx1) gradient vector of F with respect to the vector of means
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the correlation matrix elements if _covarr=0 and _cholesky=0 (K>1)
                     is the Kx(K+1)/2 gradient vector of F with respect to the covariance matrix elements if _covarr=1 and _cholesky=0; (K>1)
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to variance if _covarr=1; if _covarr=0, ignore gcov;
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the cholesky of the correlation matrix elements if _covarr=0 and _cholesky=1
                     is the Kx(K+1)/2 gradient vector of F with respect to the cholesky of the covariance matrix elements if _covarr=1 and _cholesky=1;
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to standard deviation if _covarr=1; if _covarr=0, ignore gcov;                 gx represents the (Kx1) gradient vector of F with respect to the points of truncation from below (integrals are x to infinity)
                 gx - K x 1 matrix of gradients of nonpdfcdfmvn(=F) with respect to x
                 s1 is a new seed value that is relevant only for the SSJ method (and for dimension of x>4);

                 mu  = {  mu1   
                          mu2   
                          mu3 };

                 if _covarr=1;

                cova = { sig11    sig12   sig13,        if _cholesky=0;  chol(cova)  =  { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

                 if _covarr=0;

                cova = {   1      rho12   rho13,        if _cholesky=0;  chol(cova) = {   1       S12         S13,                     if _cholesky=1
                         rho12       1    rho23,                                          0   sqrt(1-S12^2)   S23,
                         rho13    rho23      1   };                                       0         0        sqrt(1-S13^2-S23^2)  }

               gmu  =  { dF/dmu1,
                         dF/dmu2,
                         dF/dmu3 };
                         
              gcov  =  { dF/dsig11,   if _cholesky=0 and __covarr=1;         
                         dF/dsig12,                               
                         dF/dsig13,                                
                         dF/dsig22,                                
                         dF/dsig23,                                      
                         dF/disg33 };                                       

              gcov  =  { dF/drho12,   if _cholesky=0 and __covarr=0;                                       
                         dF/drho13,                                                                
                         dF/drho23  };  

              gcov  =  { dF/dS11,   if _cholesky=1 and __covarr=1;         
                         dF/dS12,                               
                         dF/dS13,                                
                         dF/dS22,                                
                         dF/dS23,                                      
                         dF/dS33 };                                       

              gcov  =  { dF/dS12,   if _cholesky=1 and __covarr=0;                                       
                         dF/dS13,                                                                
                         dF/dS23  };
                         
              gx    =   { dF/dx1,
                          dF/dx2,
                          dF/dx3 }     */

proc (5) = gradpdfcdfn(mu,cova,xa,s,indxcomp,indxeq);
    local e1,e,e10,mm,mm1,e11,Xcov,gX11reorder,gsigma,mu2condcov,mu1,nonpdf1,gmu2condcov,gx,gcov,pdf1,noncdfn2,gx1,gx2,s15,s10,P,gX11,gY,gmu,gmu2,
           gX22condcov,gX1new,gX2new,gmu1,indxfull,indeq,indneq,indxcompnew,X11,X12,X22,invX11,mu2,X22condcov,newm2,X22condcor,e2,
           gmucond,gmucond1,gmucond2,gx1cond,indx,x,cov,indx1,indxcov,x1,x2,s1;
    e = rows(xa);
    mm = _covarr;
    mm1 = _cholesky;
    if (sumc(indxeq)) == 0;
       _cholesky=0;
       { P,gmu,gcov,gx,s15 } = gradcdfmvnanlpluscomp(mu,cova,xa,s,indxcomp);
    elseif (sumc(indxeq))==e;
       s15 = s;
       _cholesky=0;
       { P,gmu,gcov,gx } = gradpdfmvnanl(mu,cova,xa);   
    else;
       indxfull = seqa(1,1,e);
       indeq = selif(indxfull,indxeq);
       indneq = selif(indxfull,(1-indxeq));
       indx = indxcomp+indxcomp';    
       indx1 = ((-1)^indxcomp);
       indxcov = ((-1)^indx);
       x = indx1.*(xa-mu);
       cov = indxcov.*cova;  
       x1 = x[indeq];
       x2 = x[indneq];
       e1 = rows(x1);
       e10 = e1*(e1+1)/2;
       e11 = e*(e+1)/2;
       e2 = rows(x2);
       X11 = cov[indeq,indeq];
       X12 = cov[indneq,indeq];
       X22 = cov[indneq,indneq];
       Xcov = (X11~X12')|(X12~X22);
       invX11 = invpd(X11);
       mu2condcov = X12*invX11*x1; 
       X22condcov = X22-X12*invX11*X12'; 
       gx = zeros(e,1);
       gmu = zeros(e,1);
       gcov = zeros(e11,1);

       _cholesky=0;
       { nonpdf1,gmu1,gX11,gx1 } = gradpdfmvnanl(zeros(e1,1),X11,x1);
       if mm==0;
          _condcov=0;
       else;
          _condcov=1;
       endif;
       { gY, gmucond, gX1new } = gcondmean(eye(e2),zeros(e,1),Xcov,x1); 
       gmucond1 = gmucond[1:e1,.];   gmucond2 = gmucond[e1+1:e,.];      gx1cond = -gmucond1;
       { gY, gX2new } = gcondcov(eye(e2),Xcov);

       if (((diag(x22condcov))==ones(e2,1)) and mm==0);
          _covarr=0;
       else;
          _covarr=1;
       endif;

       _cholesky=0;
       { noncdfn2,gmu2condcov,gX22condcov,gx2,s15 } = gradcdfmvnanl(mu2condcov,X22condcov,x2,s); 
       P = nonpdf1*noncdfn2;
       gx[indeq] = gx1*noncdfn2+nonpdf1*gx1cond*gmu2condcov;
       gx[indneq] = nonpdf1*gx2;
       gx=indx1.*gx;
       gmu=-gx;
       if mm==1;  
          gX11reorder = (matdupfull(gX11)~zeros(e1,e2))|(zeros(e2,e1)~zeros(e2,e2));
          gX11reorder = (vecdup(gX11reorder));
          gcov=gX11reorder*noncdfn2+nonpdf1*(gX1new*gmu2condcov+gX2new*gX22condcov);
          gcov = matdupfull(gcov);
          gcov[indeq|indneq,indeq|indneq]=gcov; 
          gcov = vecdup(indxcov.*gcov);   
       else;
          if e2 == e-1;
             gcov=nonpdf1*(gX1new*gmu2condcov+gX2new*gX22condcov);
          else;
             gX11reorder = (matndupdiagonefull(gX11)~zeros(e1,e2))|(zeros(e2,e1)~zeros(e2,e2));
             gX11reorder = (vecndup(gX11reorder));
             gcov=gX11reorder*noncdfn2+nonpdf1*(gX1new*gmu2condcov+gX2new*gX22condcov);
          endif;
          gcov = matndupdiagzerofull(gcov);
          gcov[indeq|indneq,indeq|indneq]=gcov;  
          gcov = vecndup(indxcov.*gcov);           
       endif;
    endif;
    if mm1==1;
       if mm==1;
          gcov = (gcholeskycov(cova))*gcov;
       else;
          gcov = (gcholeskycor(cova))*gcov;
       endif;
       if e==1;
          gcov = (2*sqrt(cova))*gcov;
       endif;
    endif;
    retp(P,gmu,gcov,gx,s15);
endp;
 

/***************************************************************************************************************************************************
                         Univariate and multivariate normal cumulative distribution function and its complement, and gradients
   Can also use this procedure as a one-stop for only cumulative distribution function or only complement of cumulative distribution  distribution
***************************************************************************************************************************************************/


/*
** cdorrectmvn.src 
**
** Purpose: Develops the integration from -inf to a for some variables, from b to inf for other variables, and from c to d for other variables;
            Combines orthant and rectangular mvn computations 
**
** Format:      { F,s1 } = cdorrectmvn(mu,cov,xg,x1,x2,s,indxone,indxcomp)
**
** Input:        mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix or KxK covariance matrix
                 xg represents (Kx1) points of lower or upper truncation for one-sided orthant integrals (whenever indxone has a one, xg must have a 
                    corresponding value; when indxone has a zero, corresponding element of xg is immaterial (put zero for example);
                    indxcomp determines whether the point is lower or upper truncation point 
                 x1 represents (Kx1) points of lower truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x1 must have a corresponding value.
                 x2 represents (Kx1) points of upper truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x2 must have a corresponding value.                    
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898
                 indxone (Kx1) - a vector of 1s and 0s, with a 1 for a variable to be integrated one-sided (orthant)
                                 and 0 for a variable to be integrated two-sided (rectangular integration)
                                 { 1  This means first and third variables are to be intergated one-sided and second is a rectangular integration 
                                   0  if all ones, same as cdfmvnanlpluscomp
                                   1
                 indxcomp (Kx1) = { 0     This means third variable integration is a complement integral (b to infinity integration), 
                                    0     and second variable integration is truncation from above (-infinity to a); 
                                    1  }; if a zero in indxone, should have a corresponding zero in indxcomp.   

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)   

** Output:      F - 1x1 
                s1 - New seed that you may need in evaluating multiple functions in estimation when using SSJ for K>4   */
                 
proc (2) = cdorrectmvn(mu,cov,xg,x1,x2,s,indxone,indxcomp);
    local e2,P,newx,kk2,w,s15,indx,F,newxg,comb1,newx1,newx2,newxone,newxlow,newxup,sign,comb,ecomb,P1,j,posone,posrect;
    e2 = rows(mu);
    if (sumc(indxone))==e2;
        { F,s15 } = cdfmvnanlpluscomp(mu,cov,xg,s,indxcomp);
        retp(F,s15);
    elseif (sumc(indxone))==0;
        { F,s15 } = cdrectmvnanl(mu,cov,x1,x2,s);
        retp(F,s15);
    else;
        kk2 = corrvc(cov);
        indx = indxcomp+indxcomp';    
        kk2 = ((-1)^(indx)).*kk2;
        kk2 = diagrv(kk2,ones(e2,1));
        w = sqrt(diag(cov));
        newxg = (xg-mu)./w;
        newx1 = (x1-mu)./w;
        newx2 = (x2-mu)./w;
        newxg = ((-1)^indxcomp).*newxg;
        newxone = (selif(newxg,indxone));
        newxlow = selif(newx1,indxone.==0);
        newxup  = selif(newx2,indxone.==0);
        posone = selif(seqa(1,1,e2),indxone);
        posrect = selif(seqa(1,1,e2),indxone.==0);
        if e2<=4;
           s15=s;
        endif;
        { sign,comb } = rectcombs(newxlow,newxup);
        ecomb = rows(comb);
        comb1 = zeros(ecomb,e2);
        comb1[.,posone] = ones(ecomb,1).*((newxone)');
        comb1[.,posrect] = comb;  
        P = 0;
        for j(1,ecomb,1); 
           if e2==2; 
              P = P+sign[j]*cdfbvn(comb1[j,1],comb1[j,2],kk2[1,2]);
           elseif e2==3;
              P = P+sign[j]*cdftvn(comb1[j,1],comb1[j,2],comb1[j,3],kk2[1,2],kk2[2,3],kk2[1,3]);
           elseif e2==4;
              P = P+sign[j]*cdfqvn(((comb1[j,.])'),kk2);
           else;      
              { P1,s15 } = cdfmvnanalytic(zeros(e2,1),kk2,((comb1[j,.])'),s); 
              P=P+sign[j]*P1;
           endif;
        endfor;
        retp(P,s15);   
    endif;
endp;

 

/*
** gradcdorrectmvn.src 
**
** Purpose: Develops the gradients of the combination of cdfmvnanl and cdfmvnanlcomp 
**

** Format:      { P,gmu,gcov,gxg,gx1,gx2,s1 } = gradcdorrectmvn(mu,cov,xg,x1,x2,s,indxone,indxcomp)
**
** Input:        P is the value of the integration
                 mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix if _covarr=0; and cov is KxK covariance matrix if _covarr=1,
                 xg represents (Kx1) points of lower or upper truncation for one-sided orthant integrals (whenever indxone has a one, xg must have a 
                    corresponding value; when indxone has a zero, corresponding element of xg is immaterial (put zero for example);
                    indxcomp determines whether the point is lower or upper truncation point 
                 x1 represents (Kx1) points of lower truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x1 must have a corresponding value.
                 x2 represents (Kx1) points of upper truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x2 must have a corresponding value.                    
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898
                 indxone (Kx1) - a vector of 1s and 0s, with a 1 for a variable to be integrated one-sided (orthant)
                                 and 0 for a variable to be integrated two-sided (rectangular integration)
                                 { 1  This means first and third variables are to be intergated one-sided and second is a rectangular integration 
                                   0  if all ones, same as cdfmvnanlpluscomp
                                   1
                 indxcomp (Kx1) = { 0     This means third variable integration is a complement integral (b to infinity integration), 
                                    0     and second variable integration is truncation from above (-infinity to a); 
                                    1  }; if a zero in indxone, should have a corresponding zero in indxcomp.   

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                 Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)  
                          
                 _covarr = 1     means cov is a covariance matrix; _covarr=0 means cov is actually a correlation matrix   
                 _Cholesky = 1 if you want gradients with respect to Cholesky of cov and not cov
                 NOTE: IF YOU HAVE A UNIVARIATE CASE (K=1), MUST ALWAYS PUT _COVARR=1, AND THEN YOU CAN IGNORE GCOV
                 
** Output:       P is 1x1 scalar
                 gmu is the (Kx1) gradient vector of F with respect to the vector of means
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the correlation matrix elements if _covarr=0 and _cholesky=0 (K>1)
                     is the Kx(K+1)/2 gradient vector of F with respect to the covariance matrix elements if _covarr=1 and _cholesky=0; (K>1)
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to variance if _covarr=1; if _covarr=0, ignore gcov;
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the cholesky of the correlation matrix elements if _covarr=0 and _cholesky=1
                     is the Kx(K+1)/2 gradient vector of F with respect to the cholesky of the covariance matrix elements if _covarr=1 and _cholesky=1;
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to standard deviation if _covarr=1; if _covarr=0, ignore gcov;                 gx represents the (Kx1) gradient vector of F with respect to the points of truncation from below (integrals are x to infinity)
                 gxg is the (Kx1) graident vector of F with respect to the vector of thresholds on one side (ignore gxg row entries if corresponding
                     indxone entry is zero)
                 gx1 and gx2 are each (Kx1) gradient vectors of F with respect to the lower and upper rectangular thresholds (ignore gx1 and gx2 row 
                     entries if corresponding indxone entry is one)
                 s1 is a new seed value that is relevant only for the SSJ method (and for dimension of x>4);

                 mu  = {  mu1   
                          mu2   
                          mu3 };

                 if _covarr=1;

                 cov = { sig11    sig12   sig13,        if _cholesky=0;   chol(cov)  =  { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

                 if _covarr=0;

                 cov = {   1      rho12   rho13,        if _cholesky=0;   chol(cov) = {   1       S12         S13,                     if _cholesky=1
                         rho12       1    rho23,                                          0   sqrt(1-S12^2)   S23,
                         rho13    rho23      1   };                                       0         0        sqrt(1-S13^2-S23^2)  }


               gmu  =  { dF/dmu1,
                         dF/dmu2,
                         dF/dmu3 };
                         
              gcov  =  { dF/dsig11,   if _cholesky=0 and __covarr=1;         
                         dF/dsig12,                               
                         dF/dsig13,                                
                         dF/dsig22,                                
                         dF/dsig23,                                      
                         dF/disg33 };                                       

              gcov  =  { dF/drho12,   if _cholesky=0 and __covarr=0;                                       
                         dF/drho13,                                                                
                         dF/drho23  };  

              gcov  =  { dF/dS11,   if _cholesky=1 and __covarr=1;         
                         dF/dS12,                               
                         dF/dS13,                                
                         dF/dS22,                                
                         dF/dS23,                                      
                         dF/dS33 };                                       

              gcov  =  { dF/dS12,   if _cholesky=1 and __covarr=0;                                       
                         dF/dS13,                                                                
                         dF/dS23  };
                         
              gxg   =   { dF/dxg1,
                          dF/dxg2,
                          dF/dxg3 }     
                          
              gx1   =   { dF/dx11,
                          dF/dx12,
                          dF/dx13 };
                          
              gx2   =   { dF/dx21,
                          dF/dx22,
                          dF/dx23 };                 */         
                          
proc (7) = gradcdorrectmvn(mu,cov,xg,x1,x2,s,indxone,indxcomp);
    local e2,indx,indx1,kk1old,kk2old,indxcov,mm1,invsig,kk1,kk2,mm,gBcorcovg,gomegacorcovg,gBcorcov1,gomegacorcov1,gmu,gcov,
          gx,rho,gx1,gx2,comb1,grho,P,s15,gBcorcov2,gomegacorcov2,w,gxg,gxx,gcov2,gBcorcov,gomegacorcov,
          newx1,newx2,newxg,newxone,newxlow,newxup,rone,posone,posrect,sign,comb,indxa,indxb,ecomb,gxg1,gxx1,gxx2,gcov1,j,P1;
    e2 = rows(mu);
    if (sumc(indxone))==e2;
        gxx1 = zeros(e2,1); gxx2 = gxx1;
        { P,gmu,gcov2,gxg1,s15 } = gradcdfmvnanlpluscomp(mu,cov,xg,s,indxcomp);
    elseif (sumc(indxone))==0;
        gxg1 = zeros(e2,1);
        { P,gmu,gcov2,gxx1,gxx2,s15 } = gradcdrectmvnanl(mu,cov,x1,x2,s);
    else;
        mm=_covarr; 
        mm1 = _cholesky;
        _cholesky=0;
        kk2 = corrvc(cov);
        indx = indxcomp+indxcomp';  
        indx1 = ((-1)^indxcomp);
        indxcov = ((-1)^indx);
        kk2old = kk2;
        kk2 = indxcov.*kk2;
        kk2 = diagrv(kk2,ones(e2,1)); 
        w = sqrt(diag(cov));
        newxg = (xg-mu)./w;
        newx1 = (x1-mu)./w;
        newx2 = (x2-mu)./w;
        kk1old = newxg;
        newxg = indx1.*newxg;
        newxone = selif(newxg,indxone);
        newxlow = selif(newx1,indxone.==0);
        newxup  = selif(newx2,indxone.==0);
        rone = rows(newxone);
        posone = selif(seqa(1,1,e2),indxone);
        posrect = selif(seqa(1,1,e2),indxone.==0);
        if e2<=4;
           s15=s;
        endif;
        { sign,comb,indxa,indxb } = rectcombsforgrad(newxlow,newxup);
        ecomb = rows(comb);
        comb1 = zeros(ecomb,e2);
        comb1[.,posone] = ones(ecomb,1).*(newxone');
        comb1[.,posrect] = comb;
        gxg1 = zeros(e2,1);
        gxx1 = zeros(e2,1);
        gxx2 = zeros(e2,1);
        if mm==1;
            gcov2 = zeros(e2*((e2+1)/2),1);
        else;
            gcov2 = zeros(e2*((e2-1)/2),1);  
        endif;
        P=0;
        for j(1,ecomb,1); 
           if e2==2; 
               P = P+sign[j]*cdfbvn(comb1[j,1],comb1[j,2],kk2[1,2]);
              { gxg,gxx,gcov } = gradcdfbvn(comb1[j,1],comb1[j,2],kk2[1,2]);  gx = gxg|gxx;
           elseif e2==3;
               P = P+sign[j]*cdftvn(comb1[j,1],comb1[j,2],comb1[j,3],kk2[1,2],kk2[2,3],kk2[1,3]);
               { gx,gcov } = gradcdftvn(((comb1[j,.])'),kk2[1,2]|kk2[1,3]|kk2[2,3]);   
           elseif e2==4;
               P = P+sign[j]*cdfqvn(((comb1[j,.])'),kk2);
               { gx,gcov } =  gradcdfqvn(((comb1[j,.])'),kk2);
           else;
               _covarr=0;
               { P1,gmu,gcov,gx,s15 } = pdfmvnanalytic(zeros(e2,1),kk2,((comb1[j,.])'),s);
               P = P+sign[j]*P1;
           endif;
           gxg1[posone] = gxg1[posone]+sign[j]*gx[posone];
           gxx1[posrect] = gxx1[posrect]+sign[j]*gx[posrect].*((indxa[j,.])'); 
           gxx2[posrect] = gxx2[posrect]+sign[j]*gx[posrect].*((indxb[j,.])');
           gcov1 = sign[j]*gcov;
           gcov1 = vecndup(indxcov.*(matndupdiagzerofull(gcov1)));
           if mm==1;
              { gBcorcov,gomegacorcov } = gradcorcov(((comb1[j,.])'),w,kk2old);
              gcov2 = gcov2+gbcorcov*sign[j]*gx+gomegacorcov*gcov1; 
           else;
              gcov2 = gcov2+gcov1; 
           endif;
        endfor;
        gxg1 = (indx1.*gxg1)./w;     gxx1 = gxx1./w;     gxx2 = gxx2./w;
        gmu = -(gxg1+gxx1+gxx2);

        if mm1==1;
          if mm==1;
             gcov2 = (gcholeskycov(cov))*gcov2;
          else;
            gcov2 = (gcholeskycor(cov))*gcov2;
          endif;
        endif;
    endif;
    retp(P,gmu,gcov2,gxg1,gxx1,gxx2,s15);
endp;
        


/*
** cdfmvnanlpluscomp.src 
**
** Purpose: Develops the integration from -inf to a for some variables, and from b to inf for other variables;
            Combines cdfmvnanl and cdfmvnanlcomp. 
**
** Format:      { F,s1 } = cdfmvnanlpluscomp(mu,cov,x,s,indxcomp)
**
** Input:        mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix or KxK covariance matrix
                 x represents points of truncation
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  
                 indxcomp (Kx1) = { 1     This means first and third abscissae are complement integrals (b to infinity integration), 
                                    0     and second abscissa is truncation from above (-infinity to a); if all zeros, equivalent to cdfmvanl;
                                    1  }; or if all ones, equivalent to cdfmvanlcomp  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)   

** Output:      F - 1x1 
                s1 - New seed that you may need in evaluating multiple functions in estimation when using SSJ for K>4   */
                 
proc (2) = cdfmvnanlpluscomp(mu,cov,x,s,indxcomp);
    local e2,P,newx,kk2,w,s15,indx;
    e2 = rows(x);
    kk2 = corrvc(cov);
    indx = indxcomp+indxcomp';    
    kk2 = ((-1)^(indx)).*kk2;
    kk2 = diagrv(kk2,ones(e2,1)); 
    w = sqrt(diag(cov));
    newx = (x-mu)./w;
    newx = ((-1)^indxcomp).*newx;
    if e2<=4;
        s15=s;
    endif;
    if e2 ==1;
       retp(cdfn(newx),s15);
    elseif e2==2;
       retp((cdfbvn(newx[1],newx[2],kk2[1,2])),s15);
    elseif e2==3;
       retp((cdftvn(newx[1],newx[2],newx[3],kk2[1,2],kk2[2,3],kk2[1,3])),s15);
    elseif e2==4;
       retp((cdfqvn(newx,kk2)),s15);
    else;        
       { P,s15 } = cdfmvnanalytic(zeros(e2,1),kk2,newx,s); 
        retp(P,s15);   
    endif;
endp;

 
/*
** gradcdfmvnanlpluscomp.src 
**
** Purpose: Develops the gradients of the combination of cdfmvnanl and cdfmvnanlcomp 
**

** Format:      { P,gmu,gcov,gx,s1 } = gradcdfmvnanlcomp(mu,cov,x,s,indxcomp)
**
** Input:        mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix if _covarr=0; and cov is KxK covariance matrix if _covarr=1,
                 x represents points of truncation
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  
                 indxcomp (Kx1) = { 1     This means first and third abscissae are complement integrals (b to infinity integration), 
                                    0     and second abscissa is truncation from above (-infinity to a); if all zeros, equivalent to cdfmvanl;
                                    1  }; or if all ones, equivalent to cdfmvanlcomp  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                 Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)  
                          
                 _covarr = 1     means cov is a covariance matrix; _covarr=0 means cov is actually a correlation matrix   
                 _Cholesky = 1 if you want gradients with respect to Cholesky of cov and not cov
                 NOTE: IF YOU HAVE A UNIVARIATE CASE (K=1), MUST ALWAYS PUT _COVARR=1, AND THEN YOU CAN IGNORE GCOV
                 
** Output:       P is the probability value
                 gmu is the (Kx1) gradient vector of F with respect to the vector of means
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the correlation matrix elements if _covarr=0 and _cholesky=0 (K>1)
                     is the Kx(K+1)/2 gradient vector of F with respect to the covariance matrix elements if _covarr=1 and _cholesky=0; (K>1)
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to variance if _covarr=1; if _covarr=0, ignore gcov;
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the cholesky of the correlation matrix elements if _covarr=0 and _cholesky=1
                     is the Kx(K+1)/2 gradient vector of F with respect to the cholesky of the covariance matrix elements if _covarr=1 and _cholesky=1;
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to standard deviation if _covarr=1; if _covarr=0, ignore gcov;                 gx represents the (Kx1) gradient vector of F with respect to the points of truncation from below (integrals are x to infinity)
                 gx is the (Kx1) graident vector of F with respect to the vector of abscissae
                 s1 is a new seed value that is relevant only for the SSJ method (and for dimension of x>4);


                 mu  = {  mu1   
                          mu2   
                          mu3 };

                 if _covarr=1;

                 cov = { sig11    sig12   sig13,        if _cholesky=0;   chol(cov)  =  { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

                 if _covarr=0;

                 cov = {   1      rho12   rho13,        if _cholesky=0;   chol(cov) = {   1       S12         S13,                     if _cholesky=1
                         rho12       1    rho23,                                          0   sqrt(1-S12^2)   S23,
                         rho13    rho23      1   };                                       0         0        sqrt(1-S13^2-S23^2)  }


               gmu  =  { dF/dmu1,
                         dF/dmu2,
                         dF/dmu3 };
                         
              gcov  =  { dF/dsig11,   if _cholesky=0 and __covarr=1;         
                         dF/dsig12,                               
                         dF/dsig13,                                
                         dF/dsig22,                                
                         dF/dsig23,                                      
                         dF/disg33 };                                       

              gcov  =  { dF/drho12,   if _cholesky=0 and __covarr=0;                                       
                         dF/drho13,                                                                
                         dF/drho23  };  

              gcov  =  { dF/dS11,   if _cholesky=1 and __covarr=1;         
                         dF/dS12,                               
                         dF/dS13,                                
                         dF/dS22,                                
                         dF/dS23,                                      
                         dF/dS33 };                                       

              gcov  =  { dF/dS12,   if _cholesky=1 and __covarr=0;                                       
                         dF/dS13,                                                                
                         dF/dS23  };
                         
              gx    =   { dF/dx1,
                          dF/dx2,
                          dF/dx3 }     */
                         
proc (5) = gradcdfmvnanlpluscomp(mu,cov,x,s,indxcomp);
    local e2,om,invsig2,sqrtom,indx,indx1,kk1old,kk2old,indxcov,mm1,invsig,kk1,kk2,mm,gBcorcov,gomegacorcov,gmu,gcov,gx,rho,gx1,gx2,grho,P,s15;
    e2 = rows(x);
    om = diag(cov);
    invsig2 = 1/om;
    sqrtom = sqrt(om);
    invsig = 1/sqrtom;
    indx = indxcomp+indxcomp';    
    indx1 = ((-1)^indxcomp);
    indxcov = ((-1)^indx);
    kk2 = corrvc(cov); 
    kk2 = diagrv(kk2,ones(e2,1)); 
    kk2 = indxcov.*kk2;
    kk2old = kk2;
    kk1 = (x-mu).*invsig;
    kk1old = kk1;
    kk1 = indx1.*kk1;

    mm=_covarr; 
    mm1 = _cholesky;
    _cholesky=0;
    if e2<=4;
        s15=s;
    endif;
    if e2 ==1;
       P = cdfn(kk1);
       gx = (indx1).*pdfn(kk1);
       gmu=-invsig.*gx;      gcov=gx.*(-0.5*((invsig2).*kk1old));       gx=gx.*invsig;  
       if mm1;
         gcov = 2*sqrtom*gcov;
       endif;
    elseif e2==2;
       P=cdfbvn(kk1[1],kk1[2],kk2[1,2]);        
       rho = kk2[1,2];
       { gx1,gx2,gcov } = gradcdfbvn(kk1[1],kk1[2],rho); 
       gx1 = indx1[1]*gx1;   gx2 = indx1[2]*gx2;    gx=gx1|gx2;     /* gcov = indxcov[1,2]*gcov;  */
    elseif e2==3;    
        P = cdftvn(kk1[1],kk1[2],kk1[3],kk2[1,2],kk2[2,3],kk2[1,3]);
        { gx,gcov } = gradcdftvn(kk1,kk2[1,2]|kk2[1,3]|kk2[2,3]); 
       gx=indx1.*gx; 
    elseif e2==4;
       P = cdfqvn(kk1,kk2);
       { gx,gcov } = gradcdfqvn(kk1,kk2); 
       gx=indx1.*gx;
    else;   
       _covarr=0;
       { P,gmu,gcov,gx,s15 } = pdfmvnanalytic(zeros(e2,1),kk2,kk1,s);
       gx=indx1.*gx;
    endif;
    if e2 >=2;
       gcov = vecndup(indxcov.*(matndupdiagzerofull(gcov)));
       gmu = -(gx)./sqrtom;
       if mm==1;
         { gBcorcov,gomegacorcov } = gradcorcov(kk1old,sqrtom,kk2old);   
         gcov = gbcorcov*gx+gomegacorcov*gcov;
       endif;
       gx=-gmu;
       if mm1==1;
         if mm==1;
            gcov = (gcholeskycov(cov))*gcov;
         else;
            gcov = (gcholeskycor(cov))*gcov;
         endif;
       endif;
    endif;
    retp(P,gmu,gcov,gx,s15);
endp;



/***************************************************************************************************************************************************
                         Univariate and multivariate normal cumulative distribution function, and gradients
***************************************************************************************************************************************************/

/*
** cdrectmvnanl.src 
**
** Purpose: Develops the cumulative distribution function for the univariate or multivariate normal 
**

** Format:      { F,s1 } = cdrectmvnanl(mu,cov,x1,x2,s)
**
** Input:        mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix or KxK covariance matrix,
                 x1 represents points of truncation at lower end 
                 x2 represents points of truncation at upper end (integrals are x1 to x2)
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)    
                          
** Output:      F - 1x1 
                s1 - New seed that you may need in evaluating multiple functions in estimation when using SSJ for K>4   */
                 
proc (2) = cdrectmvnanl(mu,cov,x1,x2,s);
    local e2,P,newx,kk2,w,s15,sign,P1,comb,ecomb,j;
    e2 = rows(x1);
    if e2<=4;
        s15=s;
    endif;
    { sign,comb } = rectcombs(x1,x2);
    ecomb = rows(comb);
    P = 0;
    for j(1,ecomb,1);
       if e2 ==1;
           P = P+sign[j]*noncdfn(mu,cov,((comb[j,.])')); 
       elseif e2==2;
           P = P+sign[j]*noncdfbvn(mu,cov,((comb[j,.])'));
       elseif e2==3;
           P = P+sign[j]*noncdftvn(mu,cov,((comb[j,.])'));
       elseif e2==4;
           P = P+sign[j]*noncdfqvn(mu,cov,((comb[j,.])'));
       else;        
           { P1,s15 } = cdfmvnanalytic(mu,cov,((comb[j,.])'),s); 
           P=P+P1;
       endif;
    endfor;
    retp(P,s15);   
endp;

 
/*
** gradcdrectmvnanl.src 
**
** Purpose: Develops the gradients of cdfmvnanl 

** Format:      { P,gmu,gcov,gx1,gx2,s1 } = gradcdrectmvnanl(mu,cov,x1,x2,s)
**
** Input:       
                 mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix if _covarr=0; and cov is KxK covariance matrix if _covarr=1,
                 x1 represents lower truncation truncation; x2 represents upper truncation points 
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                 Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)  
                          
                 _covarr = 1     means cov is a covariance matrix; _covarr=0 means cov is actually a correlation matrix   
                 _Cholesky = 1 if you want gradients with respect to Cholesky of cov and not cov

** Output:       P is the rectangular probability value
                 gmu is the (Kx1) gradient vector of F with respect to the vector of means
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the correlation matrix elements if _covarr=0 and _cholesky=0 (K>1)
                     is the Kx(K+1)/2 gradient vector of F with respect to the covariance matrix elements if _covarr=1 and _cholesky=0; (K>1)
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to variance if _covarr=1; if _covarr=0, ignore gcov;
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the cholesky of the correlation matrix elements if _covarr=0 and _cholesky=1
                     is the Kx(K+1)/2 gradient vector of F with respect to the cholesky of the covariance matrix elements if _covarr=1 and _cholesky=1;
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to standard deviation if _covarr=1; if _covarr=0, ignore gcov;
                 gx1 represents the (Kx1) gradient vector of F with respect to lower truncation points
                 gx2 represents the (Kx1) gradient vector of F with respect to upper truncation points                 
                 s1 is a new seed value that is relevant only for the SSJ method (and for dimension of x>4);


                 mu  = {  mu1   
                          mu2   
                          mu3 };

                 if _covarr=1;

                 cov = { sig11    sig12   sig13,        if _cholesky=0;   chol(cov)  =  { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

                 if _covarr=0;

                 cov = {   1      rho12   rho13,        if _cholesky=0;   chol(cov) = {   1       S12         S13,                     if _cholesky=1
                         rho12       1    rho23,                                          0   sqrt(1-S12^2)   S23,
                         rho13    rho23      1   };                                       0         0        sqrt(1-S13^2-S23^2)  }


               x1 = xl1
                    xl2
                    xl3 ;
                    
               x2 = xu1
                    xu2
                    xu3 
                    
               gmu  =  { dF/dmu1,
                         dF/dmu2,
                         dF/dmu3 };
                         
              gcov  =  { dF/dsig11,   if _cholesky=0 and __covarr=1;         
                         dF/dsig12,                               
                         dF/dsig13,                                
                         dF/dsig22,                                
                         dF/dsig23,                                      
                         dF/disg33 };                                       

              gcov  =  { dF/drho12,   if _cholesky=0 and __covarr=0;                                       
                         dF/drho13,                                                                
                         dF/drho23  };  

              gcov  =  { dF/dS11,   if _cholesky=1 and __covarr=1;         
                         dF/dS12,                               
                         dF/dS13,                                
                         dF/dS22,                                
                         dF/dS23,                                      
                         dF/dS33 };                                       

              gcov  =  { dF/dS12,   if _cholesky=1 and __covarr=0;                                       
                         dF/dS13,                                                                
                         dF/dS23  };
                         
              gx1    =   { dF/dxl1,                  gx2 = { dF/dxu1,
                          dF/dxl2,                           dF/dxu2,
                          dF/dxl3 }                          dF/dxu3 }  */
                         
proc (6) = gradcdrectmvnanl(mu,cov,x1,x2,s);
    local e2,sign,comb,indxa,ecomb,indxb,s15,gmu1,gcov1,gx1a,gx2b,mm1,j,gmu,gcov,gx,P,P1,gxx,gxx1,gxx2;
    e2 = rows(x1); 
    if e2<=4;
        s15=s;
    endif;
    { sign,comb,indxa,indxb } = rectcombsforgrad(x1,x2);
    ecomb = rows(comb);
    gmu1 = zeros(e2,1);
    if _covarr==1 or (_covarr==0 and e2==1);
       gcov1 = zeros(e2*((e2+1)/2),1);
    elseif _covarr==0 and e2>1;
       gcov1 = zeros(e2*((e2-1)/2),1);        
    endif;   
    gx1a = zeros(e2,1);
    gx2b = zeros(e2,1);
    P=0;
    mm1 = _cholesky;
    _cholesky=0;
    for j(1,ecomb,1); 
       if e2 ==1;
          P = P+sign[j]*noncdfn(mu,cov,((comb[j,.])')); 
          { gmu,gcov,gx } = gradnoncdfn(mu,cov,((comb[j,.])'));
       elseif e2==2;
          P = P+sign[j]*noncdfbvn(mu,cov,((comb[j,.])'));
          { gmu,gcov,gx } = gradnoncdfbvn(mu,cov,((comb[j,.])')); 
          if _covarr==0;
             gcov = gcov[2];
          endif;
       elseif e2==3;
          P = P+sign[j]*noncdftvn(mu,cov,((comb[j,.])'));
          { gmu,gcov,gx } = gradnoncdftvn(mu,cov,((comb[j,.])'));           
          if _covarr==0;
             gcov = gcov[2:3]|gcov[5];
          endif;
       elseif e2==4;
          P = P+sign[j]*noncdfqvn(mu,cov,((comb[j,.])'));
          { gmu,gcov,gx } = gradnoncdfqvn(mu,cov,((comb[j,.])'));  
          if _covarr==0;
             gcov = gcov[2:4]|gcov[6:7]|gcov[9];
          endif;
       else;        
          { P1,gmu,gcov,gx,s15 } = pdfmvnanalytic(mu,cov,((comb[j,.])'),s);  
          P=P+P1;
       endif;
       gmu1 = sign[j]*gmu+gmu1;
       gcov1 = sign[j]*gcov+gcov1;
       gxx = sign[j]*gx;
       gx1a = gx1a+gxx.*((indxa[j,.])');
       gx2b = gx2b+gxx.*((indxb[j,.])');
    endfor;  
    if mm1 and e2==1;
         gcov1 = 2*sqrt(cov)*gcov1;
    endif;
    if mm1==1 and e2>1;
       if _covarr==1;
          gcov1 = (gcholeskycov(cov))*gcov1;
       else;
          gcov1 = (gcholeskycor(cov))*gcov1;
       endif;
    endif;
    retp(P,gmu1,gcov1,gx1a,gx2b,s15);
endp;

/*
** cdfmvnanl.src 
**
** Purpose: Develops the cumulative distribution function for the univariate or multivariate normal 
**

** Format:      { F,s1 } = cdfmvnanl(mu,cov,x,s)
**
** Input:        mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix or KxK covariance matrix,
                 x represents points of truncation from above (integrals are -infinity to x)
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)    
                          
** Output:      F - 1x1 
                s1 - New seed that you may need in evaluating multiple functions in estimation when using SSJ for K>4   */


                 
proc (2) = cdfmvnanl(mu,cov,x,s);
    local e2,P,newx,kk2,w,s15;
    e2 = rows(x);
    if e2<=4;
        s15=s;
    endif;
    if e2 ==1;
       retp((noncdfn(mu,cov,x)),s15);
    elseif e2==2;
       retp((noncdfbvn(mu,cov,x)),s15);
    elseif e2==3;
       retp((noncdftvn(mu,cov,x)),s15);
    elseif e2==4;
       retp((noncdfqvn(mu,cov,x)),s15);
    else;      
       { P,s15 } = cdfmvnanalytic(mu,cov,x,s); 
       retp(P,s15);   
    endif;
endp;

 
/*
** gradcdfmvnanl.src 
**
** Purpose: Develops the gradients of cdfmvnanl 

** Format:      { P,gmu,gcov,gx,s1 } = gradcdfmvnanl(mu,cov,x,s)
**
** Input:        mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix if _covarr=0; and cov is KxK covariance matrix if _covarr=1,
                 x represents points of truncation from above (integrals are -infinity to x)
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                 Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)  
                          
                 _covarr = 1     means cov is a covariance matrix; _covarr=0 means cov is actually a correlation matrix  
                 ALWAYS SPECIFY _Covarr BEFORE ANY CALL TO GRADCDFMVNANL; Also, this is written so that gradients are with respect to 
                 actual covariance elements. If you want gradients with respect to cholesky of covariance elements, do this after you call
                 gradcdfmvnanl and get gcov from the procedure:
                 
                 if _covarr;
                    gchol = (gcholeskycov(cov))*gcov;
                 else;
                    gchol = (gcholeskycor(cov))*gcov;
                 endif;
                 

** Output:       P is the scalar probability value
                 gmu is the (Kx1) gradient vector of F with respect to the vector of means
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the correlation matrix elements if _covarr=0  (K>1)
                     is the Kx(K+1)/2 gradient vector of F with respect to the covariance matrix elements if _covarr=1  (K>1)
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to variance if _covarr=1; if _covarr=0, ignore gcov;
                 s1 is a new seed value that is relevant only for the SSJ method (and for dimension of x>4);


                 mu  = {  mu1   
                          mu2   
                          mu3 };

                 if _covarr=1;

                 cov = { sig11    sig12   sig13,          
                         sig12    sig22   sig23,             
                         sig13    sig23   sig33   };      

                 if _covarr=0;

                 cov = {   1      rho12   rho13,        
                         rho12       1    rho23,         
                         rho13    rho23      1   };      


                 gmu  =  { dF/dmu1,
                           dF/dmu2,
                           dF/dmu3 };
                         
                 gcov  =  { dF/dsig11,   if _covarr=1;         
                         dF/dsig12,                               
                         dF/dsig13,                                
                         dF/dsig22,                                
                         dF/dsig23,                                      
                         dF/disg33 };                                       

                 gcov  =  { dF/drho12,   if _covarr=0;                                       
                           dF/drho13,                                                                
                           dF/drho23  };  
                         
                 gx    =   { dF/dx1,
                          dF/dx2,
                          dF/dx3 }    */
                         
proc (5) = gradcdfmvnanl(mu,cov,x,s);
    local e2,om,invsig2,sqrtom,mm1,invsig,kk1,kk2,mm,gBcorcov,gomegacorcov,gmu,gcov,gx,rho,gx1,gx2,grho,P,s15;
    e2 = rows(x); 
    if e2<=4;
        s15=s;
    endif;
    if e2 ==1;
       P= noncdfn(mu,cov,x);
       { gmu,gcov,gx } = gradnoncdfn(mu,cov,x);
    elseif e2==2;
       P = noncdfbvn(mu,cov,x);
       { gmu,gcov,gx } = gradnoncdfbvn(mu,cov,x);
       if _covarr==0;
           gcov = gcov[2];
       endif;
    elseif e2==3;
       P = noncdftvn(mu,cov,x);
       { gmu,gcov,gx } = gradnoncdftvn(mu,cov,x);
        if _covarr==0;
           gcov = gcov[2:3]|gcov[5];
        endif;
    elseif e2==4;
       P = noncdfqvn(mu,cov,x);
       { gmu,gcov,gx } = gradnoncdfqvn(mu,cov,x);
        if _covarr==0;
           gcov = gcov[2:4]|gcov[6:7]|gcov[9];
        endif;
    else;        
       { P,gmu,gcov,gx,s15 } = pdfmvnanalytic(mu,cov,x,s);    
    endif;
    retp(P,gmu,gcov,gx,s15);
endp;


/***************************************************************************************************************************************************
                 Complement of Univariate and multivariate normal cumulative distribution function, and gradients
***************************************************************************************************************************************************/

/*
** cdfmvnanlcomp.src 
**
** Purpose: Develops the complement of cdfmvnanalytic 
**
** This is very simple, but does not seem to have been documented well in the literature;
** Integral of pdfmvn from x to infinity (which is cdfmvnanalyticc) is nothing but integral of pdfmvn from -infinity to -x (which is cdfmvnanalytic);
   see test.src in g:/gauss/com/new cdf approx

** Format:      { F,s1 } = cdfmvnanlcomp(mu,cov,x,s)
**
** Input:        mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix or KxK covariance matrix
                 x represents points of truncation from below (integrals are x to infinity)
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)    

                        
** Output:      F - 1x1 
                s1 - New seed that you may need in evaluating multiple functions in estimation when using SSJ for K>4   */


/* Be careful here; you cannot use noncdfn, noncdfbvn, noncdftvn, noncdfqvn, etc. below because the negative sign on x in the complement 
   computation should be applied after you first do (x-mu)./std(x) rather than doing (-x-mu)./std(x), which is what the noncd...procedures 
   do; for same reason, when using cdfmvnanlytic for the complement computation below, you MUST use cdfmvnanalytic(zeros(e2,1),kk2,-newx,s) as 
   below so that you are first computing (x-mu)./std(x) in newx and then doing -newx; so provide newx as input, use correlation matrix
   as input, and put zeros for means */
                 
proc (2) = cdfmvnanlcomp(mu,cov,x,s);
    local e2,P,newx,kk2,w,s15;
    e2 = rows(x);
    kk2 = corrvc(cov);
    kk2 = diagrv(kk2,ones(e2,1)); 
    w = sqrt(diag(cov));
    newx = (x-mu)./w;
    if e2<=4;
        s15=s;
    endif;
    if e2 ==1;
       retp(cdfn(-newx));
    elseif e2==2;
       retp((cdfbvn(-newx[1],-newx[2],kk2[1,2])),s15);
    elseif e2==3;
       retp((cdftvn(-newx[1],-newx[2],-newx[3],kk2[1,2],kk2[2,3],kk2[1,3])),s15);
    elseif e2==4;
       retp((cdfqvn(-newx,kk2)),s15);
    else;        
       { P,s15 } = cdfmvnanalytic(zeros(e2,1),kk2,-newx,s); 
        retp(P,s15);   
    endif;
endp;

 
/*
** gradcdfmvnanlcomp.src 
**
** Purpose: Develops the gradients of complement of cdfmvnanalytic 
**
** This is very simple, but does not seem to have been documented well in the literature;
** Integral of pdfmvn from x to infinity (which is cdfmvnanalyticc) is nothing but integral of pdfmvn from -infinity to -x (which is cdfmvnanalytic)

** Format:      { P,gmu,gcov,gx,s1 } = gradcdfmvnanlcomp(mu,cov,x,s)
**
** Input:        P is the probability value
                 mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix if _covarr=0; and cov is KxK covariance matrix if _covarr=1,
                 x represents points of truncation from below (integrals are x to infinity)
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                 Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)  
                          
                 _covarr = 1     means cov is a covariance matrix; _covarr=0 means cov is actually a correlation matrix   
                 _Cholesky = 1 if you want gradients with respect to Cholesky of cov and not cov

** Output:       gmu is the (Kx1) gradient vector of F with respect to the vector of means
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the correlation matrix elements if _covarr=0 and _cholesky=0 (K>1)
                     is the Kx(K+1)/2 gradient vector of F with respect to the covariance matrix elements if _covarr=1 and _cholesky=0; (K>1)
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to variance if _covarr=1; if _covarr=0, ignore gcov;
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the cholesky of the correlation matrix elements if _covarr=0 and _cholesky=1
                     is the Kx(K+1)/2 gradient vector of F with respect to the cholesky of the covariance matrix elements if _covarr=1 and _cholesky=1;
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to standard deviation if _covarr=1; if _covarr=0, ignore gcov;                 gx represents the (Kx1) gradient vector of F with respect to the points of truncation from below (integrals are x to infinity)
                 s1 is a new seed value that is relevant only for the SSJ method (and for dimension of x>4);


                 mu  = {  mu1   
                          mu2   
                          mu3 };

                 if _covarr=1;

                 cov = { sig11    sig12   sig13,        if _cholesky=0;   chol(cov)  =  { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

                 if _covarr=0;

                 cov = {   1      rho12   rho13,        if _cholesky=0;   chol(cov) = {   1       S12         S13,                     if _cholesky=1
                         rho12       1    rho23,                                          0   sqrt(1-S12^2)   S23,
                         rho13    rho23      1   };                                       0         0        sqrt(1-S13^2-S23^2)  }


               gmu  =  { dF/dmu1,
                         dF/dmu2,
                         dF/dmu3 };
                         
              gcov  =  { dF/dsig11,   if _cholesky=0 and __covarr=1;         
                         dF/dsig12,                               
                         dF/dsig13,                                
                         dF/dsig22,                                
                         dF/dsig23,                                      
                         dF/disg33 };                                       

              gcov  =  { dF/drho12,   if _cholesky=0 and __covarr=0;                                       
                         dF/drho13,                                                                
                         dF/drho23  };  

              gcov  =  { dF/dS11,   if _cholesky=1 and __covarr=1;         
                         dF/dS12,                               
                         dF/dS13,                                
                         dF/dS22,                                
                         dF/dS23,                                      
                         dF/dS33 };                                       

              gcov  =  { dF/dS12,   if _cholesky=1 and __covarr=0;                                       
                         dF/dS13,                                                                
                         dF/dS23  }; 
                         
              gx    =   { dF/dx1,
                          dF/dx2,
                          dF/dx3 }     */
                         
proc (5) = gradcdfmvnanlcomp(mu,cov,x,s);
    local e2,om,invsig2,sqrtom,mm1,invsig,kk1,kk2,mm,gBcorcov,gomegacorcov,gmu,gcov,gx,rho,gx1,gx2,grho,P,s15;
    e2 = rows(x);
    om = diag(cov);
    invsig2 = 1/om;
    sqrtom = sqrt(om);
    invsig = 1/sqrtom;
    kk1 = (x-mu).*invsig;
    kk2 = corrvc(cov);  
    kk2 = diagrv(kk2,ones(e2,1)); 
    mm=_covarr; 
    mm1 = _cholesky;
    _cholesky=0;
    if e2<=4;
        s15=s;
    endif;
    if e2 ==1;
       P=cdfn(-kk1);
       gx = -pdfn(-kk1);
       gmu=-invsig.*gx;      gcov=gx.*(-0.5*((invsig2).*kk1));       gx=gx.*invsig;  
       if mm1;
         gcov = 2*sqrtom*gcov;
       endif;
    elseif e2==2;
       rho = kk2[1,2];
       P = cdfbvn(-kk1[1],-kk1[2],rho);
       { gx1,gx2,gcov } = gradcdfbvn(-kk1[1],-kk1[2],rho); 
       gx1 = -gx1;   gx2 = -gx2;    gx=gx1|gx2;
    elseif e2==3;    
       P= cdftvn(-kk1[1],-kk1[2],-kk1[3],kk2[1,2],kk2[2,3],kk2[1,3]);
       { gx,gcov } = gradcdftvn(-kk1,kk2[1,2]|kk2[1,3]|kk2[2,3]); 
       gx=-gx; 
    elseif e2==4;
       P = cdfqvn(-kk1,kk2);
       { gx,gcov } = gradcdfqvn(-kk1,kk2); 
       gx=-gx;
    else;   
       _covarr=0;
       { P,gmu,gcov,gx,s15 } = pdfmvnanalytic(zeros(e2,1),kk2,-kk1,s);
       gx=-gx;
    endif;
    if e2 >=2;
       gmu = -(gx)./sqrtom;
       if mm==1;
         { gBcorcov,gomegacorcov } = gradcorcov(kk1,sqrtom,kk2);   
         gcov = gbcorcov*gx+gomegacorcov*gcov;
       endif;
       gx = -gmu;
       if mm1==1;
         if mm==1;
            gcov = (gcholeskycov(cov))*gcov;
         else;
            gcov = (gcholeskycor(cov))*gcov;
         endif;
       endif;
    endif;
    retp(P,gmu,gcov,gx,s15);
endp;
 

/***************************************************************************************************************************************************
                     Miscellaneous procedures for computing cumulative distribution function and its complement
***************************************************************************************************************************************************/

/*
**
** noncdfn.src 
**
** Purpose: Develops the cumulative distribution function value of the non-standard univariate normal 
**
** Format:      { P } = noncdfn(mu,sig,x)
**
** Input:        mu is the vector of means (Nx1), sig is the variance vector (Nx1), x is the abscissa points (Nx1), 
**
**
** Output:      P  - CDF function value   */
 
proc (1) = noncdfn(mu,sig,x);
    local w;
    w = (x-mu)./(sqrt(sig));
    retp(cdfn(w));
endp;    
 
 
/*
** gradnoncdfn.src 
**
** Purpose: Develops gradients with respect to the non-standard univariate normal CD function 
**
** Format:      { gmu,gcov,gx } = gradnoncdfn(mu,sig2,x)
**
** Input:        mu is the vector of means (Nx1), sig2 is the variance vector (Nx1), x is the abscissa points (Nx1), 
**
**Global :      _Cholesky = 1 if you want gcov with respect to standard deviation as opposed to variance
** Output:      gmu - Nx1 vector, gradients of cdfn with respect to mu
                gcov  - Nx1 vector, gradients of cdfn with respect to sig squared (w.r.t variance if _cholesky=0 and w.r.t standard deviation if _cholesky=1;)  
                gx  - Nx1 vector, gradients of cdfn with respect to w      */

proc (3) = gradnoncdfn(mu,sig2,x);
   local invsig2,invsig,w,gcov,sqrtom;
   invsig2 = 1/sig2;
   invsig = sqrt(invsig2);
   w = (x-mu).*invsig;
   gcov = pdfn(w).*(-0.5*((invsig2).*w));
   sqrtom = sqrt(sig2);
   if _cholesky;
      gcov = 2*sqrtom.*gcov;
   endif;    
   retp(-invsig.*pdfn(w),gcov,pdfn(w).*invsig);
endp;
 

/*
** gradcdfbvn.src 
**
** Purpose: Develops gradients with respect to the standard bivariate normal cumulative function 
**
** Format:      { gw1,gw2,grho } = gradcdfbvn(w1,w2,rho)
**
** Input:        w1 and w2 are the abscissae points (Nx1), rho is the correlation vector (Nx1)
**
**
** Output:      gw1  - Nx1 vector, gradients of cdfbvn with respect to w1
                gw2  - Nx1 vector, gradients of cdfbvn with respect to w2
                grho - Nx1 vector, gradients of cdfbvn with respect to rho  */


proc (3) = gradcdfbvn(w1,w2,rho);
   local rhotilde,tr1,tr2,pdf2,gw1,gw2,grho;
   rhotilde = sqrt((1-rho^2));
   tr1 = (w2-rho.*w1)./rhotilde; 
   tr2 = (w1-rho.*w2)./rhotilde;
   pdf2 = (1/rhotilde).*(pdfn(w1).*pdfn(tr1));
   gw1 = pdfn(w1).*cdfn(tr1);
   gw2 = pdfn(w2).*cdfn(tr2);
   grho = pdf2;
   retp(gw1,gw2,grho);
endp;    

/* noncdfbvn.src

** Purpose: The non-standard bivariate cumulative distrubution function  
**
** Format:      { P } = noncdfbvn(mu,cov,x)
**
** Input:        mu is the (2x1) vector of means, cov is the 2x2 covariance matrix, x represents the abscissae points (2x1);
**
**
** Output:      P    */

proc (1) = noncdfbvn(mu,cov,x);
    local om,sqrtom,kk1,kk2,rho;
    om = diag(cov);
    sqrtom = sqrt(om);
    kk1 = (x-mu)./sqrtom;
    kk2 = corrvc(cov);
    /* This next line is needed because some diagonal elements of kk2 computed above are slightly greater than 1 because of the algebra in computing
       correlations from corrvc, so ensuring that diagonal elements are no more than 1 */
    kk2 = diagrv(kk2,ones(2,1));     
    rho = kk2[1,2];
    retp(cdfbvn(kk1[1],kk1[2],rho));
endp;    

 
/*
** gradnoncdfbvn.src 
**
** Purpose: Develops gradients with respect to the non-standard bivariate normal cumulative function 
**
** Format:      { gmu,gcov,gx } = gradnoncdfbvn(mu,cov,x)
**
** Input:        mu is the (2x1) vector of means, cov is the 2x2 covariance matrix, x represents the abscissae points (2x1);
**
**
** Output:      gmu  - 2x1 vector, gradients of noncdfbvn with respect to mu
                gcov - 3x1 vector, gradients of noncdfbvn with respect to cov -- upper diagonal elements 
                gx   - 2x1 vector, gradients of noncdfbvn with respect to absisccae  

** Global: Cholesky = 1 if gradients with respect to Cholesky matrix of covariance; =0 if gradients with respect to cov; if Cholesky=1,
                gcov is with respect to Cholesky elements

**  x = { x1,x2 };  
           
**  mu = { mu1,mu2 };

**  cov = { cov11  cov12,               cov is a covariance matrix
            cov12  cov22 };

**  S    = { S11   S12,              cov = S'*S;
             0     S22   };
             
P  = noncdfbvn(x,mu,cov)

OUTPUT

**  gmu      =           { dP/dmu1,
                           dP/dmu2  };                           
                                               
IF _cholesky=0,

**  gcov      =          { dP/dcov11         
                           dP/dcov12     
                           dP/dcov22 };   

                         
IF _cholesky=1,

**  gcov      =          { dP/dS11    
                           dP/dS12       
                           dP/dS22 };     

**  gx      =            { dP/dx1,
                           dP/dx2  };    */


proc (3) = gradnoncdfbvn(mu,cov,x);
    local om,sqrtom,kk1,kk2,rho,gw1,gw2,grho,gbcorcov,gomegacorcov,gcov,gmu,gx;
    om = diag(cov);
    sqrtom = sqrt(om);
    kk1 = (x-mu)./sqrtom;
    kk2 = corrvc(cov);  
    kk2 = diagrv(kk2,ones(2,1));     
    rho = kk2[1,2];
    { gw1,gw2,grho } = gradcdfbvn(kk1[1],kk1[2],rho); 
    { gBcorcov,gomegacorcov } = gradcorcov(kk1,sqrtom,kk2);

    gmu = -(gw1|gw2)./sqrtom;
    gcov = gbcorcov*(gw1|gw2)+gomegacorcov*grho;
    gx = -gmu;
    if _cholesky==1;
        gcov = gcholeskycov(cov)*gcov;
    endif;  
    retp(gmu,gcov,gx);
endp;    
 


/*
** gradcdfbvnbycdfn.src 
**
** Purpose: Develops gradients with respect to the ratio of a standard bivariate normal cumulative function to a standard univariate 
            normal cumulative distribution
**
** Format:      { gw1,gw2,grho } = gradcdfbvnbycdfn(w1,w2,rho)
**
** Input:        w1 and w2 are the abscissae points (Nx1), rho is the correlation vector (Nx1)
**
**
** Output:      gw1  - Nx1 vector, gradients of P= cdfbvn(w1,w2,rho)/cdfn(w1) with respect to w1
                gw2  - Nx1 vector, gradients of P with respect to w2
                grho - Nx1 vector, gradients of P with respect to rho  
 

** Global: Cholesky = 1 if gradients with respect to Cholesky matrix of covariance; =0 if gradients with respect to cov; if Cholesky=1,
                gcov is with respect to Cholesky elements   */




proc (3) = gradcdfbvnbycdfn(w1,w2,rho);
    local gw1,gw2,gw1new,bivarcdf,univarcdf,grho;
    bivarcdf = cdfbvn(w1,w2,rho);
    univarcdf = cdfn(w1);
    { gw1,gw2,grho }  = gradcdfbvn(w1,w2,rho);
    gw1new = (univarcdf.*gw1-bivarcdf.*pdfn(w1))./(univarcdf^2);
    retp(gw1new,gw2./univarcdf,grho./univarcdf);
endp;    
 

/* All inputs and outputs are same as gradnoncdfbvn, but this procedure is for finding gradients of the ratio of non-standard bivariate cdf
   to the non-standard univariate cdf; P = bivariate cdf (x1,x2; mu1,mu2; cov)/univariate cdf (x1,mu1,cov[1,1]);  */

proc (3) = gradnoncdfbvnbycdfn(mu,cov,x);
    local om,sqrtom,kk1,kk2,rho,gw1,gw2,grho,gbcorcov,gomegacorcov,gcov,gmu,gx;
    om = diag(cov);
    sqrtom = sqrt(om);
    kk1 = (x-mu)./sqrtom;
    kk2 = corrvc(cov);  
    kk2 = diagrv(kk2,ones(2,1));     
    rho = kk2[1,2];
    { gw1,gw2,grho } = gradcdfbvnbycdfn(kk1[1],kk1[2],rho); 
    { gBcorcov,gomegacorcov } = gradcorcov(kk1,sqrtom,kk2);
    gmu = -(gw1|gw2)./sqrtom;
    gcov = gbcorcov*(gw1|gw2)+gomegacorcov*grho;
    gx = -gmu;
    if _cholesky==1;
        gcov = gcholeskycov(cov)*gcov;
    endif;
    retp(gmu,gcov,gx);
endp;    
 

/* Cumulative distribution function of non-standard trivariate cumulative distribution function */
/* mu - 3x1 vector, cov - 3x3 matrix, x - 3x1 vector of abscissa */

proc (1) = noncdftvn(mu,cov,x);
    local om,sqrtom,kk1,kk2;
    om = diag(cov);
    sqrtom = sqrt(om);
    kk1 = (x-mu)./sqrtom;
    kk2 = corrvc(cov);  
    kk2 = diagrv(kk2,ones(3,1)); 
    retp(cdftvn(kk1[1],kk1[2],kk1[3],kk2[1,2],kk2[2,3],kk2[1,3]));
endp;    


/*
** gradcdftvn.src 
**
** Purpose: Develops gradients with respect to the standard trivariate normal cumulative function 
**
** Format:      { gw,grho } = gradcdftvn(w,cor)
**
** Input:        w is a vector of abscissae points (Kx1), cor refers to the elements of the correlation matrix (Kx1, rho12, rho13, rho23)
**
**
** Output:      gw  - 3x1 vector, gradients of cdftvn with respect to w
                grho - 3x1 vector, gradients of cdftvn with respect to upper triangular cor elements  


so, w = { w1,w2,w3 }, cor = 1 rho12 rho13,
                                1   rho23,
                                       1   };

gw provides gradients with respect to w1,w2, w3, and grho provides gradients arranged with respect to rho12, rho13, and then rho 23 */
   
proc (2) = gradcdftvn(h,r);
    local tvn,epst,pt,h1,h2,h3,r12,r13,r23,wg,xg,rua,rub,res,r12t,r13t,rr2,rr3,fc;
    local gg;
    local cdfbvn_h2_h3, cdfn_h1;
    local d_tvn,d_a,d_b,d_corr;
    local d_fc_h1,d_fc_h2,d_fc_h3,d_fc_r12,d_fc_r13,d_fc_r23;
    local d_res_h1,d_res_h2,d_res_h3,d_res_r12,d_res_r13,d_res_r23;
    local temp_pntgnd_grad,temp_sincs_grad;
    local d_rua_r12,d_rub_r13;
    local d_r12t_r12,d_rr2_r12,d_r13t_r13,d_rr3_r13,d_tvn_unsorted;
    local enteredLoop1, enteredLoop2;
    local temp_bvn_grad,temp_bvn_grad2,tempVal1,tempVal2;
    //h = parm[1:3];r = parm[4:6];    

    epst = 1e-7;    pt = pi/2;    
    h1 = h[1];      h2 = h[2];      h3 = h[3];
    r12 = r[1];     r13 = r[2];     r23 = r[3];

    gg = zeros(1,6);
    temp_bvn_grad = zeros(3,1);
    temp_bvn_grad2 = zeros(3,1);
    enteredLoop1 = 0; enteredLoop2 = 0;
    if ( abs(r12) - abs(r13) > 0.0000001 ) ;
        h2 = h3;    h3 = h[2];
        r12 = r13;  r13 = r[1];enteredLoop1=1;
    endif;
    if ( abs(r13) - abs(r23) > 0.0000001 ) ;
        h1 = h2;    h2 = h[1];
        r23 = r13;  r13 = r[3];enteredLoop2=1;
    endif;

    
        if (abs(h1) + abs(h2) + abs(h3) < epst); 
            gg[4] = ( 2* 1/sqrt(1-r12^2) /pi )/8;        gg[5] = ( 2* 1/sqrt(1-r13^2) /pi )/8;        gg[6] = ( 2* 1/sqrt(1-r23^2) /pi )/8;
            d_tvn = gg;
        elseif (abs(r12) + abs(r13) < epst);
            tempVal1 = cdfn(h1);tempVal2 =cdfbvn( h2, h3, r23 ); 
            gg[1] = pdfn(h1)*tempVal2;
            { temp_bvn_grad[1],temp_bvn_grad[2],temp_bvn_grad[3] } = gradcdfbvn( h2, h3, r23 );
            gg[2] = tempVal1*temp_bvn_grad[1];
            gg[3] = tempVal1*temp_bvn_grad[2];
            gg[6] = tempVal1*temp_bvn_grad[3];
            d_tvn = gg;
        elseif (abs(r13) + abs(r23) < epst);
            tempVal1 = cdfn(h3);tempVal2 =cdfbvn( h1, h2, r12 );
            gg[3] = pdfn(h3)*tempVal2;
             { temp_bvn_grad[1],temp_bvn_grad[2],temp_bvn_grad[3] } = gradcdfbvn( h1, h2, r12 ); 
            gg[1] = tempVal1*temp_bvn_grad[1];
            gg[2] = tempVal1*temp_bvn_grad[2];
            gg[4] = tempVal1*temp_bvn_grad[3];
            d_tvn = gg;
        elseif (abs(r12) + abs(r23) < epst);
            tvn = cdfn(h2)*cdfbvn( h1, h3, r13 );
            tempVal1 = cdfn(h2);tempVal2 =cdfbvn( h1, h3, r13 );
            gg[2] = pdfn(h2)*tempVal2;
            { temp_bvn_grad[1],temp_bvn_grad[2],temp_bvn_grad[3] } = gradcdfbvn( h1, h3, r13 );
            gg[1] = tempVal1*temp_bvn_grad[1];
            gg[3] = tempVal1*temp_bvn_grad[2];
            gg[5] = tempVal1*temp_bvn_grad[3];
            d_tvn = gg;
        elseif (1 - r23 < epst);
            tvn = cdfbvn( h1, minc( h2|h3 ), r12 );"here";
            { temp_bvn_grad[1],temp_bvn_grad[2],temp_bvn_grad[3] } = gradcdfbvn( h1, minc( h2|h3 ), r12 );
            gg[1] = temp_bvn_grad[1];
            if(h2 eq h3);
                gg[2] = temp_bvn_grad[2];
                gg[3] = temp_bvn_grad[2];
            elseif(h2 lt h3);
                gg[2] = temp_bvn_grad[2];
            else;
                gg[3] = temp_bvn_grad[2];
            endif;
            gg[4] = temp_bvn_grad[3];
            d_tvn = gg;
        elseif (r23 + 1 < epst and h2 > -h3 );
            { temp_bvn_grad[1],temp_bvn_grad[2],temp_bvn_grad[3] }  = gradcdfbvn( h1, h2, r12 ) ;
            { temp_bvn_grad2[1],temp_bvn_grad2[2],temp_bvn_grad2[3] } = gradcdfbvn( h1, -h3, r12 );
            gg[1] = temp_bvn_grad[1] - temp_bvn_grad2[1];
            gg[2] = temp_bvn_grad[2] ;
            gg[3] = temp_bvn_grad2[2];
            gg[4] = temp_bvn_grad[3] - temp_bvn_grad2[3];        
            d_tvn = gg;
        else;
    
        //Compute singular TVN value
            cdfbvn_h2_h3 = cdfbvn( h2, h3, r23 );
            cdfn_h1      = cdfn(h1);
            tvn = cdfn_h1*cdfbvn_h2_h3;
        
            d_a     = pdfn(h2) .* cdfn((h3- r23 .* h2) ./ sqrt(1-r23 .* r23) );
            d_b     = pdfn(h3) .* cdfn((h2- r23 .* h3) ./ sqrt(1-r23 .* r23) );
            d_corr  = (exp(-0.5*(h2^2 + h3^2 - 2*r23 .* h2 .* h3   ) ./ (1-r23 .* r23) )) ./ sqrt(1-r23 .* r23)/(2*pi);
        
            d_tvn = (pdfn(h1)*cdfbvn_h2_h3)~(cdfn_h1*d_a)~(cdfn_h1*d_b)~0~0~(cdfn_h1*d_corr);       
            wg = { 0.1279381953467518 0.1258374563468280 0.1216704729278031 0.1155056680537265 0.1074442701159659 .09761865210411358 .08619016153195296 .07334648141108081 .05929858491543594 .04427743881742087 .02853138862893389 .01234122979998693 };
            xg = { .06405689286260559 0.1911188674736164 0.3150426796961635 0.4337935076260450 0.5454214713888396 0.6480936519369754 0.7401241915785546 0.8200019859739028 0.8864155270044012 0.9382745520027329 0.9747285559713096 0.9951872199970214 };
            rua = asin( r12 ); rub = asin( r13 ); res = 0;
            d_rua_r12 = 1/sqrt(1-r12^2);
            d_rub_r13 = 1/sqrt(1-r13^2);
            d_res_h1 = 0;d_res_h2 = 0;d_res_h3 = 0;d_res_r12=0;d_res_r13=0;d_res_r23=0;
            for j (1,12,1);
                fc = 0;d_fc_h1 = 0;d_fc_h2 = 0;d_fc_h3 = 0;d_fc_r12=0;d_fc_r13=0;d_fc_r23=0;
                temp_sincs_grad = sincs_grad( rua*( 1 - xg[j] )/2 ); 
                r12t = temp_sincs_grad[3];
                rr2  = temp_sincs_grad[4];
                d_r12t_r12 = temp_sincs_grad[1]*( 1 - xg[j] )/2*d_rua_r12;
                d_rr2_r12  = temp_sincs_grad[2]*( 1 - xg[j] )/2*d_rua_r12;
    
                temp_sincs_grad = sincs_grad( rub*( 1 - xg[j] )/2 ); 
                r13t = temp_sincs_grad[3];
                rr3  = temp_sincs_grad[4];
                d_r13t_r13 = temp_sincs_grad[1]*( 1 - xg[j] )/2*d_rub_r13;
                d_rr3_r13  = temp_sincs_grad[2]*( 1 - xg[j] )/2*d_rub_r13;
    
                if ( abs(rua) > 0 );
                    temp_pntgnd_grad = pntgnd_grad( h1, h2, h3, r13t, r23, r12t, rr2 );
                    fc = fc + rua*temp_pntgnd_grad[8];
                    d_fc_h1 = d_fc_h1 + rua*temp_pntgnd_grad[1];
                    d_fc_h2 = d_fc_h2 + rua*temp_pntgnd_grad[2];
                    d_fc_h3 = d_fc_h3 + rua*temp_pntgnd_grad[3];
                    d_fc_r12 = d_fc_r12 + d_rua_r12 * temp_pntgnd_grad[8] + rua *(temp_pntgnd_grad[6]*d_r12t_r12+temp_pntgnd_grad[7]*d_rr2_r12);
                    d_fc_r13 = d_fc_r13 + rua *(temp_pntgnd_grad[4]*d_r13t_r13);
                    d_fc_r23 = d_fc_r23 + rua*temp_pntgnd_grad[5];
                endif;
                if ( abs(rub) > 0 );
                    temp_pntgnd_grad = pntgnd_grad( h1, h3, h2, r12t, r23, r13t, rr3 );
                    fc = fc + rub*temp_pntgnd_grad[8];
                    d_fc_h1 = d_fc_h1 + rub*temp_pntgnd_grad[1];
                    d_fc_h2 = d_fc_h2 + rub*temp_pntgnd_grad[3];
                    d_fc_h3 = d_fc_h3 + rub*temp_pntgnd_grad[2];
                    d_fc_r12 = d_fc_r12 + rub *(temp_pntgnd_grad[4]*d_r12t_r12);
                    d_fc_r13 = d_fc_r13 + d_rub_r13 * temp_pntgnd_grad[8] + rub *(temp_pntgnd_grad[6]*d_r13t_r13+temp_pntgnd_grad[7]*d_rr3_r13);
                    d_fc_r23 = d_fc_r23 + rub*temp_pntgnd_grad[5];
                endif;

                temp_sincs_grad = sincs_grad( rua*( 1 + xg[j] )/2 ); 
                r12t = temp_sincs_grad[3];
                rr2  = temp_sincs_grad[4];

                d_r12t_r12 = temp_sincs_grad[1]*( 1 + xg[j] )/2*d_rua_r12;
                d_rr2_r12  = temp_sincs_grad[2]*( 1 + xg[j] )/2*d_rua_r12;
    
                temp_sincs_grad = sincs_grad( rub*( 1 + xg[j] )/2 );
                r13t = temp_sincs_grad[3];
                rr3  = temp_sincs_grad[4];
                d_r13t_r13 = temp_sincs_grad[1]*( 1 + xg[j] )/2*d_rub_r13;
                d_rr3_r13  = temp_sincs_grad[2]*( 1 + xg[j] )/2*d_rub_r13;
    
                if ( abs(rua) > 0 ) ;
                    temp_pntgnd_grad = pntgnd_grad(h1, h2, h3, r13t, r23, r12t, rr2 );
                    fc = fc + rua*temp_pntgnd_grad[8];
                    d_fc_h1 = d_fc_h1 + rua*temp_pntgnd_grad[1];
                    d_fc_h2 = d_fc_h2 + rua*temp_pntgnd_grad[2];
                    d_fc_h3 = d_fc_h3 + rua*temp_pntgnd_grad[3];
                    d_fc_r12 = d_fc_r12 + d_rua_r12 * temp_pntgnd_grad[8] + rua *(temp_pntgnd_grad[6]*d_r12t_r12+temp_pntgnd_grad[7]*d_rr2_r12);
                    d_fc_r13 = d_fc_r13 + rua *(temp_pntgnd_grad[4]*d_r13t_r13);
                    d_fc_r23 = d_fc_r23 + rua*temp_pntgnd_grad[5];
                endif;
                if ( abs(rub) > 0 );
                    temp_pntgnd_grad = pntgnd_grad( h1, h3, h2, r12t, r23, r13t, rr3 );
                    fc = fc + rub*temp_pntgnd_grad[8];
                    d_fc_h1 = d_fc_h1 + rub*temp_pntgnd_grad[1];
                    d_fc_h2 = d_fc_h2 + rub*temp_pntgnd_grad[3];
                    d_fc_h3 = d_fc_h3 + rub*temp_pntgnd_grad[2];
                    d_fc_r12 = d_fc_r12 + rub *(temp_pntgnd_grad[4]*d_r12t_r12);
                    d_fc_r13 = d_fc_r13 + d_rub_r13 * temp_pntgnd_grad[8] + rub *(temp_pntgnd_grad[6]*d_r13t_r13+temp_pntgnd_grad[7]*d_rr3_r13);
                    d_fc_r23 = d_fc_r23 + rub*temp_pntgnd_grad[5];
                endif;
                res = res + wg[j]*fc; 
                d_res_h1  = d_res_h1  + wg[j]*d_fc_h1;
                d_res_h2  = d_res_h2  + wg[j]*d_fc_h2;
                d_res_h3  = d_res_h3  + wg[j]*d_fc_h3;
                d_res_r12 = d_res_r12 + wg[j]*d_fc_r12;
                d_res_r13 = d_res_r13 + wg[j]*d_fc_r13;
                d_res_r23 = d_res_r23 + wg[j]*d_fc_r23;
            endfor;
            tvn = tvn + res/( 4*pi );   
            d_tvn = d_tvn + (d_res_h1~d_res_h2~d_res_h3~d_res_r12~d_res_r13~d_res_r23)/( 4*pi );  
    endif;
    
	if ( enteredLoop2 eq 1 ) ;
	    d_tvn_unsorted = d_tvn;
	    d_tvn_unsorted[1] = d_tvn[2];       d_tvn_unsorted[2] = d_tvn[1];
	    d_tvn_unsorted[5] = d_tvn[6];       d_tvn_unsorted[6] = d_tvn[5];
	    d_tvn = d_tvn_unsorted;
	endif;   
	if ( enteredLoop1 eq 1 ) ;
	    d_tvn_unsorted = d_tvn;
	    d_tvn_unsorted[2] = d_tvn[3];       d_tvn_unsorted[3] = d_tvn[2];
	    d_tvn_unsorted[4] = d_tvn[5];       d_tvn_unsorted[5] = d_tvn[4];
	    d_tvn = d_tvn_unsorted;
	endif;
    d_tvn = real(d_tvn);
    retp(((d_tvn[1:3])'),((d_tvn[4:6])'));
endp;


proc pntgnd_grad(ba, bb, bc, ra, rb, r, rr);
    local gg;
    local f,dt,bt,ft;
    local d_ba, d_bb, d_bc, d_ra, d_rb, d_r, d_rr;
    local d_bt_ba,d_bt_bb,d_bt_bc,d_bt_ra,d_bt_rb,d_bt_r,d_bt_rr;
    local d_ft_ba,d_ft_bb,d_ft_bc,d_ft_r,d_ft_rr;
    local d_dt_ra,d_dt_rb,d_dt_r,d_dt_rr;
    local d_bt_dt;
    
    //ba = x[1];bb = x[2];bc = x[3];ra = x[4];rb = x[5];r  = x[6];rr = x[7];

    f = 0; d_ba = 0;        d_bb=0;         d_bc=0;         d_ra=0;     d_rb=0;     d_r = 0;        d_rr=0;
    dt = rr*( rr - ( ra - rb )^2 - 2*ra*rb*( 1 - r ) );
    
    d_dt_ra = rr*(  - 2*( ra - rb ) - 2*rb*( 1 - r ) );
    d_dt_rb = rr*(   2*( ra - rb ) - 2*ra*( 1 - r ) );
    d_dt_r  = rr*(  2*ra*rb );
    d_dt_rr = ( rr - ( ra - rb )^2 - 2*ra*rb*( 1 - r ) ) + rr*( 1  );

    if (dt > 0  );
        bt = ( bc*rr + ba*( r*rb - ra ) + bb*( r*ra -rb ) )/sqrt(dt) ;
        ft = ( ba - r*bb )^2/rr + bb*bb;
        
        d_bt_dt = -0.5*bt/dt;

        d_bt_ba = (  ( r*rb - ra ) )/sqrt(dt) ;                             d_ft_ba = 2*( ba - r*bb )/rr;
        d_bt_bb = (  ( r*ra - rb ) )/sqrt(dt) ;                             d_ft_bb = 2*( ba - r*bb )*(-r)/rr + 2*bb;
        d_bt_bc = ( rr  )/sqrt(dt) ;      
    
        d_bt_ra = ( ba*( -1 ) + bb*( r ) )/sqrt(dt) +  d_bt_dt*d_dt_ra ;
        d_bt_rb = ( ba*( r ) + bb*( -1 ) )/sqrt(dt) +  d_bt_dt*d_dt_rb ;  
        d_bt_r  = ( ba*( rb) + bb*( ra) )/sqrt(dt)  +  d_bt_dt*d_dt_r ;     d_ft_r  = 2*( ba - r*bb )*(-bb)/rr ;
        d_bt_rr = ( bc  )/sqrt(dt)                  +  d_bt_dt*d_dt_rr ;    d_ft_rr = -( ba - r*bb )^2/(rr^2) ;

        if (bt > -10 and ft < 100);
            f = exp( -ft/2 );
                d_ba =  f*(-1/2)*d_ft_ba;
                d_bb =  f*(-1/2)*d_ft_bb;
                d_r  =  f*(-1/2)*d_ft_r;
                d_rr =  f*(-1/2)*d_ft_rr;
            if(bt < 10);  
                    d_ba =  d_ba*cdfn(bt) + f*pdfn(bt)*d_bt_ba;
                    d_bb =  d_bb*cdfn(bt) + f*pdfn(bt)*d_bt_bb;
                    d_bc =                  f*pdfn(bt)*d_bt_bc;
                    d_ra =                  f*pdfn(bt)*d_bt_ra;
                    d_rb =                  f*pdfn(bt)*d_bt_rb;
                    d_r  =   d_r*cdfn(bt) + f*pdfn(bt)*d_bt_r;
                    d_rr =  d_rr*cdfn(bt) + f*pdfn(bt)*d_bt_rr;
                f = f*cdfn(bt); 
                    
            endif;
        endif;
    endif;

    gg = d_ba~d_bb~d_bc~d_ra~d_rb~d_r~d_rr~f;
    retp(gg);
endp;



proc sincs_grad(x);
    local gg;
    local sx,cs,ee,signx;
    local d_ee,d_cs,d_sx;
    ee = ( pi/2 - abs(x) )^2;

    if(x<0);    d_ee = 2*( pi/2 + x );
    else;       d_ee = 2*( x - pi/2  );
    endif;

    if (ee < 5e-5);
        cs = ee*( 1 - ee*( 1 - 2*ee/15 )/3 );
        d_cs = ( 1 - ee*( 1 - 2*ee/15 )/3 )     +       ee*(-  (    ( 1 - 2*ee/15 )/3   -   ee * ( 2/45)    )         );
        d_cs = d_ee*d_cs;

        signx = x/abs(x);
        sx = ( 1 - ee*( 1 - ee/12 )/2 )*signx;
        if(x gt 0); d_sx = - (  ( 1 - ee/12 )/2 +ee*( - 1/12 )/2 );
        else;       d_sx =  (  ( 1 - ee/12 )/2 +ee*( - 1/12 )/2 );
        endif;
        d_sx = d_sx*d_ee;        
    else;
        sx = sin(x); d_sx = cos(x);
        cs = 1 - sx*sx;
        d_cs = -2*sx*d_sx;
    endif;

    retp(d_sx~d_cs~sx~cs);
endp;


 
/*
** gradnoncdftvn.src 
**
** Purpose: Develops gradients with respect to the non-standard trivariate normal cumulative function (K=3 for this to work; if K=1 or 2,
            use gradcdfn or gradcdfbvn).
**
** Format:      { gmu,gcov,gx } = gradnoncdftvn(mu,cov,x)
**
** Input:        mu is the (3x1) vector of means, cov is the 3X3 covariance matrix, x represents the abscissae points (3x1);
**
**
** Output:      gmu  - 3x1 vector, gradients of noncdfbvn with respect to mu
                gcov - 6x1 vector, gradients of noncdfbvn with respect to cov -- upper diagonal elements 
                gx   - 3x1 vector, gradients of noncdfbvn with respect to absisccae  

** Global: Cholesky = 1 if gradients with respect to Cholesky matrix of covariance; =0 if gradients with respect to cov; if Cholesky=1,
                gcov is with respect to Cholesky elements

**  x = { x1,x2,x3 };  
           
**  mu = { mu1,mu2.mu3 };

**  cov = { cov11  cov12  cov13,               cov is a covariance matrix
            cov12  cov22  cov23,
            cov13  cov23  cov33 };

**  S    = { S11   S12    S13,              cov = S'*S;
             0     S22    S23,
             0      0     S33 };
             
P  = noncdfmvn(x,mu,cov)

OUTPUT

**  gmu      =           { dP/dmu1,
                           dP/dmu2,
                           dP/dmu3 };                           
                                               
IF _cholesky=0,

**  gcov      =          { dP/dcov11         
                           dP/dcov12
                           dP/dcov13
                           dP/dcov22
                           dp/dcov23
                           dP/dcov33 };   

                         
IF _cholesky=1,

**  gcov      =          { dP/dS11    
                           dP/dS12
                           dP/dS13
                           dP/dS22
                           dP/dS23
                           dP/dS33 };     

**  gx      =            { dP/dx1,
                           dP/dx2,
                           dP/dx3 };    */


proc (3) = gradnoncdftvn(mu,cov,x);
    local om,sqrtom,kk1,kk2,rho,gw,grho,gbcorcov,gomegacorcov,gcov,gmu,gx;
    om = diag(cov);
    sqrtom = sqrt(om);
    kk1 = (x-mu)./sqrtom;
    kk2 = corrvc(cov);  
    kk2 = diagrv(kk2,ones(3,1));     
    { gw,grho } = gradcdftvn(kk1,kk2[1,2]|kk2[1,3]|kk2[2,3]); 
    { gBcorcov,gomegacorcov } = gradcorcov(kk1,sqrtom,kk2);
    gmu = -(gw)./sqrtom;
    gcov = gbcorcov*(gw)+gomegacorcov*grho;
    gx = -gmu;
    if _cholesky==1;
        gcov = gcholeskycov(cov)*gcov;
    endif;
    retp(gmu,gcov,gx);
endp;    
 
/*
** gradcdftvnbycdfbvn.src 
**
** Purpose: Develops gradients with respect to the ratio of a standard trivariate normal cumulative function to a standard biivariate 
            normal cumulative distribution
**
**
ALL inputs and outputs are same as gradcdftvn, except this procedure provides gradients of cdftvn(w1,w2,w3, cov)/cdfbvn(w1,w2,cov[1:2,1:2]);
** Format:      { gw,grho } = gradcdftvnbycdfbvn(w,cor)
**
** Input:        w is a vector of abscissae points (Kx1), cor is the correlation matrix (Kx1, rho12, rho13, rho23)
**
**
** Output:      gw  - 3x1 vector, gradients of cdftvn/cdfbvn with respect to w
                grho - 3x1 vector, gradients of cdftvn/cdfbvn with respect to upper triangular cor elements  


so, w = { w1,w2,w3 }, cor = 1 rho12 rho13,
                                1   rho23,
                                       1   };

gw provides gradients with respect to w1,w2, w3, and grho provides gradients arranged with respect to rho12, rho13, and then rho 23 */


proc(2) = gradcdftvnbycdfbvn(w,cor);
    local w1,w2,w3,rho12,rho13,rho23,gw1,gw2,bivarcdf,gwtri,grhotri,gw1w2new,grho12new,trivarcdf,grho;
    w1 = w[1]; w2 = w[2]; w3 = w[3]; rho12 = cor[1]; rho13 = cor[2]; rho23 = cor[3];
    trivarcdf = cdftvn(w1,w2,w3,rho12,rho23,rho13);
    bivarcdf = cdfbvn(w1,w2,rho12);
    { gw1,gw2,grho }  = gradcdfbvn(w1,w2,rho12);
    { gwtri,grhotri } = gradcdftvn(w,cor);
    gw1w2new = (bivarcdf*gwtri[1:2]-trivarcdf*(gw1|gw2))/(bivarcdf^2);
    grho12new = (bivarcdf*grhotri[1]-trivarcdf*(grho))/(bivarcdf^2);
    retp((gw1w2new|(gwtri[3]/bivarcdf)),(grho12new|(grhotri[2:3])/bivarcdf));
endp;


/* All inputs and outputs are same as gradnoncdftvn, but this procedure is for finding gradients of the ratio of non-standard trivariate cdf
   to the non-standard bivariate cdf; P = trivariate cdf (x1,x2,x3; mu1,mu2,mu3; cov)/bivariate cdf (x1,x2; mu1,mu2;cov[1:2,1:2]);  */

proc (3) = gradnoncdftvnbycdfbvn(mu,cov,x);
    local om,sqrtom,kk1,kk2,rho,gw,grho,gbcorcov,gomegacorcov,gcov,gmu,gx;
    om = diag(cov);
    sqrtom = sqrt(om);
    kk1 = (x-mu)./sqrtom;
    kk2 = corrvc(cov);  
    kk2 = diagrv(kk2,ones(3,1));     
    { gw,grho } = gradcdftvnbycdfbvn(kk1,kk2[1,2]|kk2[1,3]|kk2[2,3]); 
    { gBcorcov,gomegacorcov } = gradcorcov(kk1,sqrtom,kk2);
    gmu = -(gw)./sqrtom;
    gcov = gbcorcov*(gw)+gomegacorcov*grho;
    gx = -gmu;
    if _cholesky==1;
        gcov = gcholeskycov(cov)*gcov;
    endif;
    retp(gmu,gcov,gx);
endp;    
 

/* cdfqvn (aa,rr)  

 Input:       a - K x 1 vector of abscissae (K>=2)
**              rr - K x K correlation matrix 
**
** Output:      w - 1 x 1 vector  Pr(X < a| rr).     */


proc (1) = cdfqvn(a,rr);
    local p,rr10,temp1,atemp,mutemp,sigtemp,kk,kkcor;
/*  This next line is needed, because of problems when abscissa go less than -5 or > 5 */
    a = -5*(a .<=-5)+a.*(a.>-5 .and a.<5)+5*(a.>=5);   
    p = zeros(2,1);    
    temp1 = seqa(1,1,rows(a));
    atemp = a[temp1];
    mutemp=zeros(rows(a),1); 
    sigtemp = rr[temp1,temp1];
    p[1]=cdftvn(atemp[1],atemp[2],atemp[3],sigtemp[1,2],sigtemp[2,3],sigtemp[1,3]);
    { mutemp,sigtemp } = multruncbivariate(mutemp,sigtemp,atemp[1:2]); 
    p[2] = (noncdfbvn(mutemp[3:4],sigtemp[3:4,3:4],atemp[3:4]))/(noncdfn(mutemp[3],sigtemp[3,3],atemp[3]));   
    retp(p[1]*p[2]);
endp;


/*
** gradcdfqvn.src 
**
** Purpose: Develops gradients with respect to the standard approximated quadrivariate normal cumulative function 
**
** Format:      { gw,grho } = gradcdfqvn(w,cor)
**
** Input:        w is a vector of abscissae points (4x1), cor refers to the elements of the correlation matrix (4x4 matrix)
**
**
** Output:      gw  - 4x1 vector, gradients of cdfqvn with respect to w
                grho - 6x1 vector, gradients of cdfqvn with respect to upper triangular cor elements  


so, w = { w1,w2,w3,w4 }, cor = 1 rho12 rho13  rho14,
                                1   rho23  rho24,
                                       1   rho34,
                                               1 };

gw provides gradients with respect to w1,w2, w3, w4, and grho provides gradients arranged with respect to rho12, rho13, rho14, rho23, rho24, rho34 */


proc (2) = gradcdfqvn(a,rr);
    local p,temp1,atemp,mutemp,sigtemp,mutemp1,sigtemp1,gY,gmumean,gXmean,gCmean,gmucov,gXcov,gCcov;
    local gcumulmusig,gcumulC,gC,gfrompmu,gfrompcov,gfrompC,grhorho,gC1,grho1,tempnew;
/*  This next line is needed, because of problems when abscissa go less than -5 or > 5 */
    a = -5*(a .<=-5)+a.*(a.>-5 .and a.<5)+5*(a.>=5);  
    p = zeros(2,1);
    temp1 = seqa(1,1,rows(a));
    atemp = a[temp1];
    mutemp=zeros(rows(a),1); 
    sigtemp = rr[temp1,temp1];
    p[1]=cdftvn(atemp[1],atemp[2],atemp[3],sigtemp[1,2],sigtemp[2,3],sigtemp[1,3]);
    { mutemp1,sigtemp1 } = multruncbivariate(mutemp,sigtemp,atemp[1:2]);
    p[2] = (noncdfbvn(mutemp1[3:4],sigtemp1[3:4,3:4],atemp[3:4]))/(noncdfn(mutemp1[3],sigtemp1[3,3],atemp[3]));
    _condcovsigtrunc=0; _condcovmeantrunc=0;
    { gY, gmumean, gXmean, gCmean } = gcondmeantrunc(eye(2),mutemp,sigtemp,atemp[1:2]);
    { gmucov,gXcov,gCcov } = gcondcovtrunc(mutemp,sigtemp,atemp[1:2]);    

    gcumulmusig = gXmean~gXcov;
    gcumulC = (gCmean~gCcov)|zeros(2,5);
    gC = zeros(4,1);
    { gfrompmu,gfrompcov,gfrompC } = gradnoncdfbvnbycdfn(mutemp1[3:4],sigtemp1[3:4,3:4],atemp[3:4]);
    grhorho = (p[1])*(gcumulmusig[.,1:2]*gfrompmu+(gcumulmusig[.,3:5])*gfrompcov);
    gC = (p[1])*(gcumulC[.,1:2]*gfrompmu+gcumulC[.,3:5]*gfrompcov);

    gC[3:4] = (p[1])*(gfrompc);  /* getting gradient contribution directly from noncdfbvn for absiccae except the first two */       
    
    { gC1,grho1 } = gradcdftvn(atemp[1:3],(sigtemp[1,2]|sigtemp[1,3]|sigtemp[2,3]));
    grhorho = grhorho+p[2]*(grho1[1:2]|0|grho1[3]|0|0);
    gC = gC+p[2]*(gC1|0);

    tempnew = seqa(1,1,4)~temp1;
    tempnew = sorthc(tempnew,2);
    tempnew = tempnew[.,1];
    gC = (gC[tempnew]);
    grhorho = matndupdiagzerofull((grhorho)); 
    grhorho = submat(grhorho,tempnew,tempnew);
    grhorho = (vecndup(grhorho));
    retp(gC,grhorho);
    
endp;


/* Cumulative distribution function of non-standard approximated quadrivariate cumulative distribution function */
/* mu - 4x1 vector, cov - 4x4 matrix, x - 4x1 vector of abscissa */

proc (1) = noncdfqvn(mu,cov,x);
    local om,sqrtom,kk1,kk2;
    om = diag(cov);
    sqrtom = sqrt(om);
    kk1 = (x-mu)./sqrtom;
    kk2 = corrvc(cov);  
    kk2 = diagrv(kk2,ones(4,1));     
    retp(cdfqvn(kk1,kk2));
endp;   

 
/*
** gradnoncdfqvn.src 
**
** Purpose: Develops gradients with respect to the non-standard approximated quadrivariate normal cumulative function (K=4 for this to work; if K=1 or 2 or 3,
            use gradnoncdfn or gradnoncdfbvn or gradnoncdftvn).
**
** Format:      { gmu,gcov,gx } = gradnoncdqtvn(mu,cov,x)
**
** Input:        mu is the (4x1) vector of means, cov is the 4X4 covariance matrix, x represents the abscissae points (4x1);
**
**
** Output:      gmu  - 4x1 vector, gradients of noncdfbvn with respect to mu
                gcov - 10x1 vector, gradients of noncdfbvn with respect to cov -- upper diagonal elements 
                gx   - 4x1 vector, gradients of noncdfbvn with respect to absisccae  

** Global: Cholesky = 1 if gradients with respect to Cholesky matrix of covariance; =0 if gradients with respect to cov; if Cholesky=1,
                gcov is with respect to Cholesky elements

**  x = { x1,x2,x3,x4 };  
           
**  mu = { mu1,mu2,mu3,mu4 };

**  cov = { cov11  cov12  cov13   cov14,               cov is a covariance matrix
            cov12  cov22  cov23   cov24,
            cov13  cov23  cov33   cov34,
            cov14  cov24  cov34   cov44    };

**  S    = { S11   S12    S13    S14,              cov = S'*S;
             0     S22    S23    S24,
             0      0     S33    S34,
             0      0      0     S44 };
             
P  = noncdfqvn(x,mu,cov)

OUTPUT

**  gmu      =           { dP/dmu1,
                           dP/dmu2,
                           dP/dmu3,
                           dP/dmu4 };                           
                                               
IF _cholesky=0,

**  gcov      =          { dP/dcov11         
                           dP/dcov12
                           dP/dcov13
                           dP/dcov14
                           dP/dcov22
                           dp/dcov23
                           dP/dcov24
                           dP/dcov33
                           dP/dcov34
                           dP/dcov44 };   

                         
IF _cholesky=1,

**  gcov      =          { dP/dS11    
                           dP/dS12
                           dP/dS13
                           dP/dS14
                           dP/dS22
                           dP/dS23
                           dP/dS34
                           dP/dS33
                           dP/dS34
                           dP/dS44 };     

**  gx      =            { dP/dx1,
                           dP/dx2,
                           dP/dx3,
                           dP/dx4 };    */


proc (3) = gradnoncdfqvn(mu,cov,x);
    local om,sqrtom,kk1,kk2,rho,gw,grho,gbcorcov,gomegacorcov,gcov,gmu,gx;
    om = diag(cov);
    sqrtom = sqrt(om);
    kk1 = (x-mu)./sqrtom;
    kk2 = corrvc(cov);  
    kk2 = diagrv(kk2,ones(4,1));     
    { gw,grho } = gradcdfqvn(kk1,kk2); 
    { gBcorcov,gomegacorcov } = gradcorcov(kk1,sqrtom,kk2);
    gmu = -(gw)./sqrtom;
    gcov = gbcorcov*(gw)+gomegacorcov*grho;
    gx = -gmu;
    if _cholesky==1;
        gcov = gcholeskycov(cov)*gcov;
    endif;
    retp(gmu,gcov,gx);
endp;    
 
/*
** gradcdfqvnbycdfbvn.src 
**
** Purpose: Develops gradients with respect to the ratio of a standard approximated quadrivariate normal cumulative function to a standard bivariate 
            normal cumulative distribution
**
**
ALL inputs and outputs are same as gradcdfqvn, except this procedure provides gradients of cdfqvn(w1,w2,w3,w4 cov)/cdfbvn(w1,w2,cov[1:2,1:2]);
** Format:      { gw,grho } = gradcdfqvnbycdfbvn(w,cor)
**
** Input:        w is a vector of abscissae points (4x1), cor is the correlation matrix (4x4 matrix)
**
**
** Output:      gw  - 4x1 vector, gradients of cdfqvn/cdfbvn with respect to w
                grho - 6x1 vector, gradients of cdfqvn/cdfbvn with respect to upper triangular cor elements  


so, w = { w1,w2,w3,w4 }, cor = 1 rho12 rho13  rho14,
                                   1   rho23  rho24,
                                         1    rho34,
                                                 1  };

gw provides gradients arranged row-wise with respect to w1,w2, w3, and w4; and grho provides gradients arranged row-wise with respect to rho12, rho13, rho14, rho23, rho24, and rho 34 */


proc(2) = gradcdfqvnbycdfbvn(w,cor);
    local w1,w2,rho12,gw1,gw2,bivarcdf,gwquad,grhoquad,gw1w2new,grho12new,quadvarcdf,grho;
    w1 = w[1]; w2 = w[2]; rho12 = cor[1,2];
    quadvarcdf = cdfqvn(w,cor);
    bivarcdf = cdfbvn(w1,w2,rho12);
    { gw1,gw2,grho }  = gradcdfbvn(w1,w2,rho12);
    { gwquad,grhoquad } = gradcdfqvn(w,cor);
    gw1w2new = (bivarcdf*gwquad[1:2]-quadvarcdf*(gw1|gw2))/(bivarcdf^2);
    grho12new = (bivarcdf*grhoquad[1]-quadvarcdf*(grho))/(bivarcdf^2);
    retp((gw1w2new|(gwquad[3:4]/bivarcdf)),(grho12new|(grhoquad[2:6])/bivarcdf));
endp;


/* All inputs and outputs are same as gradnoncdfqvn, but this procedure is for finding gradients of the ratio of non-standardapproximated quadrivariate cdf
   to the non-standard bivariate cdf; P = quadrivariate cdf (mu1,mu2,mu3,mu4; cov; x1,x2,x3,x4)/bivariate cdf (mu1,mu2;cov[1:2,1:2];x1,x2);  */

proc (3) = gradnoncdfqvnbycdfbvn(mu,cov,x);
    local om,sqrtom,kk1,kk2,rho,gw,grho,gbcorcov,gomegacorcov,gcov,gmu,gx;
    om = diag(cov);
    sqrtom = sqrt(om);
    kk1 = (x-mu)./sqrtom;
    kk2 = corrvc(cov);  
    kk2 = diagrv(kk2,ones(4,1));     
    { gw,grho } = gradcdfqvnbycdfbvn(kk1,kk2); 
    { gBcorcov,gomegacorcov } = gradcorcov(kk1,sqrtom,kk2);
    gmu = -(gw)./sqrtom;
    gcov = gbcorcov*(gw)+gomegacorcov*grho;
    gx = -gmu;
    if _cholesky==1;
        gcov = gcholeskycov(cov)*gcov;
    endif;
    retp(gmu,gcov,gx);
endp; 


/***************************************************************************************************************************************************
                              Univariate and multivariate normal density function, and gradients
***************************************************************************************************************************************************/

/* F = pdfmvnanl(mu,cov,x) : multivariate normal density function ; all inclusive for all K values 

** Input:       mu    - K x 1 vector of means, where K corresponds to number of variates (K>=1)
                cov   - K x K covariance matrix; analyst should ensure that cov is a positive definite matrix
                x     - K x 1 matrix of abscissae

** Output:      F - 1 x 1 vector  */
 

proc (1) = pdfmvnanl(mu,cov,x);
    local e2,P,newx,kk2,w,s15;
    e2 = rows(x);
    if e2 ==1;
       retp(nonpdfn(mu,cov,x));
    elseif e2>=2;
       retp(nonpdfmvn(mu,cov,x)); 
    endif;
endp;

 
/*
** gradpdfmvnanl.src 
**
** Purpose: Develops the gradients of pdfmvnanl for all K values, and whether input covariance matrix is a covariance or a correlation matrix 

** Format:      { P,gmu,gcov,gx } = gradpdfmvnanl(mu,cov,x)
**
** Input:        mu is the (Kx1) vector of means
                 cov is the KXK correlation matrix if _covarr=0; and cov is KxK covariance matrix if _covarr=1,
                 x represents the abscissae

** Globals       _covarr = 1     means cov is a covariance matrix; _covarr=0 means cov is actually a correlation matrix   
                 _Cholesky = 1 if you want gradients with respect to Cholesky of cov and not cov
                 NOTE: Always specify both globals before any call to gradpdfmvnanl;

** Output:       P is density value
                 gmu is the (Kx1) gradient vector of F with respect to the vector of means
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the correlation matrix elements if _covarr=0 and _cholesky=0 (K>1)
                     is the Kx(K+1)/2 gradient vector of F with respect to the covariance matrix elements if _covarr=1 and _cholesky=0; (K>1)
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to variance if _covarr=1; if _covarr=0, ignore gcov;
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the cholesky of the correlation matrix elements if _covarr=0 and _cholesky=1
                     is the Kx(K+1)/2 gradient vector of F with respect to the cholesky of the covariance matrix elements if _covarr=1 and _cholesky=1;
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to standard deviation if _covarr=1; if _covarr=0, ignore gcov;                 gx represents the (Kx1) gradient vector of F with respect to the points of truncation from below (integrals are x to infinity)
                 If you are working with standardized univariate normal, simply ignore gmu and gcov;
                 
                 mu  = {  mu1   
                          mu2   
                          mu3 };

                 if _covarr=1;

                 cov = { sig11    sig12   sig13,        if _cholesky=0;   chol(cov)  =  { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

                 if _covarr=0;

                 cov = {   1      rho12   rho13,        if _cholesky=0;   chol(cov) = {   1       S12         S13,                     if _cholesky=1
                         rho12       1    rho23,                                          0   sqrt(1-S12^2)   S23,
                         rho13    rho23      1   };                                       0         0        sqrt(1-S13^2-S23^2)  }

                 x = { x1,
                       x2,
                       x3 };
                       
               gmu  =  { dF/dmu1,
                         dF/dmu2,
                         dF/dmu3 };
                         
              gcov  =  { dF/dsig11,   if _cholesky=0 and __covarr=1;         
                         dF/dsig12,                               
                         dF/dsig13,                                
                         dF/dsig22,                                
                         dF/dsig23,                                      
                         dF/disg33 };                                       

              gcov  =  { dF/drho12,   if _cholesky=0 and __covarr=0;                                       
                         dF/drho13,                                                                
                         dF/drho23  };  

              gcov  =  { dF/dS11,   if _cholesky=1 and __covarr=1;         
                         dF/dS12,                               
                         dF/dS13,                                
                         dF/dS22,                                
                         dF/dS23,                                      
                         dF/dS33 };                                       

              gcov  =  { dF/dS12,   if _cholesky=1 and __covarr=0;                                       
                         dF/dS13,                                                                
                         dF/dS23  }; 
                         
              gx    =   { dF/dx1,
                          dF/dx2,
                          dF/dx3 } */
                         
proc (4) = gradpdfmvnanl(mu,cov,x);
    local e2,om,invsig2,sqrtom,mm1,invsig,kk1,kk2,mm,gBcorcov,gomegacorcov,gmu,gcov,gx,rho,gx1,gx2,grho,P,s15;
    e2 = rows(x); 
    if e2 ==1;
       P=nonpdfn(mu,cov,x);
       { gmu,gcov,gx } = gradnonpdfn(mu,cov,x);
    elseif e2>=2;
       P=nonpdfmvn(mu,cov,x);
       { gmu,gcov,gx } = gradnonpdfmvn(mu,cov,x);
       if _covarr==0;
           gcov = vecndup(matdup(gcov));
       endif;   
    endif;
    retp(P,gmu,gcov,gx);
endp;

                 
/***************************************************************************************************************************************************
          Miscellaneous procedures for computing univariate and multivariate normal density function, and gradients
***************************************************************************************************************************************************/


/* gs = gradpdfn(s) Gradient of the univariate normal density function   

** Input:       s - Q x 1 matrix of abscissae, where Q corresponds to number of observations

** Output:      gs - Q x 1 matrix of gradients of pdfmvn with respect to s   */



proc (1) = gradpdfn(s);
    retp(-s.*pdfn(s));
endp;


/* F = nonpdfn(mu,cov,x);  non-standard univariate normal density function

* Input:       x - Q x 1 matrix of abscissae, where Q corresponds to number of observations
              mu - Q x 1 matrix of means
            cov  -  Q x 1 variance (not standard deviation) or 1 x 1 variance if all variances are identical across Q

** Output:      F - Q x 1 vector of nonpdfn  */

proc(1) = nonpdfn(mu,cov,x);
    local sigs;
    sigs = sqrt(cov);
    retp((1/sigs).*pdfn((x-mu)./sigs));
endp;


/* { gmu,gcov,gx }  = gradnonpdfn(mu,cov,x); Gradient of the non-standard normal density function  

* Input:       
              mu - Q x 1 matrix of means
             cov -  Q x 1 variance (not standard deviation) or 1 x 1 variance if all variances are identical across Q
               x - Q x 1 matrix of abscissae, where Q corresponds to number of observations

** _Cholesky =0 if gradient with respect to the variance of variable, _Cholesky=1 if gradient w.r.t standard deviation of variable  
** Output:      
                gmu - Q x 1 vector of gradients of F with respect to mu
               gcov - Q x 1 vector of the gradient F with respect sigma
                 gx - Q x 1 vector of gradients of F with respect to s  */

proc(3) = gradnonpdfn(mu,cov,x);
    local w,sigs,w1,gcov,sqrtom;
    sigs = sqrt(cov);
    w = (x-mu)./sigs;
    w1 = gradpdfn(w);
    sqrtom = sqrt(cov);
    gcov = ((1/(2*sigs)).*(((-w1.*w)./cov)-pdfn(w)./cov));
    if _cholesky;
      gcov = 2*sqrtom.*gcov;
    endif; 
    retp((-w1./cov),gcov,(w1./cov));
endp;


/*
** gradpdfbvn.src 
**
** Purpose: Develops gradients with respect to the standard bivariate normal density function 
**
** Format:      { gw1,gw2,grho } = gradpdfbvn(w1,w2,rho)
**
** Input:        w1 and w2 are the abscissae points (Nx1), rho is the correlation vector (Nx1)
**
**
** Output:      gw1  - Nx1 vector, gradients of pdfbvn with respect to w1
                gw2  - Nx1 vector, gradients of pdfbvn with respect to w2
                grho - Nx1 vector, gradients of pdfbvn with respect to rho  */


proc (3) = gradpdfbvn(w1,w2,rho);
   local rhotilde,tr1,tr2,pdf2,gw1,gw2,grho;
   rhotilde = sqrt((1-rho^2));
   tr1 = (w2-rho.*w1)./rhotilde; 
   tr2 = (w1-rho.*w2)./rhotilde;
   pdf2 = (1/rhotilde).*(pdfn(w1).*pdfn(tr1));
   gw1 = -pdf2.*tr2.*(1/rhotilde);
   gw2 = -pdf2.*tr1.*(1/rhotilde);
   grho = (pdf2./(rhotilde^2)).*(rho+(tr1.*tr2));
   retp(gw1,gw2,grho);
endp;    
 

/* F = pdfmvn(cov,x) : standard multivariate normal density function   

** Input:       
              cov - K x K correlation matrix; analyst should ensure that r is a positive definite correlation matrix
                x - K x Q matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations 
** Output:      F - Q x 1 vector  

             cov   =   { 1       rho12     rho13,        
                         rho12     1       rho23,        
                         rho13   rho23       1   };      

               x   = {  x11   x12,
                        x21   x22,
                        x31   x32 };   say three abscissae and 2 individuals   

               F   =  { F for individual 1
                       F for individual 2  }  */
                
proc pdfmvn(cov,x);
    local e1,w,newm,r1,comp1,comp2,comp3,a1,comp4;
    e1 = rows(x);
    r1 = invpd(cov);
    newm=x;
	comp1 = ((2*pi)^(-e1/2))*((det(cov))^(-0.5));
    comp4 = diag(newm'*r1*newm);
    comp2 = (-0.5)*comp4;
    comp3 = exp(comp2);
    a1 = (comp3.>=(2.4502955e-308));
    comp3 = a1.*comp3+(1-a1)*0;   
    retp(comp1*comp3);   
endp;


/* { gcov,gx } = gradpdfmvn(cov,x) :   

** Input:     cov - K x K correlation matrix; analyst should ensure that r is a positive definite correlation matrix
                x - K x 1 matrix of abscissae, where K corresponds to number of variates
** Output:   gcov - (K*(K-1)/2) x 1  vector of gradients of pdfmvn with respect to the correlation (upper triagular wise) 
               gx - K x 1 matrix of gradients of pdfmvn with respect to x

** Global       _Cholesky = 1 if you want gradients with respect to Cholesky of cov and not cov

              cov   =   { 1     rho12     rho13,        if _cholesky=0;    chol(cov)  = { 1       S12           S13,      if _cholesky=1
                         rho12     1      rho23,                                          0   sqrt(1-S12^2)     S23,
                         rho13  rho23       1   };                                        0         0           sqrt(1-S13^2-S23^2)  }

                x   = { x1   
                        x2 
                        x3  };   say three abscissae 

                gx  =  { dF/dx1  
                         dF/dx2  
                         dF/dx3 };


              gcov   =  { dF/drho12,          if _cholesky=0        gcov  =  { dF/dS12,         if _cholesky=1;
                          dF/drho13,                                           dF/dS13,
                          dF/drho23 };                                         dF/dS23  }      */


proc (2) = gradpdfmvn(cov,x);
    local e1,w,gs,gr,z,newm,comp1,r1,comp2;
    z = pdfmvn(cov,x);
    r1 = invpd(cov);
    e1 = rows(x);
    newm=x;
    gs = r1*newm;
    gr = (-1.0)*(r1-r1*(newm*newm')*r1);
    if _cholesky==0;
       retp(z.*vecndup(gr),z.*(-gs));
    elseif _cholesky==1;
       retp(gcholeskycor(cov)*z*vecndup(gr),z.*(-gs));
    endif;
endp;


/* F = nonpdfmvn(mu,cov,x) : standard multivariate normal density function   ]]

** Input:       
                mu    - K x Q matrix of means or, if all means are the same, K x 1 matrix of means
                cov   - K x K covariance matrix; analyst should ensure that sigma is a positive definite matrix
                x     - K x Q matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations
** Output:      F - Q x 1 vector  
                              

              x   = { x11   x12   x13, 
                      x21   x22   x23   };   say two abscissae and 3 individuals 

              mu   = { mu11 mu12  mu13,            or mu = { mu1
                      m221 mu22  mu23   }                  mu2 

            cov    = { sig11   sig12,
                       sig12   sig22    };  

              F   =  { F for individual 1
                       F for individual 2
                       F for individual 3 }   */
                       

proc nonpdfmvn(mu,cov,x);
    local e1,w,r,newm,comp1,comp2;
    w = sqrt(diag(cov));
	newm = (x-mu)./w;
    r = corrvc(cov);
    retp(((prodc(w))^(-1))*pdfmvn(r,newm));
endp;


/* { gmu,gcov,gx } = gradnonpdfmvn(mu,cov,x) : NON-standard multivariate normal density function     
   IMPORTANT NOTE: IF YOU ARE USING STANDARD multivariate normal density function, use gradpdfmvn for gradient computation, not this procedure.
                   If YOU ARE USING A NON-STANDARD UNIVARIATE NORMAL DENSITY FUNCTION, USE GRADNONPDFN FOR GRAIDENT PROCEDURE, NOT THIS PROCEDURE

** Input:       
                mu    - K x 1 matrix of means or, if all means are the same, K x 1 matrix of means
                cov   - K x K covariance matrix; analyst should ensure that sigma is a positive definite matrix
                x     - K x 1 matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations (K>=2)

** Global       _Cholesky = 1 if you want gradients with respect to Cholesky of sigma and not sigma

** Output:      gmu - K x 1 matrix of gradients of nonpdfmvn with respect to s
               gcov - (K*(K+1)/2) x 1  vector of gradients of nonpdfmvn with respect to the covariance elements (upper triagular wise)  
                 gx - K x 1 matrix of gradients of nonpdfmvn with respect to b 
                             
                mu   = { mu1
                        mu2  }; 

               cov  = { sig11   sig12,                chol(cov)   =    {  S11   S12,
                       sig12   sig22    };                                  0    S22 };
                       
                x   = { x1   
                        x2   };   say two abscissae                        

               gmu  =  {   dF/dmu1,
                           dF/dmu2 }; 
                           
             gcov   =  {   dF/dsig11,  if _cholesky=0                    gcov =  {  dF/dS11,    if _cholesky=1;
                           dF/dsig12                                                dF/dS12,
                           dF/dsig22 }                                              dF/dS22 };    
                           
                gx  =  {   dF/dx1   
                           dF/dx2  };  */
                                                 

proc (3) = gradnonpdfmvn(mu,cov,x);
    local e1,w,gs,gr,w1,gb,z,newm,mm,r,gdiag,r1,gBcorcov,gomegacorcov,gsigma;
    z = nonpdfmvn(mu,cov,x);
    w = sqrt(diag(cov));
	newm = (x-mu)./w;
    w1 = (prodc(w))^(-1);
    r = corrvc(cov);
    mm=_cholesky;
    _cholesky=0;
    { gr,gs } = gradpdfmvn(r,newm);
    { gBcorcov,gomegacorcov } = gradcorcov(newm,w,r);
    gsigma = w1*(gBcorcov*gs+gomegacorcov*gr);
    gsigma = matdupfull(gsigma);
    gdiag = diag(gsigma)-0.5*(z./(w^2));
    gsigma = diagrv(gsigma,gdiag);   
    gsigma = vecdup(gsigma);
    gs = w1*(gs./w);   gb =-gs; 
    if mm == 0;
      retp(gb,gsigma,gs);
    else;
      retp(gb,(gcholeskycov(cov))*gsigma,gs);
    endif;
endp;


/* f = pdfstudt(nu,x) : standard univariate t-density function   

** Input:       
                nu   -  Q x 1 degrees of freedom parameters (nu should take values >= 1 ) or 1 x 1 if same degree of freedom
                x     - Q x 1 vector of abscissae corresponding to 

** Output:      f - Q x 1 vector  
                              

              f   =  { f for individual 1
                       f for individual 2
                       f for individual 3 }   */
proc pdfstudt(nu,x);
   local c1,c2,c3,c4;
   c1 = skipfact(nu);
   c4 = 1/(((1+((x^2)./(nu))))^((nu+1)/2));
   c2 = nu%2 .== zeros(rows(nu),1);
   c3 = (1/sqrt(nu)).*((1/2)*(c2)+(1/pi)*(1-c2));
   retp(c3.*c1.*c4);
endp;
     
/* F = nonpdfstudt(nu,x,mu,cov);  non-standard univariate t density function

** Input:       
                nu    -  Q x 1 degrees of freedom parameters (nu should take values >= 1 ) or 1 x 1 if same degree of freedom
                x     -  Q x 1 vector of abscissae corresponding to 
                mu    -  Q x 1 matrix of means
                cov   -  Q x 1 variance (not standard deviation) or 1 x 1 variance if all variances are identical across Q

** Output:      f - Q x 1 vector  

** Output:      F - Q x 1 vector of nonpdfn  */

proc(1) = nonpdfstudt(nu,x,mu,cov);
    local sigs;
    sigs = sqrt(cov);
    retp((1/sigs).*pdfstudt(nu,((x-mu)./sigs)));
endp;


/* f = pdflogn(x) : standard univariate log-normal density function   

** Input:       
                x     - Q x 1 vector of abscissae corresponding to 

** Output:      f - Q x 1 vector  
                              

              f   =  { f for individual 1
                       f for individual 2
                       f for individual 3 }   */
proc pdflogn(x);
   retp((1/x).*pdfn(ln(x)));
endp; 

     
/* F = nonpdflogn(x,mu,cov);  non-standard univariate log-normal density function

** Input:       
                x     -  Q x 1 vector of abscissae corresponding to 
                mu    -  Q x 1 matrix of means
                cov   -  Q x 1 variance (not standard deviation) or 1 x 1 variance if all variances are identical across Q

** Output:      f - Q x 1 vector  */

proc(1) = nonpdflogn(x,mu,cov);
    local sigs,c1;
    sigs = sqrt(cov);
    c1 = (1/sigs).*(1/x).*(pdfn((ln(x)-mu)./sigs));
    retp(c1);
endp;



/***************************************************************************************************************************************************
             Standard partial cumulative multivariate normal distribution function with possible complement integration, and gradients
***************************************************************************************************************************************************/

/* { F,s1 } =pdfcdfmvn(x,cov,s,indxeq) : Standard partial cumulative multivariate normal distribution function

Input:       
             cov - K x K matrix of correlation parameters 
               x - Kx1 vector of absiccae for equality conditions and truncation from above for inequality conditions
          indxeq - Kx1 vector, where there is a one for abscissae for equality conditions and zero for truncation from above               


             cov   =   { 1       rho12     rho13,        
                         rho12     1       rho23,        
                         rho13   rho23       1   };   

               x   = {  x1   
                        x2   
                        x3 };   say three abscissae 
                        
                 s = seed for use by SSJ procedure (if this procedure is used) for integration dimension > 4;
                
           indxeq  =  { 1     This means first and third abscissae are equality conditions, 
                        0     and second abscissa is truncation from above
                        1  };


Output:        F   =  integral from X2 = -inf to x2 { pdfmvn(x1|X2|x3, cov) } dX2

              s1   = seed for use of next SSJ call in model estimation
               
Global:  The global below is applicable only when the dimensionalityof integration exceeds four. 
         _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                         "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                         "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                         "OVUS"                    - One-variate univariate screening approach
                         "OVBS"                    - One-variate bivariate screening approach
                         "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                         "BME"                     - Bivariate ME approach
                         "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)  */
                                       
proc (2) = pdfcdfmvn(cov,x,s,indxeq);
    local e1,indxfull,s10,indeq,s15,p,indneq,x1,x2,X11,X12,X22,invX11,mu2,X22condcov,newm2,X22condcor,e2;
    e1 = rows(x);
    if e1<=4;
        s15=s;
    endif;
    indxfull = seqa(1,1,e1);
    indeq = selif(indxfull,indxeq);
    indneq = selif(indxfull,(1-indxeq));
    x1 = x[indeq];
    x2 = x[indneq];
    e2 = rows(x2);
    X11 = cov[indeq,indeq];
    X12 = cov[indneq,indeq];
    X22 = cov[indneq,indneq];
    invX11 = invpd(X11);
    mu2 = X12*invX11*x1;
    X22condcov = X22-X12*invX11*X12'; 
    if e2 ==1;
       retp((pdfmvn(X11,x1)*noncdfn(mu2,X22condcov,x2)),s15);        
    elseif e2==2;
       retp((pdfmvn(X11,x1)*noncdfbvn(mu2,X22condcov,x2)),s15); 
    elseif e2==3;
       retp((pdfmvn(X11,x1)*cdftvn(mu2,X22condcov,x2)),s15);  
    elseif e2==4;
       retp((pdfmvn(X11,x1)*cdfqvn(mu2,X22condcov,x2)),s15);  
    else;        
       _covarr = 1;
       { P,s15 } = cdfmvnanalytic(mu2,x22condcov,x2,s); 
        retp((pdfmvn(X11,x1)*P),s15);   
    endif;
endp;


/* { gcov,gx,s1 } = gradpdfcdfmvn(cov,x,s,indxeq) : Gradients of Standard partial cumulative multivariate normal distribution function

Input:       x - Kx1 vector of absiccae for equality conditions and truncation from above for inequality conditions
           cov - K x K matrix of correlation parameters 
             s - seed for use by SSJ procedure (if this procedure is used) for integration dimension > 4;
             indxeq - Kx1 vector, where there is a one for abscissae for equality conditions and zero for truncation from above               

             cov   =   { 1     rho12     rho13,        if _cholesky=0;     chol(cov)  = { 1       S12           S13,      if _cholesky=1
                         rho12     1      rho23,                                          0   sqrt(1-S12^2)     S23,
                         rho13  rho23       1   };                                        0         0           sqrt(1-S13^2-S23^2)  } 

               x   = {  x1   
                        x2   
                        x3 };   say three abscissae 

           indxeq  =  { 1     This means first and third abscissae are equality conditions, 
                        0     and second abscissa is truncation from above; cannot have all zeros (equivalent to multivariate cumulative distribution)
                        1  }; or cannot have all ones (equivalent to multivariate density function); use cdfmvn and pdfmvn in these cases.  


Global       _Cholesky = 1 if you want gradients with respect to Cholesky of sigma and not sigma
  
** Output:     gcov - (K*(K-1)/2) x 1  vector of gradients of pdfcdfmvn with respect to the correlation (upper triagular wise) 
                 gx - K x 1 matrix of gradients of pdfcdfmvn with respect to x

              gcov   =  { dF/drho12,          if _cholesky=0        gcov  =  { dF/dS12,         if _cholesky=1;
                          dF/drho13,                                           dF/dS13,
                          dF/drho23 };                                         dF/dS23  }      
                          
                gx  =  { dF/dx1   
                         dF/dx2  
                         dF/dx3 };                           */
                         
proc (3) = gradpdfcdfmvn(cov,x,s,indxeq);
    local e1,e,e10,e11,Xcov,gX11reorder,gx,gcov,pdf1,x1,x2,noncdfn2,gx1,gx2,s15,P,gX11,gY,gmu,gmu2,gX22condcov,
          gX1new,mm1,gX2new,indxfull,indeq,indneq,X11,X12,X22,invX11,mu2,X22condcov,newm2,X22condcor,e2;
    e = rows(x); 
    mm1=_cholesky;
    indxfull = seqa(1,1,e);
    indeq = selif(indxfull,indxeq);
    indneq = selif(indxfull,(1-indxeq));
    x1 = x[indeq];
    x2 = x[indneq];
    e1 = rows(x1);
    e10 = e1*(e1-1)/2;
    e11 = e*(e-1)/2;
    e2 = rows(x2);
    if e2<=4;
        s15=s;
    endif;   
    X11 = cov[indeq,indeq];
    X12 = cov[indneq,indeq];
    X22 = cov[indneq,indneq];
    Xcov = (X11~X12')|(X12~X22);
    invX11 = invpd(X11);
    mu2 = X12*invX11*x1;
    X22condcov = X22-X12*invX11*X12'; 

    gx = zeros(e,1);
    gcov = zeros(e11,1);
    _condcov=0;
    pdf1 = pdfmvn(X11,x1);
    _cholesky=0;
    { gX11,gx1 } = gradpdfmvn(X11,x1);
    { gY, gmu, gX1new } = gcondmean(eye(e2),zeros(e,1),Xcov,x1);  
    { gY, gX2new } = gcondcov(eye(e2),Xcov);
    if e2 ==1;
      noncdfn2 = noncdfn(mu2,X22condcov,x2);        
      { gmu2,gX22condcov,gx2 } = gradnoncdfn(mu2,X22condcov,x2);  
    elseif e2==2;
      noncdfn2 = noncdfbvn(mu2,X22condcov,x2);        
      { gmu2,gX22condcov,gx2 } = gradnoncdfbvn(mu2,X22condcov,x2);  
    elseif e2==3;
      noncdfn2 = noncdftvn(mu2,X22condcov,x2);        
      { gmu2,gX22condcov,gx2 } = gradnoncdftvn(mu2,X22condcov,x2);  
    elseif e2==4;
      noncdfn2 = noncdfqvn(mu2,X22condcov,x2);        
      { gmu2,gX22condcov,gx2 } = gradnoncdfqvn(mu2,X22condcov,x2); 
    else;
      _covarr=1; 
      { P,gmu2,gX22condcov,gx2,s15 } = pdfmvnanalytic(mu2,X22condcov,x2,s);
      noncdfn2 = P; 
    endif;
    
    gx[indeq] = gx1*noncdfn2+pdf1*invX11*X12'*gmu2;
    gx[indneq] = pdf1*gx2;
    if e2 == e-1;
       gcov=pdf1*(gX1new*gmu2+gX2new*gX22condcov);
    else;
       gX11reorder = (matndupdiagonefull(gX11)~zeros(e1,e2))|(zeros(e2,e1)~zeros(e2,e2));
       gX11reorder = (vecndup(gX11reorder));
       gcov=gX11reorder*noncdfn2+pdf1*(gX1new*gmu2+gX2new*gX22condcov);
    endif;
    gcov = matndupdiagzerofull(gcov);
    gcov[indeq|indneq,indeq|indneq]=gcov;   
    if mm1 == 0;
       retp(vecndup(gcov),gx,s15);
    else;
       retp((gcholeskycor(cov)*vecndup(gcov)),gx,s15);
    endif;
endp;
 

/* { F,s1 } =nonpdfcdfmvn(mu,cov,x,s,indxeq) : Non-standard partial cumulative multivariate normal distribution function

Input:       
            mu - Kx1 vector of means of the K random variates
           cov - K x K matrix of covariance parameters 
             x - Kx1 vector of absiccae for equality conditions and truncation from above for inequality conditions
             s - seed for use by SSJ procedure (if this procedure is used) for integration dimension > 4;
        indxeq - Kx1 vector, where there is a one for abscissae for equality conditions and zero for truncation from above               

              mu   = { mu1,
                       mu2,
                       mu3 };

             cov   =   { sig11    sig12   sig13,        if _cholesky=0;    chol(cov)  = { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

               x   = {  x1   
                        x2   
                        x3 };   say three abscissae 

           indxeq  =  { 1     This means first and third abscissae are equality conditions, 
                        0     and second abscissa is truncation from above; cannot have all zeros (equivalent to multivariate cumulative distribution)
                        1  }; or cannot have all ones (equivalent to multivariate density function); use cdfmvn and pdfmvn in these cases.  

Output:        F   =  integral from X2 = -inf to x2 { nonpdfmvn(x1|X2|x3, cov) } dX2

              s1   = seed for use of next SSJ call in model estimation

Global:  The global below is applicable only when the dimensionalityof integration exceeds four. 
         _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                         "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                         "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                         "OVUS"                    - One-variate univariate screening approach
                         "OVBS"                    - One-variate bivariate screening approach
                         "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                         "BME"                     - Bivariate ME approach
                         "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS   */

                                     
proc (2) = nonpdfcdfmvn(mu,cov,x,s,indxeq);
    local e1,indxfull,s10,indeq,s15,p,mu1,mu2condcov,indneq,x1,x2,X11,X12,X22,invX11,mu2,X22condcov,newm2,X22condcor,e2;
    e1 = rows(x);
    indxfull = seqa(1,1,e1);
    indeq = selif(indxfull,indxeq);
    indneq = selif(indxfull,(1-indxeq));
    x1 = x[indeq];
    x2 = x[indneq];
    mu1 = mu[indeq];
    mu2 = mu[indneq];
    e2 = rows(x2);
    if e2<=4;
        s15=s;
    endif;    
    X11 = cov[indeq,indeq];
    X12 = cov[indneq,indeq];
    X22 = cov[indneq,indneq];
    invX11 = invpd(X11);
    mu2condcov = X12*invX11*(x1-mu1)+mu2;
    X22condcov = X22-X12*invX11*X12'; 
    if e2 ==1;
       retp((nonpdfmvn(mu1,X11,x1)*noncdfn(mu2condcov,X22condcov,x2)),s15);        
    elseif e2==2;
       retp((nonpdfmvn(mu1,X11,x1)*noncdfbvn(mu2condcov,X22condcov,x2)),s15); 
    elseif e2==3;
       retp((nonpdfmvn(mu1,X11,x1)*noncdftvn(mu2condcov,X22condcov,x2)),s15);  
    elseif e2==4;
       retp((nonpdfmvn(mu1,X11,x1)*noncdfqvn(mu2condcov,X22condcov,x2)),s15);  
    else;        
       _covarr = 1;
       { P,s15 } = cdfmvnanalytic(mu2condcov,x22condcov,x2,s); 
        retp((nonpdfmvn(mu1,X11,x1)*P),s15);   
    endif;
endp;


/* { gmu,gcov,gx,s1 } = gradnonpdfcdfmvn(mu,cov,x,s,indxeq) : Gradients of non-standard partial cumulative multivariate normal distribution function

Input:      mu - Kx1 vector of means of the K random variates
           cov - K x K matrix of covariance parameters 
             x - Kx1 vector of absiccae for equality conditions and truncation from above for inequality conditions 
            s - seed for use by SSJ procedure (if this procedure is used) for integration dimension > 4;
       indxeq - Kx1 vector, where there is a one for abscissae for equality conditions and zero for truncation from above               

              mu   = { mu1,
                       mu2,
                       mu3 };

             cov   =   { sig11    sig12   sig13,        if _cholesky=0;    chol(cov)  = { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

               x   = {  x1   
                        x2   
                        x3 };   say three abscissae 

           indxeq  =  { 1     This means first and third abscissae are equality conditions, 
                        0     and second abscissa is truncation from above; cannot have all zeros (equivalent to multivariate cumulative distribution)
                        1  }; or cannot have all ones (equivalent to multivariate density function); use cdfmvn and pdfmvn in these cases.  

Global       _Cholesky = 1 if you want gradients with respect to Cholesky of cov and not cov

** Output:      gmu - K x 1 vector of gradients of nonpdfcdfmvn(=F) with respect to mu
               gcov - (K*(K+1)/2) x 1  vector of gradients of nonpdfcdfmvn with respect to the covariance elements (upper triagular wise) 
                 gx - K x 1 matrix of gradients of nonpdfcdfmvn(=F) with respect to s
               s1   = seed for use of next SSJ call in model estimation
                gx  =  { dF/dx1   
                         dF/dx2  
                         dF/dx3 };

               gmu  =  { dF/dmu1,
                         dF/dmu2,
                         dF/dmu3 };
                         
              gcov  =  { dF/dsig11,          if _cholesky=0         gcov  =  { dF/dS11,         if _cholesky=1;
                         dF/dsig12,                                           dF/dS12,
                         dF/dsig13,                                           dF/dS13,
                         dF/dsig22,                                           dF/dS22,
                         dF/dsig23,                                           dF/dS23,
                         dF/disg33 };                                         dF/dS33  }      */
                                     
proc (4) = gradnonpdfcdfmvn(mu,cov,x,s,indxeq);
    local e1,e,e10,e11,Xcov,gX11reorder,gsigma,mu2condcov,mu1,nonpdf1,gmu2condcov,gx,gcov,pdf1,noncdfn2,gx1,gx2,s15,s10,P,gX11,gY,gmu,gmu2,
           gX22condcov,gX1new,gX2new,gmu1,indxfull,indeq,indneq,x1,x2,X11,X12,X22,invX11,mu2,X22condcov,newm2,X22condcor,e2,
           gmucond,mm1,gmucond1,gmucond2,gx1cond;
    e = rows(x);
    mm1=_cholesky;
    indxfull = seqa(1,1,e);
    indeq = selif(indxfull,indxeq);
    indneq = selif(indxfull,(1-indxeq));
    x1 = x[indeq];
    x2 = x[indneq];
    mu1 = mu[indeq];
    mu2 = mu[indneq];
    mu=mu1|mu2;
    e1 = rows(x1);
    e10 = e1*(e1+1)/2;
    e11 = e*(e+1)/2;
    e2 = rows(x2);
    if e2<=4;
        s15=s;
    endif;
    X11 = cov[indeq,indeq];
    X12 = cov[indneq,indeq];
    X22 = cov[indneq,indneq];
    Xcov = (X11~X12')|(X12~X22);
    invX11 = invpd(X11);
    mu2condcov = X12*invX11*(x1-mu1)+mu2; 
    X22condcov = X22-X12*invX11*X12'; 

    gx = zeros(e,1);
   gmu = zeros(e,1);
   gcov = zeros(e11,1);
    _condcov=1;
    nonpdf1 = nonpdfmvn(mu1,X11,x1);
    _cholesky=0;
    if e1 == 1;
        { gmu1,gX11,gx1 } = gradnonpdfn(mu1,X11,x1);
    else;
        { gmu1,gX11,gx1 } = gradnonpdfmvn(mu1,X11,x1);
    endif;
    { gY, gmucond, gX1new } = gcondmean(eye(e2),mu,Xcov,x1); 
    gmucond1 = gmucond[1:e1,.];   gmucond2 = gmucond[e1+1:e,.];      gx1cond = -gmucond1;
    { gY, gX2new } = gcondcov(eye(e2),Xcov);

    if e2 ==1;
      noncdfn2 = noncdfn(mu2condcov,X22condcov,x2);        
      { gmu2condcov,gX22condcov,gx2 } = gradnoncdfn(mu2condcov,X22condcov,x2);  
    elseif e2==2;
      noncdfn2 = noncdfbvn(mu2condcov,X22condcov,x2);        
      { gmu2condcov,gX22condcov,gx2 } = gradnoncdfbvn(mu2condcov,X22condcov,x2);  
    elseif e2==3;
      noncdfn2 = noncdftvn(mu2condcov,X22condcov,x2);        
      { gmu2condcov,gX22condcov,gx2 } = gradnoncdftvn(mu2condcov,X22condcov,x2);  
    elseif e2==4;
      noncdfn2 = noncdfqvn(mu2condcov,X22condcov,x2);        
      { gmu2condcov,gX22condcov,gx2 } = gradnoncdfqvn(mu2condcov,X22condcov,x2); 
    else;
      _covarr=1; 
      { P,gmu2condcov,gX22condcov,gx2,s15 } = pdfmvnanalytic(mu2condcov,X22condcov,x2,s);
      noncdfn2 = P; 
    endif;
    
    gx[indeq] = gx1*noncdfn2+nonpdf1*gx1cond*gmu2condcov;
    gx[indneq] = nonpdf1*gx2;
    gmu[indeq] = gmu1*noncdfn2+nonpdf1*gmucond1*(gmu2condcov);
    gmu[indneq] = nonpdf1*gmucond2*gmu2condcov;
    gX11reorder = (matdupfull(gX11)~zeros(e1,e2))|(zeros(e2,e1)~zeros(e2,e2));
    gX11reorder = (vecdup(gX11reorder));
    gcov=gX11reorder*noncdfn2+nonpdf1*(gX1new*gmu2condcov+gX2new*gX22condcov);
    gcov = matdupfull(gcov);
    gcov[indeq|indneq,indeq|indneq]=gcov; 
    if mm1 == 0;
       retp(gmu,vecdup(gcov),gx,s15);
    else;
       retp(gmu,(gcholeskycov(cov)*vecdup(gcov)),gx,s15);
    endif;
endp;
 

/***************************************************************************************************************************************************
                         Univariate and multivariate logistic cumulative distribution function and its complement, and gradients
***************************************************************************************************************************************************/


/* cdfmvlogit(a) : standard multivariate logistic cumulative distribution function   

 Input:       a - K x Q  matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations
**
** Output:      w - Q x 1 vector  Pr(X < a). */


proc (1) = cdfmvlogit(a);
    local f; 
    f = exp(-a);
    retp((1+sumc(f))^(-1));
endp;


/* { ga } = gradcdfmvlogit(a) :   

 Input:       a - K x Q vector of abscissae (a is truncation point from above for mvlogit variable vector X (of size K)- -inf to a, and
                                             Q is number of observations)

** Output:    ga - K x Q matrix  */

proc (1) = gradcdfmvlogit(a);
    local f,h; 
    f = exp(-a);
    h=(1+sumc(f))^(-1);
    retp(h'.*(f.*(h')));
endp;


/* noncdfmvlogit(a,mu,sig)  : non-standard multivariate logistic CDF  

 Input:       a - K x Q matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations 
             mu - K x Q matrix of location parameters, or if all Q observations have same mu, Kx1 vector
             sig - K x Q matrix of scale parameters, or if all Q observations have same sig, Kx1 vector 
**
** Output:      w - Q x 1 vector  */

proc(1) = noncdfmvlogit(a,mu,sig);
    local aa,f;
    aa = (a-mu)./sig;
    f = exp(-aa);
    retp((1+sumc(f))^(-1));
endp;



/* { ga,gmu,gsig } = gradnoncdfmvlogit(a,mu,sig) :   

 Input:       a - K x Q matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations 
             mu - K x Q matrix of location parameters, or if all Q observations have same mu, Kx1 vector
             sig - K x Q matrix of scale parameters, or if all Q observations have same sig, Kx1 vector 

** Output:    ga - K x Q matrix  
              gmu - K x Q matrix of location parameters, or if all Q observations have same mu, Kx1 vector
              gsig - K x Q matrix of scale parameters, or if all Q observations have same sig, Kx1 vector  */

proc (3) = gradnoncdfmvlogit(a,mu,sig);
    local aa,f,h,aa1,aa2,aamu,aasig; 
    aa = (a-mu)./sig;
    aa1 = gradcdfmvlogit(aa);
    aa2 = aa1./sig;
    aamu = aa1.*(-1/sig);
    aasig = (aa1.*(-aa))./sig;
    if cols(mu)==1;
      aamu = sumc((aamu'));
    endif;
    if cols(sig)==1;
      aasig = sumc((aasig'));
    endif;
    retp(aa2,aamu,aasig);
endp;



/* cdfmvlogitcomp(b) : Complement of cdfmvlogit  

 Input:         b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)

** Output:      w - 1 x 1 vector  Pr(Y > b). */

proc (1) = cdfmvlogitcomp(b);
    local a1,b1,a2,b2,i,yi,com,b3,b4,j,com1; 
    b1 = rows(b);
    com1=0;
    for i (1,b1,1);
        com=0;
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2 = b[yi[j,.]];
            b4 = ((-1)^i).*cdfmvlogit(b2);
            com = com+b4;
        endfor;            
        com1 = com+com1;
    endfor;
    /* because of digitization issues, sometimes (a2+com1) returns a value of zero minus (that is, a value very close to zero but negative);
       in this case, simply return the value of zero */
    if (1+com1) < 0;
       retp(0);
    else;
       retp(1+com1);
    endif;        
endp;   


/* { gb } = gradcdfmvlogitcomp(b) :   

 Input:      b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)

** Output:   gb - K x 1 vector */


proc (1) = gradcdfmvlogitcomp(b);
    local a1,b1,ga1,gcombnew,gcomanew,i,gcoma,gcomb,yi,j,gcomb1,b2,gcom; 
    b1 = rows(b);
    gcombnew = zeros(b1,1); 
    for i (1,b1,1);
        gcomb = zeros(b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            gcomb1 = zeros(b1,1);
            b2 = b[yi[j,.]];
            gcom = ((-1)^i).*gradcdfmvlogit(b2);
            gcomb1[yi[j,.]]=gcom;
            gcomb = gcomb+gcomb1;
        endfor;          
        gcombnew = gcombnew+gcomb;
    endfor;
    retp(gcombnew);
endp;   


/* noncdfmvlogitcomp(b,mu,sig) : complement of noncdfmvlogit  

 Input:       b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)
              mu - (K) x 1 vector of location parameters of Y
              sig - (K) x 1 vector of scale parameters of Y

** Output:      w - 1 x 1 vector  Pr(Y > b). */

proc (1) = noncdfmvlogitcomp(b,mu,sig);
    local bb;
    bb = (b-mu)./sig;
    retp(cdfmvlogitcomp(bb));
endp;

/* gradnoncdfmvlogitcomp(a,b,mu,sig) : gradient of complement of noncdfmvlogit  

 { gb,gmu,gsig } = gradnoncdfmvlogitcomp(b,mu,sig) :   

Input:        b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - c to inf)
              mu - (K) x 1 vector of location parameters of Y
              sig - (K) x 1 vector of scale parameters of Y

** Output:    gb - K x 1 vector
              gmu - (K) x 1 vector
              gsig - (K) x 1 matrix of scale parameters  */


proc (3) = gradnoncdfmvlogitcomp(b,mu,sig);
    local bb,gbb,gbb1,gsig;   
    bb = (b-mu)./sig;
    { gbb } = gradcdfmvlogitcomp(bb);
    gbb1 = gbb./sig;
    gsig = (-gbb.*bb)./sig;  
    retp(gbb1,(-gbb1),(gsig));
endp;


/* cdfmvlogitc(a,b) : combination of cdfmvlogit and complement of cdfmvlogit  

 Input:       a - K x 1 vector of abscissae (a is truncation point from above for mvlogit variable vector X- -inf to a)
              b - M x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)

**  If you want Pr(Y>b), just put a = 1000;

** Output:      w - 1 x 1 vector  Pr(X < a, Y > b). */

proc (1) = cdfmvlogitc(a,b);
    local a1,b1,a2,b2,i,yi,com,b3,b4,j,com1; 
    a1 = rows(a);
    b1 = rows(b);
    a2 = cdfmvlogit(a);
    com1=0;
    for i (1,b1,1);
        com=0;
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2 = b[yi[j,.]];
            b4 = ((-1)^i).*cdfmvlogit(a|b2);
            com = com+b4;
        endfor;            
        com1 = com+com1;
    endfor;
    /* because of digitization issues, sometimes (a2+com1) returns a value of zero minus (that is, a value very close to zero but negative);
       in this case, simply return the value of zero */
    if (a2+com1) < 0;
       retp(0);
    else;
       retp(a2+com1);
    endif;        
endp;   


/* { ga,gb } = gradcdfmvlogitc(a,b) :   

 Input:       a - K x 1 vector of abscissae (a is truncation point from above for mvlogit variable vector X- -inf to a)
              b - M x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)

**  If you want Pr(Y>b), just put a = 1000;

** Output:    ga - K x 1 vector
              gb - M x 1 vector */


proc (2) = gradcdfmvlogitc(a,b);
    local a1,b1,ga1,gcombnew,gcomanew,i,gcoma,gcomb,yi,j,gcomb1,b2,gcom; 
    a1 = rows(a);
    b1 = rows(b);
    ga1 = gradcdfmvlogit(a);
    gcombnew = zeros(b1,1); 
    gcomanew = zeros(a1,1);
    for i (1,b1,1);
        gcoma=zeros(a1,1);
        gcomb = zeros(b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            gcomb1 = zeros(b1,1);
            b2 = b[yi[j,.]];
            gcom = ((-1)^i).*gradcdfmvlogit(a|b2);
            gcoma = gcoma+gcom[1:a1];
            gcomb1[yi[j,.]]=gcom[a1+1:rows(gcom)];
            gcomb = gcomb+gcomb1;
        endfor;          
        gcomanew = gcomanew+gcoma;
        gcombnew = gcombnew+gcomb;
    endfor;
    retp(gcomanew+ga1,gcombnew);
endp;   


/* noncdfmvlogitc(a,b,mu,sig) : combination of noncdfmvlogit and complement of noncdfmvlogit  

 Input:       a - K x 1 vector of abscissae (a is truncation point from above for mvlogit variable vector X- -inf to a)
              b - M x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)
              mu - (K+M) x 1 vector of location parameters of X|Y
              sig - (K+M) x 1 vector of scale parameters of X|Y

**  If you want Pr(Y>b), just put a = 1000;

** Output:      w - 1 x 1 vector  Pr(X < a, Y > b). */

proc (1) = noncdfmvlogitc(a,b,mu,sig);
    local aa,m,h,bb;
    m = rows(a);
    h = rows(b);
    aa = (a-mu[1:m])./sig[1:m];
    bb = (b-mu[m+1:m+h])./sig[m+1:m+h];
    retp(cdfmvlogitc(aa,bb));
endp;

/* gradnoncdfmvlogitc(a,b,mu,sig) : gradient of combination of noncdfmvlogit and complement of noncdfmvlogit  

 { ga,gb,gmu,gsig } = gradnoncdfmvlogitc(a,b,mu,sig) :   

Input:        a - K x 1 vector of abscissae (a is truncation point from above for mvlogit variable vector X- -inf to b)
              b - M x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - c to inf)
              mu - (K+M) x 1 vector of location parameters of X|Y
              sig - (K+M) x 1 vector of scale parameters of X|Y

** Output:    ga - K x 1 vector 
              gb - M x 1 vector
              gmu - (K+M) x 1 vector
              gsig - (K+M) x 1 matrix of scale parameters  */


proc (4) = gradnoncdfmvlogitc(a,b,mu,sig);
    local m,h,mua,mub,siga,sigb,aa,bb,gaa,gbb,gaa1,gbb1,gsiga,gsigb;
    m = rows(a);
    h = rows(b);
    mua = mu[1:m];
    mub = mu[m+1:m+h];
    siga = sig[1:m];
    sigb = sig[m+1:m+h];    
    aa = (a-mua)./siga;
    bb = (b-mub)./sigb;
    { gaa, gbb } = gradcdfmvlogitc(aa,bb);
    gaa1 = gaa./siga;
    gbb1 = gbb./sigb;
    gsiga = (-gaa.*aa)./siga;
    gsigb = (-gbb.*bb)./sigb;  
    retp(gaa1,gbb1,(-gaa1|-gbb1),(gsiga|gsigb));
endp;

/* cdrectmvlogit(mu,sig,x1,x2) : rectangular integration of standard multivariate logistic distribution  

 Input:       mu - K x 1 vector of location parameters
              sig - K x 1 vector of scale parameters
              x1 - K x 1 vector of abscissae (a is lower truncation point)
              x2 - K x 1 vector of abscissae (b is upper truncation point)

cdfrectmvlogit(x1,x2) is integral from x1 to x2 of multivariate logistic density function P(x1<X<x2)

**  If you want Pr(X>x1), just put x2 = 1000*ones(K,1); if you want Pr(X<x2), just put x1 = -1000*ones(K,1); 

** Output:      w - 1 x 1 vector  Pr(x1<X<x2). */

proc (1) = cdrectmvlogit(mu,sig,x1,x2);
    local e2,P,newx,kk2,w,s15,sign,P1,comb,ecomb,j;
    e2 = rows(x1);
    { sign,comb } = rectcombs(x1,x2);
    ecomb = rows(comb);
    P = 0;
    for j(1,ecomb,1);
       P = P+sign[j]*noncdfmvlogit(((comb[j,.])'),mu,sig); 
    endfor;
    if P < 0;
       retp(0);
    else;
       retp(P);
    endif;   
endp;   

 
/*
** gradcdrectmvlogit.src 
**
** Purpose: Develops the gradients of cdrectmvlogit 

** Format:      { P,gmu,gsig,gx1,gx2 } = gradcdrectmvlogit(mu,sig,x1,x2)
**
** Input:       
                 mu is the (Kx1) vector of location parameters
                 sig is the(KX1) vector of scale parameters
                 x1 represents lower truncation truncation; x2 represents upper truncation points 

** Output:       P is the rectangular probability value
                 gmu is the (Kx1) gradient vector of F with respect to the vector of location parameters
                 gsig is the Kx1 gradient vector of F with respect to the location parameters (K>1)
                 gx1 represents the (Kx1) gradient vector of F with respect to lower truncation points
                 gx2 represents the (Kx1) gradient vector of F with respect to upper truncation points                 

                 mu  = {  mu1       x1 = { x11               x2 = { x21
                          mu2              x12                      x22
                          mu3 };           x13 };                   x23 };

                 sig = { sig1
                         sig2
                         sig3  };

                 gmu  =  { dF/dmu1,                                       
                           dF/dmu2,                                                                
                           dF/dmu3  };    same with gsig, gx1, and gx2    */
                         
proc (5) = gradcdrectmvlogit(mu,sig,x1,x2);
    local e2,sign,comb,indxa,ecomb,indxb,s15,gmu1,gsig1,gx1a,gx2b,mm1,j,gmu,gsig,gx,P,P1,gxx,gxx1,gxx2;
    e2 = rows(x1); 
    { sign,comb,indxa,indxb } = rectcombsforgrad(x1,x2);
    ecomb = rows(comb);
    gmu1 = zeros(e2,1);  gsig1 = zeros(e2,1);  gx1a = zeros(e2,1);    gx2b = zeros(e2,1);
    P=0;    
    for j(1,ecomb,1); 
       P = P+sign[j]*noncdfmvlogit(((comb[j,.])'),mu,sig);  
       { gx,gmu,gsig } = gradnoncdfmvlogit(((comb[j,.])'),mu,sig);
       gmu1 = sign[j]*gmu+gmu1;
       gsig1 = sign[j]*gsig+gsig1;
       gxx = sign[j]*gx;
       gx1a = gx1a+gxx.*((indxa[j,.])');
       gx2b = gx2b+gxx.*((indxb[j,.])');
    endfor;  
    retp(P,gmu1,gsig1,gx1a,gx2b);
endp;

/***************************************************************************************************************************************************
                         Univariate and multivariate logistic density function, and gradients
***************************************************************************************************************************************************/


/* pdfmvlogit(a) : standard multivariate logistic density function   

 Input:       a - K x Q matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations
**
** Output:      w - Q x 1 vector  */


proc (1) = pdfmvlogit(a);
    local m,f;
    m = rows(a); 
    f = exp(-a);
    retp((m!)*((1+sumc(f))^(-(m+1))).*exp(-(sumc(a))));
endp;


/* { ga } = gradpdfmvlogit(a) :   

 Input:       a - K x Q vector of abscissae (K is number of variates and Q corresponds to number of observations)

** Output:    ga - K x Q matrix  */

proc (1) = gradpdfmvlogit(a);
    local m,f,h,d,pf; 
    m = rows(a); 
    f = exp(-a);
    d = (1+sumc(f));
    pf = ((m!)*((d)^(-(m+1))).*exp(-(sumc(a))));
    h = (m+1).*(f./(d'))-1;
    retp((pf').*h);
endp;

/* nonpdfmvlogit(a,mu,sig)  : non-standard multivariate logistic density function  

 Input:       a - K x Q matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations
             mu - K x Q matrix of location parameters
             sig - K x Q matrix of scale parameters 
**
** Output:      w - Q x 1 vector  */

proc(1) = nonpdfmvlogit(a,mu,sig);
    local aa,m,f;
    aa = (a-mu)./sig;
    retp((1/prodc(sig)).*pdfmvlogit(aa));
endp;

/* gradnonpdfmvlogit(a,mu,sig)  : Gradient of non-standard multivariate logistic density function  

 Input:      a - K x Q matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations
             mu - K x Q matrix of location parameters
             sig - K x Q matrix of scale parameters 
**
** Output:    ga - K x Q matrix  
              gmu - K x Q matrix of location parameters, or if all Q observations have same mu, Kx1 vector
              gsig - K x Q matrix of scale parameters, or if all Q observations have same sig, Kx1 vector  */

proc(3) = gradnonpdfmvlogit(a,mu,sig);
    local aa,aa1,prsig,aa2,aamu,aasig1,aasig2,aasig;
    aa = (a-mu)./sig;
    aa1 = gradpdfmvlogit(aa);
    prsig = ((1/prodc(sig)))';
    aa2 = prsig.*(aa1./sig);
    aamu = -aa2;
    aasig1 = prsig.*((aa1.*(-aa))./sig);
    aasig2 = (-prsig./sig).*((pdfmvlogit(aa))');
    aasig = aasig1+aasig2;
    if cols(mu)==1;
      aamu = sumc((aamu'));
    endif;
    if cols(sig)==1;
      aasig = sumc((aasig'));
    endif;
    retp(aa2,aamu,aasig);
endp;


/***************************************************************************************************************************************************
                 Standard partial cumulative multivariate logistic cumulative distribution function and its complement, and gradients
***************************************************************************************************************************************************/

/* pdfcdfmvlogit(a,b) : standard partial cumulative multivariate logistic distribution function

Prob(eta1=a,eta2<b), where eta = (eta1|eta2) is standard multivariate logistic distributed.

Input:       a - K1xQ matrix of absiccae for equality conditions, where K1 corresponds to number of "equality variates" and Q corresponds to number of observations
             b - K2xQ matrix of absiccae representing truncation from above, where K2 corresponds to number of "inequality variates" and Q corresponds to number of observations  

Output:      w - Qx1 vector   */

proc(1) = pdfcdfmvlogit(a,b);
    local m,d,c;
    m = rows(a);
    d = a|b;
    c = (prodc((exp(-a))))./((1+(sumc(exp(-d))))^(m+1));
    retp((m!)*c);
endp;


/* { ga,gb } = gradpdfcdfmvlogit(a,b) :   

Input:       a - K1xQ matrix of absiccae for equality conditions, where K1 corresponds to number of "equality variates" and Q corresponds to number of observations
             b - K2xQ matrix of absiccae representing truncation from above, where K2 corresponds to number of "inequality variates" and Q corresponds to number of observations  

Output:     ga - K1xQ matrix of gradients for absiccae for equality conditions, where K1 corresponds to number of "equality variates" and Q corresponds to number of observations
            gb - K2xQ matrix of gradients for absiccae representing truncation from above, where K2 corresponds to number of "inequality variates" and Q corresponds to number of observations  */

proc (2) = gradpdfcdfmvlogit(a,b);
    local m,f,f1,d,pf,h,h1; 
    m = rows(a); 
    f = exp(-a);
    f1 = exp(-b);
    d = (1+sumc(f)+sumc(f1));
    pf = ((m!)*((d)^(-(m+1))).*exp(-(sumc(a))));
    h = (m+1).*(f./(d'))-1;
    h1 = ((pf')*(m+1)).*(f1./d');
    retp(((pf').*h),h1);
endp;

/* nonpdfcdfmvlogit(a,b,mu,sig) : non-standard partial cumulative multivariate logistic distribution function

(eta1|eta2) distributed with location parameter mu and scale parameter sig

Prob(eta1=a,eta2<b), where eta = (eta1|eta2) is non-standard multivariate logistic distributed.

Input:       a - K1xQ matrix of absiccae for equality conditions, where K1 corresponds to number of "equality variates" and Q corresponds to number of observations
             b - K2xQ matrix of absiccae representing truncation from above, where K2 corresponds to number of "inequality variates" and Q corresponds to number of observations
            mu - (K1+K2)xQ matrix of location parameters, or if all Q observations have same mu, can be a (K1+K2)x1 vector; First K1 rows of mu correspond to a, next K2 to b;
           sig - (K1+K2)xQ matrix of scale parameters, or if all Q observations have same sig, can be a (K1+K2)x1 vector; First k1 rows of sig correspond to a, next K2 to b;              

Output:      w - Qx1 vector   */

proc(1) = nonpdfcdfmvlogit(a,b,mu,sig);
    local k1,k2,aa,bb;
    k1 = rows(a);
    k2 = rows(b);
    aa = (a-mu[1:k1,.])./(sig[1:k1,.]);
    bb = (b-mu[k1+1:k1+k2])./(sig[k1+1:k1+k2]);
    retp((1/(prodc(sig[1:k1,.]))).*pdfcdfmvlogit(aa,bb));
endp;

/* { ga,gb,gmua,gmub,gsiga,gsigb } = gradnonpdfcdfmvlogit(a,b,mu,sig)  : Gradient of non-standard multivariate logistic density function  

Input:       a - K1xQ matrix of absiccae for equality conditions, where K1 corresponds to number of "equality variates" and Q corresponds to number of observations
             b - K2xQ matrix of absiccae representing truncation from above, where K2 corresponds to number of "inequality variates" and Q corresponds to number of observations
            mu - (K1+K2)xQ matrix of location parameters, or if all Q observations have same mu, can be a (K1+K2)x1 vector; First K1 rows of mu correspond to a, next K2 to b;
           sig - (K1+K2)xQ matrix of scale parameters, or if all Q observations have same sig, can be a (K1+K2)x1 vector; First K1 rows of sig correspond to a, next K2 to b;              

Output:     ga - K1xQ matrix of gradients for absiccae for equality conditions, where K1 corresponds to number of "equality variates" and Q corresponds to number of observations
            gb - K2xQ matrix of gradients for absiccae representing truncation from above, where K2 corresponds to number of "inequality variates" and Q corresponds to number of observations   
            gmua - K1 x Q matrix of gradients of location parameters, or if all Q observations have same mu, K1x1 vector
            gmub - K2 x Q matrix of gradients of location parameters, or if all Q observations have same mu, K2x1 vector
            gsiga - K1 x Q matrix of gradients of scale parameters, or if all Q observations have same sig, K1x1 vector  
            gsigb - K2 x Q matrix of gradients of scale parameters, or if all Q observations have same sig, K1x1 vector  */

proc(6) = gradnonpdfcdfmvlogit(a,b,mu,sig);
    local k1,k2,siga,sigb,mua,mub,aa,bb,gaa,gbb,prsig,gaa2,gbb2,gmua,gmub,gsiga1,gsiga2,gsiga,gsigb;
    k1 = rows(a);
    k2 = rows(b);
    siga = sig[1:k1,.];
    sigb = sig[k1+1:k1+k2,.];
    mua = mu[1:k1,.];
    mub = mu[k1+1:k1+k2,.];
    aa = (a-mua)./(siga);
    bb = (b-mub)./(sigb);
    { gaa,gbb } = gradpdfcdfmvlogit(aa,bb);
    prsig = ((1/prodc(siga)))';
    gaa2 = prsig.*(gaa./siga);
    gbb2 = prsig.*(gbb./sigb);
    gmua = -gaa2;
    gmub = -gbb2;
    gsiga1 = prsig.*((gaa.*(-aa))./siga);
    gsiga2 = (-prsig./siga).*((pdfcdfmvlogit(aa,bb))');
    gsiga = gsiga1+gsiga2;
    gsigb = prsig.*((gbb.*(-bb))./sigb);
    if cols(mu)==1;
      gmua = sumc((-gaa2'));
      gmub = sumc((-gbb2'));
    endif;
    if cols(sig)==1;
      gsiga = sumc((gsiga'));
      gsigb = sumc((gsigb'));
    endif;
    retp(gaa2,gbb2,gmua,gmub,gsiga,gsigb);
endp;




/* pdfcdfmvlogitc(a,b,c) : combination of cdfmvlogit and complement of cdfmvlogit, with pdfmvlogit  

 Input:       a - M x 1 vector of density function evaluation points (equality) for new set of variates Z
              b - K x 1 vector of abscissae (b is truncation point from above for mvlogit variable vector X- -inf to b)
              c - M x 1 vector of abscissae (c is truncation point from below for mvlogit variable vector Y - c to inf)


**  If you want Pr(Y>b), just put a = 1000;

** Output:      w - 1 x 1 vector  Pr(Z=a,X < b, Y > c). */

proc (1) = pdfcdfmvlogitc(a,b,c);
    local a1,b1,a2,c2,i,yi,com,c3,c4,j,com1; 
    a1 = rows(a);
    a2 = pdfcdfmvlogit(a,b);
    com1=0;
    for i (1,a1,1);
        com = 0;
        yi = combinate(a1,i);
        for j (1,rows(yi),1);
            c2 = c[yi[j,.]];              
            c4 = ((-1)^i).*pdfcdfmvlogit(a,b|c2);
            com = com+c4;
        endfor;
        com1 = com+com1;
    endfor;
    retp((a2)+com1);
endp;


/* nonpdfcdfmvlogitc(a,b,c,mu,sig) : combination of cdfmvlogit and complement of cdfmvlogit, with pdfmvlogit  

 Input:       a - M x 1 vector of density function evaluation points (equality) for new set of variates Z
              b - K x 1 vector of abscissae (b is truncation point from above for mvlogit variable vector X- -inf to b)
              c - M x 1 vector of abscissae (c is truncation point from below for mvlogit variable vector Y - c to inf)
              mu - (K+2*M) x 1 vector of location parameters of Z|X|Y; Z and Y should be of same dimension
              sig - (K+2*M) x 1 vector of scale parameters of Z|X|Y;

**  If you want Pr(z=c,Y>b), just put a = 1000;

** Output:      w - 1 x 1 vector  Pr(Z=c,X < a, Y > b). */

proc (1) = nonpdfcdfmvlogitc(a,b,c,mu,sig);
    local a1,b1,a2,c2,i,yi,com,c4,j,com1; 
    b1 = rows(b);
    a1 = rows(a);
    a2 = nonpdfcdfmvlogit(a,b,mu[1:a1+b1],sig[1:a1+b1]);
    com1=0;
    for i (1,a1,1);
        com = 0;
        yi = combinate(a1,i);
        for j (1,rows(yi),1);
           c2 = c[yi[j,.]];
           c4 = ((-1)^i).*nonpdfcdfmvlogit(a,b|c2,(mu[1:a1+b1]|mu[a1+b1+yi[j,.]]),(sig[1:a1+b1]|sig[a1+b1+yi[j,.]]));
           com = com+c4;
        endfor;
        com1 = com+com1;
    endfor;
    retp((a2)+com1);
endp;


/* { ga,gb,gc,gmu,gsig } = gradnonpdfcdfmvlogitc(a,b,c,mu,sig) : combination of cdfmvlogit and complement of cdfmvlogit, with pdfmvlogit  

Input:       a - M x 1 vector of density function evaluation points (equality) for new set of variates Z
              b - K x 1 vector of abscissae (b is truncation point from above for mvlogit variable vector X- -inf to b)
              c - M x 1 vector of abscissae (c is truncation point from below for mvlogit variable vector Y - c to inf)
              mu - (K+2*M) x 1 vector of location parameters of Z|X|Y; Z and Y should be of same dimension
              sig - (K+2*M) x 1 vector of scale parameters of Z|X|Y;

** Output:    ga - M x 1 vector
              gb - K x 1 vector 
              gc - M x 1 vector
              gmu - (K+2*M) x 1 vector
              gsig - (K+2*M) x 1 matrix of scale parameters */

proc (5) = gradnonpdfcdfmvlogitc(a,b,c,mu,sig);
    local a1,b1,ga1,gb1,gmua1,gmub1,gsiga1,gsigb1,gcombanew,gcombbnew,gcombcnew,gcombmuanew,gcombmubnew,gcombmucnew,
          gcombsiganew,gcombsigbnew,gcombsigcnew,gcoma,gcomb,gcomc,gcommua,gcommub,gcommuc,gcomsiga,gcomsigb,gcomsigc,
          gcomc1,gcommuc1,gcomsigc1,i,yi,c2,gcoma1,gcomb1,gcommua1,gcommub1,gcomsiga1,gcomsigb1,j; 
    a1 = rows(a);
    b1 = rows(b);
    { ga1,gb1,gmua1,gmub1,gsiga1,gsigb1 } = gradnonpdfcdfmvlogit(a,b,mu[1:a1+b1],sig[1:a1+b1]);
    gcombanew = zeros(a1,1);
    gcombbnew = zeros(b1,1);
    gcombcnew = zeros(a1,1);
    gcombmuanew = zeros(a1,1);
    gcombmubnew = zeros(b1,1);
    gcombmucnew = zeros(a1,1);
    gcombsiganew= zeros(a1,1);
    gcombsigbnew = zeros(b1,1);
    gcombsigcnew = zeros(a1,1);    
    for i (1,a1,1);
        gcoma = zeros(a1,1);
        gcomb = zeros(b1,1);
        gcomc = zeros(a1,1);
        gcommua = zeros(a1,1);
        gcommub = zeros(b1,1);
        gcommuc = zeros(a1,1);
        gcomsiga = zeros(a1,1);
        gcomsigb = zeros(b1,1);
        gcomsigc = zeros(a1,1);        
        yi = combinate(a1,i);
        for j (1,rows(yi),1);
           gcomc1 = zeros(a1,1);
           gcommuc1 = zeros(a1,1);
           gcomsigc1 = zeros(a1,1);
           c2 = c[yi[j,.]];
           { gcoma1,gcomb1,gcommua1,gcommub1,gcomsiga1,gcomsigb1 } = gradnonpdfcdfmvlogit(a,b|c2,(mu[1:a1+b1]|mu[a1+b1+yi[j,.]]),(sig[1:a1+b1]|sig[a1+b1+yi[j,.]]));
           gcoma = gcoma+((-1)^i)*gcoma1;
           gcomb = gcomb+((-1)^i)*gcomb1[1:b1];
           gcomc1[yi[j,.]] = ((-1)^i)*gcomb1[b1+1:rows(gcomb1)];
           gcomc = gcomc+gcomc1;
           gcommua = gcommua+((-1)^i)*gcommua1;
           gcommub = gcommub+((-1)^i)*gcommub1[1:b1];
           gcommuc1[yi[j,.]] = ((-1)^i)*gcommub1[b1+1:rows(gcommub1)];
           gcommuc = gcommuc+gcommuc1;
           gcomsiga = gcomsiga+((-1)^i)*gcomsiga1;
           gcomsigb = gcomsigb+((-1)^i)*gcomsigb1[1:b1];
           gcomsigc1[yi[j,.]] = ((-1)^i)*gcomsigb1[b1+1:rows(gcomsigb1)];
           gcomsigc = gcomsigc+gcomsigc1;
        endfor;
        gcombanew = gcombanew+gcoma;
        gcombbnew = gcombbnew+gcomb;
        gcombcnew = gcombcnew+gcomc;
        gcombmuanew = gcombmuanew+gcommua;
        gcombmubnew = gcombmubnew+gcommub;
        gcombmucnew = gcombmucnew+gcommuc;
        gcombsiganew = gcombsiganew+gcomsiga; 
        gcombsigbnew = gcombsigbnew+gcomsigb;
        gcombsigcnew = gcombsigcnew+gcomsigc;         
    endfor;
    retp(gcombanew+ga1,gcombbnew+gb1,gcombcnew,((gcombmuanew+gmua1)|(gcombmubnew+gmub1)|gcombmucnew),((gcombsiganew+gsiga1)|(gcombsigbnew+gsigb1)|gcombsigcnew));
endp;


/*
** cdorrectmvlogit.src 
**
** Purpose: Develops the integration from -inf to a for some variables, from b to inf for other variables, and from c to d for other variables;
            Combines orthant and rectangular multivariate logistic computations 
**
** Format:      { F } = cdorrectmvlogit(mu,sig,xg,x1,x2,indxone,indxcomp)
**
** Input:        mu is the (Kx1) vector of location parameters
                 sig is the (KX1) vector of scale parameters
                 xg represents (Kx1) points of lower or upper truncation for one-sided orthant integrals (whenever indxone has a one, xg must have a 
                    corresponding value; when indxone has a zero, corresponding element of xg is immaterial (put zero for example);
                    indxcomp determines whether the point is lower or upper truncation point 
                 x1 represents (Kx1) points of lower truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x1 must have a corresponding value.
                 x2 represents (Kx1) points of upper truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x2 must have a corresponding value.                    
                 indxone (Kx1) - a vector of 1s and 0s, with a 1 for a variable to be integrated one-sided (orthant)
                                 and 0 for a variable to be integrated two-sided (rectangular integration)
                                 { 1  This means first and third variables are to be intergated one-sided and second is a rectangular integration 
                                   0  if all ones, same as cdfmvnanlpluscomp
                                   1
                 indxcomp (Kx1) = { 0     This means third variable integration is a complement integral (b to infinity integration), 
                                    0     and second variable integration is truncation from above (-infinity to a); 
                                    1  }; if a zero in indxone, should have a corresponding zero in indxcomp.    

** Output:      F - 1x1   */
                 
proc (1) = cdorrectmvlogit(mu,sig,xg,x1,x2,indxone,indxcomp);
    local e2,P,newx,kk2,w,s15,indx,F,newxg,comb1,newx1,newx2,newxone,newxlow,newxup,sign,comb,ecomb,P1,j,posone,posrect;
    local xg1,xg2,indxnewcomp,indxnewnoncomp,newxnoncomp,newxcomp,com1,a2,b1,b2,b4,yi,i,com,com2;
    local mu4,muone,murect,sigone,sigrect,sig4,noncompdims,compdims,munoncomp,mucomp,sigcomp,signoncomp,posxg1,posxg2;
    e2 = rows(x1);
    if (sumc(indxone))==e2;
        if (sumc(indxcomp))==0;
           F = noncdfmvlogit(xg,mu,sig);
        elseif (sumc(indxcomp))==e2;
           F = noncdfmvlogitcomp(xg,mu,sig);
        else;
           xg1 = (selif(xg,indxcomp.==0));
           xg2 = (selif(xg,indxcomp.==1));
           posxg1 = selif(seqa(1,1,e2),1-indxcomp);
           posxg2 = selif(seqa(1,1,e2),(indxcomp)); 
           mu4 = mu[posxg1]|mu[posxg2];   sig4 = sig[posxg1]|sig[posxg2];
           F = noncdfmvlogitc(xg1,xg2,mu4,sig4);      
        endif;
    elseif (sumc(indxone))==0;
        { F } = cdrectmvlogit(mu,sig,x1,x2);
    else;
        newxone = (selif(xg,indxone));
        newxlow = selif(x1,indxone.==0);
        newxup  = selif(x2,indxone.==0);
        posone = selif(seqa(1,1,e2),indxone);
        posrect = selif(seqa(1,1,e2),indxone.==0);
        { sign,comb } = rectcombs(newxlow,newxup);     
        ecomb = rows(comb);
        if (sumc(indxcomp)) ==0;
           comb1 = zeros(ecomb,e2);
           comb1[.,posone] = ones(ecomb,1).*((newxone)');
           comb1[.,posrect] = comb;  
           F = 0;
           for j(1,ecomb,1); 
              F = F+sign[j]*noncdfmvlogit(((comb1[j,.])'),mu,sig);
           endfor;
        elseif (indxcomp == indxone);  
           b1 = sumc(indxcomp);
           F=0;
           muone=selif(mu,indxone); murect = selif(mu,indxone.==0); sigone=selif(sig,indxone); sigrect = selif(sig,indxone.==0);
           for i (1,b1,1);
              com=0;
              yi = combinate(b1,i);
              for j (1,rows(yi),1);
                 com2=0;
                 b2 = (newxone[yi[j,.]]);
                 mu4 = muone[yi[j,.]]|murect;  sig4 = sigone[yi[j,.]]|sigrect;
                 for k(1,ecomb,1);
                    b4 = ((-1)^i)*sign[k]*noncdfmvlogit((b2|((comb[k,.])')),mu4,sig4);
                    com2=com2+b4;
                 endfor;
                 com=com+com2;
              endfor;
              F = F+com;
           endfor;
           F = F+cdrectmvlogit(murect,sigrect,newxlow,newxup);
        else;
           indxnewnoncomp = indxone.==1 .and indxcomp .==0;
           indxnewcomp = indxone.==1 .and indxcomp.==1;
           newxnoncomp = selif(xg,indxnewnoncomp);   noncompdims = rows(newxnoncomp);
           newxcomp = selif(xg,indxnewcomp);   compdims = rows(newxcomp);   
           munoncomp = selif(mu,indxnewnoncomp);    signoncomp = selif(sig,indxnewnoncomp);
           mucomp = selif(mu,indxnewcomp);          sigcomp = selif(sig,indxnewcomp);
           murect = selif(mu,indxone.==0);           sigrect = selif(sig,indxone.==0);
           comb1 = ((newxnoncomp)'.*ones(ecomb,1))~comb;    mu4 = munoncomp|murect;   sig4 = signoncomp|sigrect;
           a2 = 0;
           for j(1,ecomb,1); 
              a2 = a2+sign[j]*noncdfmvlogit(((comb1[j,.])'),mu4,sig4);
           endfor;
           b1 = compdims;
           F=0;
           for i (1,b1,1);
              com=0;
              yi = combinate(b1,i);
              for j (1,rows(yi),1);
                 com2=0;
                 b2 = (newxcomp[yi[j,.]]);   mu4 = munoncomp|mucomp[yi[j,.]]|murect;    sig4 = signoncomp|sigcomp[yi[j,.]]|sigrect; 
                 for k(1,ecomb,1);
                    b4 = ((-1)^i)*sign[k]*noncdfmvlogit((newxnoncomp|b2|((comb[k,.])')),mu4,sig4);
                    com2=com2+b4;
                 endfor;
                 com=com+com2;
              endfor;
              F = F+com;
           endfor;
           F = F+a2;      
        endif;
    endif;
    if (F) < 0;
       retp(0);
    else;
       retp(F);
    endif;   
endp;


/* 
** gradcdorrectmvlogit.src 
**
** Purpose: Develops the gradients of the combination of cdorrectmvlogit 
**
** Format:      { F,gmu,gsig,gxg,gx1,gx2 } = gradcdorrectmvlogit(mu,sig,xg,x1,x2,indxone,indxcomp)
**
** Input:        F is the value of the integration
                 mu is the (Kx1) vector of location parameters
                 sig is the K vector of scale parameters,
                 xg represents (Kx1) points of lower or upper truncation for one-sided orthant integrals (whenever indxone has a one, xg must have a 
                    corresponding value; when indxone has a zero, corresponding element of xg is immaterial (put zero for example);
                    indxcomp determines whether the point is lower or upper truncation point 
                 x1 represents (Kx1) points of lower truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x1 must have a corresponding value.
                 x2 represents (Kx1) points of upper truncation for rectangular integrals (when indxone has a one, corresponding element of x1 is 
                    immaterial (put a value of zero); when indxone has a zero, x2 must have a corresponding value.                    
                 indxone (Kx1) - a vector of 1s and 0s, with a 1 for a variable to be integrated one-sided (orthant)
                                 and 0 for a variable to be integrated two-sided (rectangular integration)
                                 { 1  This means first and third variables are to be intergated one-sided and second is a rectangular integration 
                                   0  if all ones, same as noncdfmvnlogitc
                                   1
                 indxcomp (Kx1) = { 0     This means third variable integration is a complement integral (b to infinity integration), 
                                    0     and second variable integration is truncation from above (-infinity to a); 
                                    1  }; if a zero in indxone, should have a corresponding zero in indxcomp.   

**Global:        
                 
** Output:       F is 1x1 scalar
                 gmu is the (Kx1) gradient vector of F with respect to the vector of means
                 gsig is the Kx1 gradient vector of F 
                 gxg is the (Kx1) graident vector of F with respect to the vector of thresholds on one side (ignore gxg row entries if corresponding
                     indxone entry is zero)
                 gx1 and gx2 are each (Kx1) gradient vectors of F with respect to the lower and upper rectangular thresholds (ignore gx1 and gx2 row 
                     entries if corresponding indxone entry is one)

                 mu  = {  mu1   
                          mu2   
                          mu3 };

                 gmu  =  { dF/dmu1,
                         dF/dmu2,
                         dF/dmu3 };
                         
                 gsig  =  { dF/dsig1,         
                         dF/dsig2,                               
                         dF/dsig3  };                                       
                         
                 gxg   =   { dF/dxg1,
                          dF/dxg2,
                          dF/dxg3 }     
                          
                 gx1   =   { dF/dx11,
                          dF/dx12,
                          dF/dx13 };
                          
                 gx2   =   { dF/dx21,
                          dF/dx22,
                          dF/dx23 };                         */
                          
proc (6) = gradcdorrectmvlogit(mu,sig,xg,x1,x2,indxone,indxcomp);
    local e2,indx,indx1,kk1old,kk2old,indxcov,mm1,invsig,kk1,kk2,mm,gBcorcovg,gomegacorcovg,gBcorcov1,gomegacorcov1,gmu,gsig,
          gx,rho,gx1,gx2,comb1,grho,P,s15,gBcorcov2,gomegacorcov2,w,gxg,gxx,gcov2,gBcorcov,gomegacorcov,
          newx1,newx2,newxg,newxone,newxlow,newxup,rone,posone,posrect,sign,comb,indxa,indxb,ecomb,gxg1,gxx1,gxx2,gsig1,j,P1;
    local xg1,xg2,posxg1,posxg2,gxg2,gxxg1,gmu1,indxnewcomp,indxnewnoncomp,newxnoncomp,newxcomp,com1,a2,b1,b2,b4,yi,i,com,com2;
    local gcomone,gcomrect1,gcomrect2,gcomonei,gcomrect1i,gcomrect2i,gcomone11i,gcomrect11i,gcomrect21i,rb2,gcomone111i;
    local compdims,noncompdims,rectdims,posnoncomp,poscomp,grect1,grect2,gcomcompi,gcomnoncompi,gcomcomp11i,gcomcomp111i;
    local gcomnoncomp,gcomnoncomp1,grecttemp,gcomcomp,gcomnoncomp11i,gxxg2,gmu2,gsig2,F;
    local mu4,sig4,gmucomp,gsigcomp,munoncomp,mucomp,murect,signoncomp,sigcomp,sigrect,muone,sigone,gmuone,gsigone,gmu4,gsig4;    
    e2 = rows(x1);
    if (sumc(indxone))==e2;
        gx1 = zeros(e2,1); gx2 = gx1;
        if (sumc(indxcomp))==0;
           { gxg,gmu,gsig } = gradnoncdfmvlogit(xg,mu,sig);   
           F = noncdfmvlogit(xg,mu,sig);
        elseif (sumc(indxcomp))==e2;
           { gxg,gmu,gsig } = gradnoncdfmvlogitcomp(xg,mu,sig); 
           F = noncdfmvlogitcomp(xg,mu,sig);
        else;
           gxg = zeros(e2,1);   gmu=gxg;   gsig=gxg;
           xg1 = (selif(xg,indxcomp.==0));
           xg2 = (selif(xg,indxcomp.==1));
           posxg1 = selif(seqa(1,1,e2),1-indxcomp);
           posxg2 = selif(seqa(1,1,e2),(indxcomp));              
           mu4 = mu[posxg1]|mu[posxg2];   sig4 = sig[posxg1]|sig[posxg2];
           F = noncdfmvlogitc(xg1,xg2,mu4,sig4); 
           { gxg1,gxg2,gmu4,gsig4 } = gradnoncdfmvlogitc(xg1,xg2,mu4,sig4);
           gmu[posxg1]=gmu4[1:rows(posxg1)];  gmu[posxg2]=gmu4[rows(posxg1)+1:rows(gmu4)];   
           gsig[posxg1]=gsig4[1:rows(posxg1)];  gsig[posxg2]=gsig4[rows(posxg1)+1:rows(gsig4)];  
           gxg[posxg1] = gxg1;  gxg[posxg2] = gxg2; 
        endif;
    elseif (sumc(indxone))==0;
       { F,gmu,gsig,gx1,gx2 } = gradcdrectmvlogit(mu,sig,x1,x2);
       gxg = zeros(e2,1);
    else;
        newxone = (selif(xg,indxone));
        newxlow = selif(x1,indxone.==0);
        newxup  = selif(x2,indxone.==0);
        rectdims = rows(newxlow);
        posone = selif(seqa(1,1,e2),indxone);
        posrect = selif(seqa(1,1,e2),indxone.==0);
        { sign,comb,indxa,indxb } = rectcombsforgrad(newxlow,newxup);
        ecomb = rows(comb);
        gxg = zeros(e2,1);
        gx1 = zeros(e2,1);
        gx2 = zeros(e2,1);
        gmu = zeros(e2,1);
        gsig = zeros(e2,1);
        if (sumc(indxcomp)) ==0;
           comb1 = zeros(ecomb,e2); 
           comb1[.,posone] = ones(ecomb,1).*((newxone)');   comb1[.,posrect] = comb;   
           F = 0;
           for j(1,ecomb,1); 
              F = F+sign[j]*noncdfmvlogit(((comb1[j,.])'),mu,sig);
              { gxxg1,gmu1,gsig1 } = gradnoncdfmvlogit(((comb1[j,.])'),mu,sig);   
              gxxg1= sign[j]*gxxg1;  gmu1 = sign[j]*gmu1;   gsig1 = sign[j]*gsig1;
              gxg[posone] = gxg[posone]+gxxg1[posone];
              gx1[posrect] = gx1[posrect]+gxxg1[posrect].*((indxa[j,.])'); 
              gx2[posrect] = gx2[posrect]+gxxg1[posrect].*((indxb[j,.])');    
              gmu = gmu+gmu1;
              gsig = gsig+gsig1;
           endfor;
        elseif (indxcomp == indxone);
           b1 = sumc(indxcomp);
           F=0;
           gcomone = zeros(b1,1); 
           gcomrect1 = zeros(rectdims,1);
           gcomrect2 = gcomrect1;
           muone = selif(mu,indxone);
           murect = selif(mu,indxone.==0);
           sigone = selif(sig,indxone);
           sigrect = selif(sig,indxone.==0);    
           for i (1,b1,1);
              gcomonei = zeros(b1,1); 
              gcomrect1i = zeros(rectdims,1);
              gcomrect2i = gcomrect1i;
              com=0;
              yi = combinate(b1,i);
              for j (1,rows(yi),1);
                 gcomone11i = zeros(b1,1);   gcomrect11i = zeros(rectdims,1);  gcomrect21i = gcomrect11i;
                 com2=0;
                 b2 = (newxone[yi[j,.]]);
                 rb2 = rows(b2); mu4 = muone[yi[j,.]]|murect;  sig4 = sigone[yi[j,.]]|sigrect;
                 for k(1,ecomb,1);
                    gmuone = zeros(b1,1);   gsigone = zeros(b1,1);
                    gcomone111i = zeros(b1,1);
                    b4 = ((-1)^i)*sign[k]*noncdfmvlogit((b2|((comb[k,.])')),mu4,sig4);
                    { gxxg1,gmu1,gsig1 } = gradnoncdfmvlogit((b2|((comb[k,.])')),mu4,sig4); 
                    gxxg1 = ((-1)^i)*sign[k]*gxxg1;   gmu1 = ((-1)^i)*sign[k]*gmu1;    gsig1 = ((-1)^i)*sign[k]*gsig1;
                    gmuone[yi[j,.]] = gmu1[1:rb2]; gsigone[yi[j,.]] = gsig1[1:rb2];
                    gmu[posone] = gmu[posone]+gmuone;    gsig[posone] = gsig[posone]+gsigone;
                    gmu[posrect] = gmu[posrect]+gmu1[rb2+1:rows(gmu1)];   
                    gsig[posrect] = gsig[posrect]+gsig1[rb2+1:rows(gsig1)];
                    gcomone111i[yi[j,.]] = gxxg1[1:rb2];
                    gcomone11i = gcomone11i+gcomone111i;
                    grecttemp = gxxg1[rb2+1:rows(gxxg1)];
                    gcomrect11i = gcomrect11i+grecttemp.*((indxa[k,.])'); 
                    gcomrect21i = gcomrect21i+grecttemp.*((indxb[k,.])');
                    com2=com2+b4;
                 endfor;
                 gcomonei = gcomonei+gcomone11i;
                 gcomrect1i = gcomrect1i+gcomrect11i; 
                 gcomrect2i = gcomrect2i+gcomrect21i;                 
                 com=com+com2;
              endfor;
              gcomone = gcomone+gcomonei;
              gcomrect1 = gcomrect1+gcomrect1i;
              gcomrect2 = gcomrect2+gcomrect2i;
              F = F+com;
           endfor;
           gxg[posone] = gcomone;
           F = F+cdrectmvlogit(murect,sigrect,newxlow,newxup);
           { P,gmu2,gsig2,grect1,grect2 } = gradcdrectmvlogit(murect,sigrect,newxlow,newxup);
           gcomrect1 = gcomrect1+grect1;
           gcomrect2 = gcomrect2+grect2;
           gmu[posrect] = gmu[posrect]+gmu2;
           gsig[posrect] = gsig[posrect]+gsig2;
           gx1[posrect] = gcomrect1;
           gx2[posrect] = gcomrect2;                
        else;
           indxnewnoncomp = indxone.==1 .and indxcomp .==0;
           indxnewcomp = indxone.==1 .and indxcomp.==1;
           newxnoncomp = selif(xg,indxnewnoncomp);
           newxcomp = selif(xg,indxnewcomp);
           munoncomp = selif(mu,indxnewnoncomp);
           mucomp = selif(mu,indxnewcomp);
           murect = selif(mu,indxone.==0);
           signoncomp = selif(sig,indxnewnoncomp);
           sigcomp = selif(sig,indxnewcomp);
           sigrect = selif(sig,indxone.==0);            
           compdims = rows(newxcomp);
           noncompdims = rows(newxnoncomp);
           posnoncomp = selif(seqa(1,1,e2),indxnewnoncomp);
           poscomp = selif(seqa(1,1,e2),indxnewcomp);
           posrect = selif(seqa(1,1,e2),indxone.==0);
           comb1 = ((newxnoncomp)'.*ones(ecomb,1))~comb; mu4 = munoncomp|murect;  sig4 = signoncomp|sigrect;
           a2 = 0;
           for j(1,ecomb,1); 
              a2 = a2+sign[j]*noncdfmvlogit(((comb1[j,.])'),mu4,sig4);
              { gxxg2,gmu2,gsig2 } = gradnoncdfmvlogit(((comb1[j,.])'),mu4,sig4);
              gxxg2 = sign[j]*gxxg2;  gmu2 = sign[j]*gmu2; gsig2 = sign[j]*gsig2;  
              gmu[posnoncomp] = gmu[posnoncomp]+gmu2[1:noncompdims];  gsig[posnoncomp] = gsig[posnoncomp]+gsig2[1:noncompdims];
              gmu[posrect] = gmu[posrect]+gmu2[noncompdims+1:rows(gmu2)];  gsig[posrect] = gsig[posrect]+gsig2[noncompdims+1:rows(gsig2)];              
              gxg[posnoncomp] = gxg[posnoncomp]+gxxg2[1:noncompdims];
              gx1[posrect] = gx1[posrect]+gxxg2[noncompdims+1:noncompdims+rectdims].*((indxa[j,.])'); 
              gx2[posrect] = gx2[posrect]+gxxg2[noncompdims+1:noncompdims+rectdims].*((indxb[j,.])');
           endfor;
           b1 = compdims;
           F=0;
           gcomnoncomp = zeros(noncompdims,1);
           gcomcomp = zeros(b1,1); 
           gcomrect1 = zeros(rectdims,1);
           gcomrect2 = gcomrect1;
           for i (1,b1,1);
              gcomnoncompi = zeros(noncompdims,1);
              gcomcompi = zeros(b1,1); 
              gcomrect1i = zeros(rectdims,1);
              gcomrect2i = gcomrect1i;
              com=0;
              yi = combinate(b1,i);
              for j (1,rows(yi),1);
                 gcomnoncomp11i = zeros(noncompdims,1); gcomcomp11i = zeros(b1,1);   gcomrect11i = zeros(rectdims,1);  gcomrect21i = gcomrect11i;
                 com2=0;
                 b2 = (newxcomp[yi[j,.]]);   mu4 = munoncomp|mucomp[yi[j,.]]|murect;  sig4 = signoncomp|sigcomp[yi[j,.]]|sigrect;
                 rb2 = rows(b2);
                 for k(1,ecomb,1);
                    gcomcomp111i = zeros(b1,1);     gmucomp = zeros(b1,1);   gsigcomp = zeros(b1,1);
                    b4 = ((-1)^i)*sign[k]*noncdfmvlogit((newxnoncomp|b2|((comb[k,.])')),mu4,sig4);
                    { gxxg1,gmu1,gsig1 } = gradnoncdfmvlogit((newxnoncomp|b2|((comb[k,.])')),mu4,sig4); 
                    gxxg1=((-1)^i)*sign[k]*gxxg1; gmu1=((-1)^i)*sign[k]*gmu1; gsig1=((-1)^i)*sign[k]*gsig1;
                    gmu[posnoncomp] = gmu[posnoncomp]+gmu1[1:noncompdims];
                    gsig[posnoncomp] = gsig[posnoncomp]+gsig1[1:noncompdims];
                    gmucomp[yi[j,.]] = gmu1[noncompdims+1:noncompdims+rb2]; gsigcomp[yi[j,.]] = gsig1[noncompdims+1:noncompdims+rb2];
                    gmu[poscomp] = gmu[poscomp]+gmucomp;  gsig[poscomp] = gsig[poscomp]+gsigcomp;
                    gmu[posrect] = gmu[posrect]+gmu1[noncompdims+rb2+1:rows(gmu1)];   
                    gsig[posrect] = gsig[posrect]+gsig1[noncompdims+rb2+1:rows(gsig1)];
                    gcomnoncomp11i = gcomnoncomp11i+gxxg1[1:noncompdims];
                    gcomcomp111i[yi[j,.]] = gxxg1[noncompdims+1:noncompdims+rb2];
                    gcomcomp11i = gcomcomp11i+gcomcomp111i;
                    grecttemp = gxxg1[noncompdims+rb2+1:rows(gxxg1)];
                    gcomrect11i = gcomrect11i+grecttemp.*((indxa[k,.])'); 
                    gcomrect21i = gcomrect21i+grecttemp.*((indxb[k,.])');
                    com2=com2+b4;
                 endfor;
                 gcomnoncompi = gcomnoncompi+gcomnoncomp11i;
                 gcomcompi = gcomcompi+gcomcomp11i;
                 gcomrect1i = gcomrect1i+gcomrect11i; 
                 gcomrect2i = gcomrect2i+gcomrect21i;                 
                 com=com+com2;
              endfor;
              gcomnoncomp = gcomnoncomp+gcomnoncompi;
              gcomcomp = gcomcomp+gcomcompi;
              gcomrect1 = gcomrect1+gcomrect1i;
              gcomrect2 = gcomrect2+gcomrect2i;
              F = F+com;
           endfor;
           gxg[posnoncomp] = gxg[posnoncomp]+gcomnoncomp;
           gxg[poscomp] = gcomcomp;
           gx1[posrect] = gx1[posrect]+gcomrect1;
           gx2[posrect] = gx2[posrect]+gcomrect2;             
           F = F+a2;      
        endif;
    endif;
    if (F) < 0; 
       F=0;
    endif;   
    retp(F,gmu,gsig,gxg,gx1,gx2);
endp;
      
        
/* simmdcev(a,m,n,sig) : Drawing from error terms for true MDCEV model with a being a (K-1)x1 vector of v tilde sub k,1 values, one each
                   for each inside good (values for consumed inside goods appearing first), m being the number of consumed inside goods (value of m 
                   should be between 1 and K-1, inclusive of these boundary values), and n is the number of error term draws needed 

 Input:       a - (K-1) x 1 vector of vtilde sub k,1 values
              m = (1x1) scalar
              n - number of successful draws needed
              sig - scale parameter for extreme value draws .

** Output:      w -  n x (K+m) matrix of error term realizations; the first (K-1) columns are error realizations for the discrete components of all inside 
                     goods (the first m columns corresponding to the discrete components of the consumed goods), the next m columns are error realizations 
                     for the continuous components of the consumed goods, and the last column being the error realization for the outside good 
                s - seed coming out from call  */

proc (2) = simmdcev(a,m,n,sig,seed);
    local arows,seed20,i,e2,rfinal,err1,seednext,r,r1,r1min,r1max,e1,rout1,rinside,routside,riter;
    arows = rows(a);
    seed20=seed;
    i=1;
    e2=0;
    rfinal = {};
    do until i>n;
       { err1,seednext} = (rndu(4*n,arows+1,seed20));
       r = (-ln(-ln(err1)))*sig;
       r1 = r[.,1:arows]-a';
       r1min = minc(((r1[.,1:m])'));

       if m < arows;
          r1max = maxc(((r1[.,m+1:arows])'));
          e1 = r1min .> r1max;
          if sumc(e1)>=1;
             r1min = selif(r1min,e1); r1max = selif(r1max,e1);
             rinside = selif(r[.,1:arows],e1); rout1 = selif(err1[.,arows+1],e1); 
             routside = ((1-rout1).*(exp(-exp(-r1max/sig))))+(rout1.*(exp(-exp(-r1min/sig))));
             routside = (-ln(-ln(routside)))*sig;
             riter=rinside~routside;
             rfinal = rfinal|riter;
          endif;
       else;
          rinside = r[.,1:arows];
          rout1 = err1[.,arows+1];
          routside = rout1.*exp(-exp(-r1min/sig));
          routside = (-ln(-ln(routside)))*sig;
          e1 = ones(n,1);
          riter=rinside~routside;
          rfinal = rfinal|riter;
       endif;
       e2=(sumc(e1))+e2;
       i = 1+e2;
       seed20=seednext;
    endo;

    retp(seed20,rfinal[1:n,.]);
endp;
        


/* simtradmdcev(a,m,n,sig,seed) : Drawing from error terms for traditional MDCEV model with a being a (K-1)x1 vector of v tilde sub k,1 values, one each
                   for each inside good (values for consumed inside goods appearing first), m being the number of consumed inside goods (value of m 
                   should be between 1 and K-1, inclusive of these boundary values), and n is the number of error term draws needed 

 Input:       a - (K-1) x 1 vector of vtilde sub k,1 values
              m = (1x1) scalar
              n - number of successful draws needed
              sig - scale parameter for extreme value draws 
              psi - (Kx1) vector of deterministic part of psi baseline utility 
              gamma - (K-1)x1 vector of gamma sub k values for inside goods
              price - (K-1)x1 vector of p sub k values for inside goods
              seed - initial seed

** Output:      w -  n x K matrix of error term realizations; the first (K-1) columns are error realizations for the discrete components of all inside 
                     goods (the first m columns corresponding to the discrete components of the consumed goods), and the last column being the error realization for the outside good 
                s - seed coming out from call  */

proc (2) = simtradmdcev(a,m,n,sig,psi,gamma,price,seed);
    local arows,seed20,i,e2,rfinal,err1,seednext,r,r1,r1min,r1max,e1,rout1,rinside,routside,riter;
    arows = rows(a);
    seed20=seed;
    i=1;
    e2=0;
    rfinal = {};
    do until i>n;
       { err1,seednext} = (rndu(4*n,arows+1,seed20));
       r = (-ln(-ln(err1)))*sig;
       r1 = r[.,1:arows]-a';
       r1min = minc(((r1[.,1:m])'));

       if m < arows;
          r1max = maxc(((r1[.,m+1:arows])'));
          e1 = r1min .> r1max;
          if sumc(e1)>=1;
             r1min = selif(r1min,e1); r1max = selif(r1max,e1);
             rinside = selif(r[.,1:arows],e1); rout1 = selif(err1[.,arows+1],e1); 
             routside = ((1-rout1).*(exp(-exp(-r1max/sig))))+(rout1.*(exp(-exp(-r1min/sig))));
             routside = (-ln(-ln(routside)))*sig;
             riter=rinside~routside;
             rfinal = rfinal|riter;
          endif;
       else;
          rinside = r[.,1:arows];
          rout1 = err1[.,arows+1];
          routside = rout1.*exp(-exp(-r1min/sig));
          routside = (-ln(-ln(routside)))*sig;
          e1 = ones(n,1);
          riter=rinside~routside;
          rfinal = rfinal|riter;
       endif;
       e2=(sumc(e1))+e2;
       i = 1+e2;
       seed20=seednext;
    endo;
    retp(seed20,rfinal[1:n,.]);
endp;
        

/***************************************************************************************************************************************************
                         Survival distribution for minimum Gumbel variable, its complement, and gradients
***************************************************************************************************************************************************/


/* sdfmmvlogit(a,c) : standard multivariate minlogistic survival distribution function, where X is multivariate minlogistic random variable   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute survival distribution at
**
** Output:      w - 1 x 1 vector  Pr(X > c). */


proc (1) = sdfmmvlogit(a,c);
    local f; 
    f = a*(exp(c));
    retp((prodc((1+f)))^(-1));
endp;


/* { ga,gc } = gradsdfmmvlogit(a,c) :   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae to compute survival distribution at


** Output:    ga - QK x 1 vector    gc - K x 1 vector

 a = { a11 a12 a13,              c = { w1                ga = { df/da11                  gc = { df/dw1
       a21 a22 a23 };                  w2                       df/da12                         df/dw2
                                       w3 };                    df/da13                         df/dw3 };
                                                                df/da21
                                                                df/da22
                                                                df/da23 }   */

proc (2) = gradsdfmmvlogit(a,c);
    local f,h,erow,ecol,c1,f1,f2,gf2,ga1,gc1,ga,gc; 
    erow = rows(a);  ecol = cols(a); 
    c1 = exp(c);   /* K x 1 vector */
    f = a*c1;    /* Q x 1 vector  */
    f1 = (1+f);  
    f2 = 1/(prodc(f1));
    gf2 = -f2./f1;   /* Q x 1 vector */
    { ga1,gc1 } = gradprodAB(a,c1);      /* ga1 is QKx1 vector and gc1 is KxQ vector */
    gc = c1.*gc1;  gc = gc'.*gf2;   gc=sumc(gc);   /* K x 1 vector */
    ga = ga1.*(gf2');  ga = sumc((ga'));
    retp(ga,gc);
endp;


/* nonsdfmmvlogit(a,c,mu,sig) : non-standard multivariate minlogistic survival distribution function, where X is multivariate minlogistic random variable   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute survival distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
**
** Output:      w - 1 x 1 vector  Pr(X > c). */


proc (1) = nonsdfmmvlogit(a,c,mu,sig);
    local f,newc; 
    newc = (c-mu)./sig;
    f = sdfmmvlogit(a,newc);
    retp(f);
endp;


/* { ga,gc,gmu,gsig } = gradnonsdfmmvlogit(a,c,mu,sig) :   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae to compute survival distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters

** Output:    ga - QK x 1 vector    gc - K x 1 vector
              gmu - K x 1 vector
              gsig - K x 1 vector  */

proc (4) = gradnonsdfmmvlogit(a,c,mu,sig);
    local newc,ga,gnewc,gnew2,gmu,gsig; 
    newc = (c-mu)./sig;
    { ga,gnewc } = gradsdfmmvlogit(a,newc);
    gnew2 = gnewc./sig;
    gmu = gnewc.*(-1/sig);
    gsig = (gnewc.*(-newc))./sig;
    retp(ga,gnew2,gmu,gsig);    
endp;


/* cdfmmvlogit(a,c) : standard multivariate minlogistic cumulative distribution function, where X is multivariate minlogistic random variable 

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute cumulative distribution at

** Output:      w - 1 x 1 vector  Pr(X < c) */

proc (1) = cdfmmvlogit(a,c);
    local c1,c2,c4,i,yi,com,j,a2,com1; 
    c1 = rows(c);
    com1=0;
    for i (1,c1,1);
        com=0;
        yi = combinate(c1,i);
        for j (1,rows(yi),1);
            c2 = c[yi[j,.]];
            a2 = a[.,yi[j,.]];
            c4 = ((-1)^i).*sdfmmvlogit(a2,c2);
            com = com+c4;
        endfor;            
        com1 = com+com1;
    endfor;
    /* because of digitization issues, sometimes (a2+com1) returns a value of zero minus (that is, a value very close to zero but negative);
       in this case, simply return the value of zero */
    if (1+com1) < 0;
       retp(0);
    else;
       retp(1+com1);
    endif;        
endp;   

/*
{ ga,gc } = gradcdfmmvlogit(a,c) :   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae to compute cumulative distribution at


** Output:    ga - QK x 1 vector    gc - K x 1 vector  */
 

proc (2) = gradcdfmmvlogit(a,c);
    local c1,c2,i,yi,com,j,com1,erow,ecol,gcombnew,ganew,gcomb,gaa,gcomb1,ga1,a2,ga,gcom; 
    c1 = rows(c);   erow = rows(a);  ecol = cols(a); 
    gcombnew = zeros(c1,1); 
    ganew = zeros(erow,ecol);
    for i (1,c1,1);
        gcomb = zeros(c1,1);
        gaa = zeros(erow,ecol);
        yi = combinate(c1,i);
        for j (1,rows(yi),1);
            gcomb1 = zeros(c1,1);  ga1 = zeros(erow,ecol);
            c2 = c[yi[j,.]];   a2 = a[.,yi[j,.]];
            { ga, gcom } = gradsdfmmvlogit(a2,c2);  
            ga=reshape(ga,erow,i);
            gcomb1[yi[j,.]]=((-1)^i).*gcom;  
            ga1[.,yi[j,.]]=((-1)^i).*ga;
            gcomb = gcomb+gcomb1;   gaa = gaa+ga1;
        endfor;          
        gcombnew = gcombnew+gcomb;   ganew = ganew+gaa;
    endfor;
    retp((vecr(ganew)),gcombnew);
endp;   


/* noncdfmmvlogit(a,c,mu,sig) : non-standard multivariate minlogistic cumulative distribution function, where X is multivariate minlogistic random variable   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute cumulative distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
**
** Output:      w - 1 x 1 vector  Pr(X < c). */


proc (1) = noncdfmmvlogit(a,c,mu,sig);
    local c1,cindx,c2,a10,mu10,c10,sig10,i,yi,j,com4;
    c1=rows(c);
    c2 = 1;
    for i (1,c1,1);
        yi = combinate(c1,i);
        for j (1,rows(yi),1);
            cindx = yi[j,.];    
            a10 = a[.,cindx];    c10 = c[cindx];        mu10 = mu[cindx];   sig10 = sig[cindx]; 
            com4 = ((-1)^i).*nonsdfmmvlogit(a10,c10,mu10,sig10);
            c2 = c2+com4;
        endfor;            
    endfor;
    retp(c2);
endp;


/* { ga,gc,gmu,gsig } = gradnoncdfmmvlogit(a,c,mu,sig) :   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae to compute cumulative distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters

** Output:    ga - QK x 1 vector    gc - K x 1 vector
              gmu - K x 1 vector
              gsig - K x 1 vector  */

proc (4) = gradnoncdfmmvlogit(a,c,mu,sig);
    local e1,indxnoncomp,cindx,bindx,b2indx,b1,c5,c2,a5,mu5,sig5,a10,c10,mu10,sig10,i,yi,j,finindx,com4;
    local gc,ga,gmu,ga1,ga2,c1,gsig,gc2,gmu2,gsig2,erow,ecol;
    c1=rows(c);  erow = rows(a);   ecol=cols(a);
    gc = zeros(c1,1);    ga = zeros(erow,ecol);    gmu = gc;   gsig = gc;    
    for i (1,c1,1);
        yi = combinate(c1,i);
        for j (1,rows(yi),1);
            cindx = yi[j,.];    
            a10 = a[.,cindx];    c10 = c[cindx];        mu10 = mu[cindx];   sig10 = sig[cindx]; 
            { ga2,gc2,gmu2,gsig2 } = gradnonsdfmmvlogit(a10,c10,mu10,sig10);  ga2 =reshape(ga2,erow,i); 
            ga[.,cindx] = ga[.,cindx]+((-1)^i)*ga2;    gc[cindx]=gc[cindx]+((-1)^i)*gc2;
            gmu[cindx] = gmu[cindx]+((-1)^i)*gmu2;    gsig[cindx]=gsig[cindx]+((-1)^i)*gsig2;
        endfor;
    endfor;
    retp(vecr(ga),gc,gmu,gsig);
endp;


/* cdfmmvlogitc(a,c,indxcomp) : combination of cdfmmvlogit and complement of cdfmmvlogit (i.e., sdfmmvlogit)  

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae 
              indxcomp - K x 1 vector of indicators; indxcomp =1 in positions of abscissae that are from value to infinity

** Output:    w - 1 x 1 vector  */

proc (1) = cdfmmvlogitc(a,c,indxcomp);
    local indxnoncomp,e1,cindx,bindx,b2indx,b5,c5,a5,b1,c2,i,yi,j,b2,finindx,a10,c10,b4,com4; 
    e1=rows(c);
    indxnoncomp = indxcomp.==0;
    cindx = selif(seqa(1,1,e1),indxcomp);    bindx = selif(seqa(1,1,e1),indxnoncomp); 
    b1 = sumc(indxnoncomp);
    c5 = selif(c,indxcomp);      a5 = (selif((a'),indxcomp))';
    c2 = sdfmmvlogit(a5,c5);
    for i (1,b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2indx = bindx[yi[j,.]];    finindx = cindx|b2indx; 
            a10 = a[.,finindx];    c10 = c[finindx];
            com4 = ((-1)^i).*sdfmmvlogit(a10,c10);
            c2 = c2+com4;
        endfor;            
    endfor;
    /* because of digitization issues, sometimes (c2) returns a value of zero minus (that is, a value very close to zero but negative);
       in this case, simply return the value of zero */
    if (c2) < 0;
       retp(0);
    else;
       retp(c2);
    endif;        
endp;   


/* { ga,gc } = gradcdfmmvlogitc(a,c,indxcomp) :   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae 
              indxcomp - K x 1 vector of indicators; indxcomp =1 in positions of abscissae that are from value to infinity

** Output:    ga - QK x 1 vector 
              gc - K x 1 vector */


proc (2) = gradcdfmmvlogitc(a,c,indxcomp);
    local indxnoncomp,e1,gc,a5,ga,gc1,ga1,gc2,ga2,erow,ecol,cindx,bindx,b2indx,b5,c5,b1,c2,i,yi,j,b2,finindx,a10,c10,b4,com4; 
    e1=rows(c); erow=rows(a);  ecol=cols(a);
    indxnoncomp = indxcomp.==0;
    cindx = selif(seqa(1,1,e1),indxcomp);    bindx = selif(seqa(1,1,e1),indxnoncomp);
    b1 = sumc(indxnoncomp);
    c5 = selif(c,indxcomp);   a5 = (selif((a'),indxcomp))';
    gc = zeros(e1,1);    ga = zeros(erow,ecol);  
    { ga1,gc1 } = gradsdfmmvlogit(a5,c5);   ga1 = reshape(ga1,erow,rows(cindx));   
    ga[.,cindx]=ga1;   gc[cindx]=gc1;
    for i (1,b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2indx = bindx[yi[j,.]];    finindx = cindx|b2indx; 
            a10 = a[.,finindx];    c10 = c[finindx];
            { ga2,gc2 } = gradsdfmmvlogit(a10,c10);  ga2 = ((-1)^i).*ga2;   gc2 =((-1)^i).*gc2;   ga2=reshape(ga2,erow,rows(finindx)); 
            ga[.,finindx] = ga[.,finindx]+ga2;    gc[finindx]=gc[finindx]+gc2;
        endfor;            
    endfor;
    retp(vecr(ga),gc);
endp;   


/* noncdfmmvlogitc(a,c,mu,sig,indxcomp) : non-standard multivariate minlogistic cdf plus its complement function, where X is multivariate minlogistic random variable   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
       indxcomp - K x 1 vector of indicators; indxcomp =1 in positions of abscissae that are from value to infinity
**
** Output:      w - 1 x 1 vector  */


proc (1) = noncdfmmvlogitc(a,c,mu,sig,indxcomp);
    local e1,indxnoncomp,cindx,bindx,b2indx,b1,c5,c2,a5,mu5,sig5,a10,c10,mu10,sig10,i,yi,j,finindx,com4;
    e1=rows(c);
    indxnoncomp = indxcomp.==0;
    if sumc(indxnoncomp)==e1;
        c2 = noncdfmmvlogit(a,c,mu,sig);
    else;
        cindx = selif(seqa(1,1,e1),indxcomp);    bindx = selif(seqa(1,1,e1),indxnoncomp); 
        b1 = sumc(indxnoncomp);
        c5 = selif(c,indxcomp);      a5 = (selif((a'),indxcomp))';    mu5 = selif(mu,indxcomp);   sig5 = selif(sig,indxcomp);
        c2 = nonsdfmmvlogit(a5,c5,mu5,sig5);
        for i (1,b1,1);
           yi = combinate(b1,i);
           for j (1,rows(yi),1);
               b2indx = bindx[yi[j,.]];    finindx = cindx|b2indx; 
               a10 = a[.,finindx];    c10 = c[finindx];        mu10 = mu[finindx];   sig10 = sig[finindx]; 
               com4 = ((-1)^i).*nonsdfmmvlogit(a10,c10,mu10,sig10);
               c2 = c2+com4;
           endfor;            
        endfor;
    endif;
    retp(c2);
endp;


/* { ga,gc,gmu,gsig } = gradnoncdfmmvlogitc(a,c,mu,sig,indxcomp) :   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae to compute distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
       indxcomp - K x 1 vector of indicators; indxcomp =1 in positions of abscissae that are from value to infinity

** Output:    ga - QK x 1 vector    gc - K x 1 vector
              gmu - K x 1 vector
              gsig - K x 1 vector  */

proc (4) = gradnoncdfmmvlogitc(a,c,mu,sig,indxcomp);
   local e1,indxnoncomp,cindx,bindx,b2indx,b1,c5,c2,a5,mu5,sig5,a10,c10,mu10,sig10,i,yi,j,finindx,com4;
   local gc,ga,gmu,ga1,ga2,gsig,gc1,gmu1,gsig1,gc2,erow,ecol,gmu2,gsig2;
    e1=rows(c);  erow = rows(a);  ecol=cols(a); 
    indxnoncomp = indxcomp.==0;
    if sumc(indxnoncomp)==e1;
        { ga,gc,gmu,gsig } = gradnoncdfmmvlogit(a,c,mu,sig);
        retp(vecr(ga),gc,gmu,gsig);
    else;
        cindx = selif(seqa(1,1,e1),indxcomp);    bindx = selif(seqa(1,1,e1),indxnoncomp); 
        gc = zeros(e1,1);    ga = zeros(erow,ecol);    gmu = gc;   gsig = gc;        
        b1 = sumc(indxnoncomp);
        c5 = selif(c,indxcomp);      a5 = (selif((a'),indxcomp))';    mu5 = selif(mu,indxcomp);   sig5 = selif(sig,indxcomp);
        { ga1,gc1,gmu1,gsig1 } = gradnonsdfmmvlogit(a5,c5,mu5,sig5); ga1 = reshape(ga1,erow,rows(cindx)); 
        ga[.,cindx]=ga1;   gc[cindx]=gc1;    gmu[cindx]=gmu1;   gsig[cindx]=gsig1;
        for i (1,b1,1);
           yi = combinate(b1,i);
           for j (1,rows(yi),1);
              b2indx = bindx[yi[j,.]];    finindx = cindx|b2indx; 
              a10 = a[.,finindx];    c10 = c[finindx];        mu10 = mu[finindx];   sig10 = sig[finindx]; 
              { ga2,gc2,gmu2,gsig2 } = gradnonsdfmmvlogit(a10,c10,mu10,sig10);  ga2 =reshape(ga2,erow,rows(finindx)); 
              ga[.,finindx] = ga[.,finindx]+((-1)^i)*ga2;    gc[finindx]=gc[finindx]+((-1)^i)*gc2;
              gmu[finindx] = gmu[finindx]+((-1)^i)*gmu2;    gsig[finindx]=gsig[finindx]+((-1)^i)*gsig2;
           endfor; 
        endfor;
        retp(vecr(ga),gc,gmu,gsig);
    endif;
endp;


/* pdfmmvlogit(a,c) : standard multivariate minlogistic density function, where X is multivariate minlogistic random variable 

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute density function at

** Output:      w - 1 x 1 vector  Pr(X = c) */

proc (1) = pdfmmvlogit(a,c);
    local e1,e10,expsumc,b,f,c1,bindx,f1,f1prod,c2,cfact,bprod,d,d1; 
    e1 = rows(c);
    expsumc = exp(sumc(c));
    { B,F,C1,Bindx } = newcombs(a,e1);
    f = a*(exp(c)); 
    f1 = ((1+(f')))^(1+c1);   f1prod = prodc((f1'));
    c2 = c1!; cfact = prodc((c2'));  bprod = prodc((b'));
    d = (cfact.*bprod)./f1prod; d1 = sumc(d);
    e10 = expsumc*d1;
/*    if isden(e10);
       retp(0);
    else;
       retp(e10);     
    endif;   */
    retp(e10);
endp;   

/*
{ ga,gc } = gradpdfmmvlogit(a,c) :   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae to compute survival distribution at


** Output:    ga - QK x 1 vector    gc - K x 1 vector  */
 

proc (2) = gradpdfmmvlogit(a,c);
    local e1,erow,ecol,expsumc,b,c1,bindx,f,f5,f1,c5,f1prod,c2,cfact,gc1,bprod,d,d1,d5,ga1,gc5,gf1prod,gadenom,ganumer,gc,gdenom,ga,i,gaanumer,gatemp; 
    e1 = rows(c);   erow = rows(a);    ecol = cols(a);
    expsumc = exp(sumc(c));    gc1 = expsumc.*ones(e1,1);   /* gc1 is Kx1  */
    { B,F,C1,Bindx } = newcombs(a,e1);  c5=exp(c);    /* B - (Q^K)*K matrix ;  F - (Q^K)*K matrix;   C1 - (Q^K)*Q matrix  */
    f = a*c5;      /* f is Q x 1 vector */
    f5 = 1+f;    /* f5 is Q*1 vector  */
    f1 = ((f5'))^(1+c1);   f1prod = prodc((f1'));   /* f1 is (Q^K) x Q matrix; f1prod is (Q^K)x1 vector */
    c2 = c1!; cfact = prodc((c2'));  bprod = prodc((b'));   /* cfact is (Q^K)x1 vector; bprod is (Q^K)x1 vector */
    d5 = cfact.*bprod;       /* d5 is Q^K x 1 vector */
    d = d5./f1prod;  d1 = sumc(d);   /* d is (Q^K)x1 vector and d1 is 1 x 1 scalar */
    { ga1,gc5 } = gradprodAB(a,c5);      /* ga1 is QKxQ vector and gc5 is KxQ vector */
    gf1prod = f1prod.*(1+c1)./(f5');     gf1prod=gf1prod';   /* gf1prod is Q x (Q^K)  */
    gadenom = ga1*gf1prod;  /* QKx(Q^K) matrix */ 
    ganumer = d5./(b);    /* ganumer is Q^K x K matrix */   /* This is gradients w.r.t B */
    gc = (gc5*gf1prod).*c5;     /* K x Q^K matrix */ 
    gdenom = (-d)./f1prod;   /* (Q^K x 1 vector)  */
    gc = (gc*gdenom);    /* K x 1 vector */
    gc = gc1*d1+gc*expsumc;     /* K x 1 vector */
    ga = zeros(erow*ecol,1);
    for i(1,rows(B),1);
        gaanumer=zeros(erow*ecol,1);    gaanumer=gaanumer';    /* 1 x QK  */
        gaanumer[Bindx[i,.]] = ganumer[i,.];
        gatemp=((f1prod[i].*((gaanumer)')-d5[i].*gadenom[.,i]))./((f1prod[i])^2);      /* QK x 1 */
        ga = ga+gatemp;
    endfor;
    ga = ga*expsumc;
    retp(ga,gc);
endp;     
 

/* nonpdfmmvlogit(a,c,mu,sig) : non-standard multivariate minlogistic density function, where X is multivariate minlogistic random variable   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute survival distribution at (or can be 1 x 1 if the abscissae are all the same)
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
** Output:      w - 1 x 1 vector  Pr(X = c). */


proc (1) = nonpdfmmvlogit(a,c,mu,sig);
    local f,newc; 
    newc = (c-mu)./sig;
    f = pdfmmvlogit(a,newc);
    retp(((1/prodc(sig))).*f);
endp;

/* gradnonpdfmmvlogit(a,c,mu,sig)  : Gradient of non-standard multivariate lminogistic density function  

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute survival distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
**
** Output:    ga - QK x 1 vector    gc - K x 1 vector
              gmu - K x 1 vector
              gsig - K x 1 vector  */


proc(4) = gradnonpdfmmvlogit(a,c,mu,sig);
    local aa,newc,ga,aa1,prsig,aa2,aamu,aasig1,aasig2,aasig;
    newc = (c-mu)./sig;
    { ga,aa1 } = gradpdfmmvlogit(a,newc);  
    prsig = ((1/prodc(sig)))';
    aa2 = prsig.*(aa1./sig);
    aamu = -aa2;
    aasig1 = prsig.*((aa1.*(-newc))./sig);
    aasig2 = (-prsig./sig).*((pdfmmvlogit(a,newc))');
    aasig = aasig1+aasig2;
    retp(prsig*ga,aa2,aamu,aasig);
endp;


/* sdfpdfmmvlogit(a,c,indxeq) : standard multivariate minlogistic partial density/survival function, where X is multivariate minlogistic random variable 

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute density/survival function at
         indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)
** Output:      w - 1 x 1 vector   */

proc (1) = sdfpdfmmvlogit(a,c,indxeq);
    local e1,ce,eequal,expsumc,b,f,c1,bindx,f1,f1prod,c2,cfact,bprod,d,d1; 
    e1=rows(c);
    ce = selif(c,indxeq);
    eequal = rows(ce);
    expsumc = exp(sumc(ce));
    { B,F,C1,Bindx } = newcombs(a,eequal);
    f = a*(exp(c)); 
    f1 = ((1+(f')))^(1+c1);   f1prod = prodc((f1'));
    c2 = c1!; cfact = prodc((c2'));  bprod = prodc((b'));
    d = (cfact.*bprod)./f1prod;  d1 = sumc(d);
    retp(expsumc*d1);      
endp;   

/*
{ ga,gc } = gradsdfpdfmmvlogit(a,c,indxeq) :   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae to compute survival/density distribution at
         indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)

** Output:    ga - QK x 1 vector    gc - K x 1 vector  */
 

proc (2) = gradsdfpdfmmvlogit(a,c,indxeq);
    local e1,erow,ecol,expsumc,b,c1,bindx,f,f5,f1,c5,f1prod,c2,cfact,gc1,bprod,d,d1,d5,ga1,gc5,gf1prod,gadenom,ganumer,gc,gdenom,ga,i;
    local ce,eqindx,eequal,gcnumer,gaanumer,gatemp; 
    e1 = rows(c);   erow = rows(a);    ecol = cols(a);
    ce = selif(c,indxeq);   eqindx = selif(seqa(1,1,e1),indxeq);
    eequal = rows(ce);
    expsumc = exp(sumc(ce));   gcnumer = zeros(e1,1);
    gc1 = expsumc.*ones(eequal,1);   /* gc1 is eequalx1  */    gcnumer[eqindx]=gc1;
    { B,F,C1,Bindx } = newcombs(a,eequal);  
    c5=exp(c);    /* B - (Q^K)*eequal matrix ;  F - (Q^K)*eequal matrix;   C1 - (Q^K)*Q matrix  */
    f = a*c5;      /* f is Q x 1 vector */
    f5 = 1+f;    /* f5 is Q*1 vector  */
    f1 = ((f5'))^(1+c1);   f1prod = prodc((f1'));   /* f1 is (Q^K) x Q matrix; f1prod is (Q^K)x1 vector */
    c2 = c1!; cfact = prodc((c2'));  bprod = prodc((b'));   /* cfact is (Q^K)x1 vector; bprod is (Q^K)x1 vector */
    d5 = cfact.*bprod;       /* d5 is Q^K x 1 vector */
    d = d5./f1prod;  d1 = sumc(d);   /* d is (Q^K)x1 vector and d1 is 1 x 1 scalar */
    { ga1,gc5 } = gradprodAB(a,c5);      /* ga1 is QKxQ vector and gc5 is KxQ vector */
    gf1prod = f1prod.*(1+c1)./(f5');     gf1prod=gf1prod';   /* gf1prod is Q x (Q^K)  */
    gadenom = ga1*gf1prod;  /* QKx(Q^K) matrix */ 
    ganumer = d5./(b);  /* ganumer is Q^K x K matrix */   /* This is gradients w.r.t B */
    gc = (gc5*gf1prod).*c5;     /* K x Q^K matrix */ 
    gdenom = (-d)./f1prod;   /* (Q^K x 1 vector)  */
    gc = (gc*gdenom);    /* K x 1 vector */
    gc = gcnumer*d1+gc*expsumc;     /* K x 1 vector */
    ga = zeros(erow*ecol,1);
    for i(1,rows(B),1);
        gaanumer=zeros(erow*ecol,1);    gaanumer=gaanumer';    /* 1 x QK  */
        gaanumer[Bindx[i,.]] = ganumer[i,.];
        gatemp=((f1prod[i].*((gaanumer)')-d5[i].*gadenom[.,i]))./((f1prod[i])^2);      /* QK x 1 */
        ga = ga+gatemp;
    endfor;
    ga = ga*expsumc;
    retp(ga,gc);
endp;     
 

/* nonsdfpdfmmvlogit(a,c,mu,sig,indxeq) : non-standard multivariate minlogistic density/suruvival function, where X is multivariate minlogistic random variable   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute survival distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
        indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)
**
** Output:      w - 1 x 1 vector  */


proc (1) = nonsdfpdfmmvlogit(a,c,mu,sig,indxeq);
    local f,newc,sigeq; 
    newc = (c-mu)./sig;
    f = sdfpdfmmvlogit(a,newc,indxeq);   sigeq = selif(sig,indxeq);
    retp(((1/prodc(sigeq))).*f);
endp;

/* gradnonsdfpdfmmvlogit(a,mu,sig)  : Gradient of non-standard multivariate lminogistic density function  

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute survival distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
        indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)
**
** Output:    ga - QK x 1 vector    gc - K x 1 vector
              gmu - K x 1 vector
              gsig - K x 1 vector  */


proc(4) = gradnonsdfpdfmmvlogit(a,c,mu,sig,indxeq);
    local aa,sigeq,aasignew,eqindx,newc,ga,aa1,prsig,e1,aa2,aamu,aasig1,aasig2,aasig;
    sigeq = selif(sig,indxeq); e1=rows(c);
    eqindx = selif(seqa(1,1,e1),indxeq);
    newc = (c-mu)./sig;
    { ga,aa1 } = gradsdfpdfmmvlogit(a,newc,indxeq);  
    prsig = ((1/prodc(sigeq)))';
    aa2 = prsig.*(aa1./sig);
    aamu = -aa2;
    aasig1 = prsig.*((aa1.*(-newc))./sig);
    aasig2 = (-prsig./sigeq).*((sdfpdfmmvlogit(a,newc,indxeq))');  aasignew = zeros(rows(sig),1);  aasignew[eqindx]=aasig2;
    aasig = aasig1+aasignew;
    retp(prsig*ga,aa2,aamu,aasig);
endp;



/* cdfpdfmmvlogit(a,c,indxeq) : standard multivariate minlogistic partial density/cumulative function, where X is multivariate minlogistic random variable 

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute density/cumulative function at
         indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)
** Output:      w - 1 x 1 vector   */

proc (1) = cdfpdfmmvlogit(a,c,indxeq);
    local e1,ce,ae,indxcdf,cindx,bindx,b1,i,yi,j,b2indx,finindx,a10,c10,indxeq10,com4,c2;
    e1=rows(c);
    ce = selif(c,indxeq);      ae = (selif((a'),indxeq))';      indxcdf = 1-indxeq;
    cindx = selif(seqa(1,1,e1),indxeq);    bindx = selif(seqa(1,1,e1),indxcdf);
    b1 = sumc(indxcdf);
    c2 = pdfmmvlogit(ae,ce);
    for i (1,b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2indx = bindx[yi[j,.]];    finindx = cindx|b2indx; 
            a10 = a[.,finindx];    c10 = c[finindx];    indxeq10 = indxeq[finindx];
            com4 = ((-1)^i)*sdfpdfmmvlogit(a10,c10,indxeq10);
            c2 = c2+com4;
        endfor;            
    endfor;
    /* because of digitization issues, sometimes (c2) returns a value of zero minus (that is, a value very close to zero but negative);
       in this case, simply return the value of zero */
    if (c2) < 0;
       retp(0);
    else;
       retp(c2);
    endif;       
endp;



/* gradcdfpdfmmvlogit(a,c,indxeq) : gradient of standard multivariate minlogistic partial density/cumulative function, where X is multivariate minlogistic random variable 

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute density/cumulative function at
         indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)

** Output:    ga - QK x 1 vector    gc - K x 1 vector  */

proc (2) = gradcdfpdfmmvlogit(a,c,indxeq);
    local e1,erow,ecol,ae,indxcdf,cindx,ce,b1,gc,ga,ga1,gc1,i,yi,j,bindx,b2indx,finindx,a10,c10,indxeq10;
    local ga2,gc2;
    e1=rows(c);   erow = rows(a);   ecol = cols(a);
    ce = selif(c,indxeq);      ae = (selif((a'),indxeq))';      indxcdf = 1-indxeq;
    cindx = selif(seqa(1,1,e1),indxeq);    bindx = selif(seqa(1,1,e1),indxcdf);
    b1 = sumc(indxcdf);
    gc = zeros(e1,1);    ga = zeros(erow,ecol);  
    { ga1,gc1 } = gradpdfmmvlogit(ae,ce);   ga1 = reshape(ga1,erow,rows(cindx));   
    ga[.,cindx]=ga1;   gc[cindx]=gc1;
    for i (1,b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2indx = bindx[yi[j,.]];    finindx = cindx|b2indx; 
            a10 = a[.,finindx];    c10 = c[finindx];    indxeq10 = indxeq[finindx];
            { ga2,gc2 }  = gradsdfpdfmmvlogit(a10,c10,indxeq10);  ga2=reshape(ga2,erow,rows(finindx)); 
            ga[.,finindx] = ga[.,finindx]+((-1)^i)*ga2;    gc[finindx]=gc[finindx]+((-1)^i)*gc2;
        endfor;            
    endfor;
    retp(vecr(ga),gc);     
endp;



/* noncdfpdfmmvlogit(a,c,mu,sig,indxeq) : non-standard multivariate minlogistic density/suruvival function, where X is multivariate minlogistic random variable   

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute cumulative distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
        indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)
**
** Output:      w - 1 x 1 vector  */


proc (1) = noncdfpdfmmvlogit(a,c,mu,sig,indxeq);
    local e1,ce,ae,mue,sige,indxcdf,cindx,bindx,b2indx,b1,com4;
    local i,yi,j,finindx,a10,c10,mu10,sig10,erow,ecol,c2,indxeq10;
    e1=rows(c);
    ce = selif(c,indxeq);      ae = (selif((a'),indxeq))';       mue = selif(mu,indxeq);   sige = selif(sig,indxeq);  indxcdf = 1-indxeq;
    cindx = selif(seqa(1,1,e1),indxeq);    bindx = selif(seqa(1,1,e1),indxcdf);
    b1 = sumc(indxcdf);
    c2 = nonpdfmmvlogit(ae,ce,mue,sige);
    for i (1,b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2indx = bindx[yi[j,.]];    finindx = cindx|b2indx; 
            a10 = a[.,finindx];    c10 = c[finindx];    indxeq10 = indxeq[finindx];   mu10=mu[finindx];    sig10 = sig[finindx];
            com4 = ((-1)^i)*nonsdfpdfmmvlogit(a10,c10,mu10,sig10,indxeq10);
            c2 = c2+com4;
        endfor;            
    endfor;
    /* because of digitization issues, sometimes (c2) returns a value of zero minus (that is, a value very close to zero but negative);
       in this case, simply return the value of zero */
    if (c2) < 0;
       retp(0);
    else;
       retp(c2);
    endif;       
endp;


/* gradnoncdfpdfmmvlogit(a,c,mu,sig,indxeq)  : Gradient of non-standard multivariate minogistic partial density/cumulative function  

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscsicae to compute cumulative distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
        indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)
**
** Output:    ga - QK x 1 vector    gc - K x 1 vector
              gmu - K x 1 vector
              gsig - K x 1 vector  */


proc(4) = gradnoncdfpdfmmvlogit(a,c,mu,sig,indxeq);
    local e1,ce,ae,mue,sige,indxcdf,cindx,bindx,b2indx,b1,gc,ga,gmu,gsig,gc1,ga1,gmu1,gsig1,ga2,gc2,gmu2,gsig2;
    local i,yi,j,finindx,a10,c10,mu10,sig10,erow,ecol,indxeq10;
    e1=rows(c); erow = rows(a); ecol=cols(a);
    ce = selif(c,indxeq);      ae = (selif((a'),indxeq))';       mue = selif(mu,indxeq);   sige = selif(sig,indxeq);  indxcdf = 1-indxeq;
    cindx = selif(seqa(1,1,e1),indxeq);    bindx = selif(seqa(1,1,e1),indxcdf); 
    b1 = sumc(indxcdf);
    gc = zeros(e1,1);    ga = zeros(erow,ecol);    gmu = gc;   gsig = gc;    
    { ga1,gc1,gmu1,gsig1 } = gradnonpdfmmvlogit(ae,ce,mue,sige);     ga1 = reshape(ga1,erow,rows(cindx)); 
    ga[.,cindx]=ga1;   gc[cindx]=gc1;    gmu[cindx]=gmu1;   gsig[cindx]=gsig1;
    for i (1,b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2indx = bindx[yi[j,.]];    finindx = cindx|b2indx; 
            a10 = a[.,finindx];    c10 = c[finindx];    indxeq10 = indxeq[finindx];   mu10=mu[finindx];    sig10 = sig[finindx];
            { ga2,gc2,gmu2,gsig2 } = gradnonsdfpdfmmvlogit(a10,c10,mu10,sig10,indxeq10);  ga2 =reshape(ga2,erow,rows(finindx)); 
            ga[.,finindx] = ga[.,finindx]+((-1)^i)*ga2;    gc[finindx]=gc[finindx]+((-1)^i)*gc2;
            gmu[finindx] = gmu[finindx]+((-1)^i)*gmu2;    gsig[finindx]=gsig[finindx]+((-1)^i)*gsig2;
        endfor;            
    endfor;
    retp(vecr(ga),gc,gmu,gsig);     
endp;


/* nonsdfpdfcdfmmvlogit(a,c,mu,sig,indxeq,indxcomp) : standard multivariate minlogistic partial density function, where X is multivariate minlogistic random variable 

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae to compute density/cumulative/survival distribution at
             mu - K x 1 vector of location parameters
            sig - K x 1 vector of scale parameters
         indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)
       indxcomp - K x 1 vector of indicators; indxcomp =1 in positions of abscissae that are from value to infinity (survivor functions) (if indxeq=1 for an abscissa
                  point, indxcomp should be zero

** Output:      w - 1 x 1 vector  */

proc (1) = nonsdfpdfcdfmmvlogit(a,c,mu,sig,indxeq,indxcomp);
    local e1,notequal,indxsdf,indxcdf,cindx,bindx,eindx,b1,csdf,aesdf,cesdf,muesdf,sigesdf,c2,i,yi,j,b2indx,finindx,a10,c10,mu10,sig10;
    local indxeq10,com4,csdfindx,ccdfindx,ceqindx,finindx1,indx5,equal,e1sdf,e1cdf;
    e1=rows(c);  equal = sumc(indxeq); notequal = e1-equal;    e1sdf = sumc(indxcomp);    e1cdf = notequal-e1sdf;
    if equal==e1;
        c2=nonpdfmmvlogit(a,c,mu,sig);
    elseif notequal==e1;
        c2=noncdfmmvlogitc(a,c,mu,sig,indxcomp);
    elseif equal>0 and notequal>0;
        if e1sdf>0 and e1cdf==0;
           c2=nonsdfpdfmmvlogit(a,c,mu,sig,indxeq);
        elseif e1sdf==0 and e1cdf>0;
           c2=noncdfpdfmmvlogit(a,c,mu,sig,indxeq);
        elseif e1sdf>0 and e1cdf>0;
           indxsdf = (1-indxeq).*indxcomp;      indxcdf = (1-indxeq).*(1-indxcomp);  
           csdfindx = selif(seqa(1,1,e1),indxsdf);    ccdfindx = selif(seqa(1,1,e1),indxcdf);     ceqindx = selif(seqa(1,1,e1),indxeq);
           b1 = sumc(indxcdf);      
           finindx1 = ceqindx|csdfindx;
           aesdf = a[.,finindx1];    cesdf = c[finindx1];      muesdf = mu[finindx1];    sigesdf = sig[finindx1];  indx5 = indxeq[finindx1];
           c2 = nonsdfpdfmmvlogit(aesdf,cesdf,muesdf,sigesdf,indx5);
           for i (1,b1,1);
              yi = combinate(b1,i);
              for j (1,rows(yi),1);
                  b2indx = ccdfindx[yi[j,.]];    finindx = ceqindx|csdfindx|b2indx;  
                  a10 = a[.,finindx];    c10 = c[finindx];    indxeq10 = indxeq[finindx];   mu10=mu[finindx];    sig10 = sig[finindx];
                  com4 = ((-1)^i)*nonsdfpdfmmvlogit(a10,c10,mu10,sig10,indxeq10);
                  c2 = c2+com4;
              endfor;            
           endfor;
        endif;
    endif;
    retp(c2);
endp;      


/* gradnonsdfpdfcdfmmvlogit(a,c,mu,sig,indxeq,indxcomp) : standard multivariate minlogistic partial density function, where X is multivariate minlogistic random variable 

 Input:       a - Q x K  matrix, where Q corresponds to number of constraints, and K corresponds to number of goods
              c - K x 1 vector of abscissae to compute density/cumulative/survival distribution at
         indxeq - K x 1 vector of indicators of abscissae that represent point values (for density function computation)
       indxcomp - K x 1 vector of indicators; indxcomp =1 in positions of abscissae that are from value to infinity (survivor functions) (if indxeq=1 for an abscissa
                  point, indxcomp does not matter and will be ignored; indxcomp comes into play only if indxeq=0

** Output:    ga - QK x 1 vector    gc - K x 1 vector
              gmu - K x 1 vector
              gsig - K x 1 vector  
{ ga,gc,gmu,gsig } =  gradnonsdfpdfcdfmmvlogit(a,c,mu,sig,indxeq,indxcomp);  */

proc (4) = gradnonsdfpdfcdfmmvlogit(a,c,mu,sig,indxeq,indxcomp);
    local e1,notequal,indxsdf,indxcdf,cindx,bindx,eindx,b1,csdf,aesdf,cesdf,muesdf,sigesdf,c2,i,yi,j,b2indx,finindx,a10,c10,mu10,sig10,indxeq10,com4;
    local erow,ecol,ga,gc,gmu,gsig,csdfindx,ccdfindx,ceqindx,ga1,gc1,gmu1,gsig1,ga2,gc2,gmu2,gsig2,indx5,finindx1,equal,e1sdf,e1cdf;
    e1=rows(c);  equal = sumc(indxeq); notequal = e1-equal;  erow = rows(a);  ecol=cols(a);  e1sdf = sumc(indxcomp); e1cdf = notequal-e1sdf;
    if equal==e1;
        { ga,gc,gmu,gsig } = gradnonpdfmmvlogit(a,c,mu,sig);        
    elseif notequal==e1;
        { ga,gc,gmu,gsig } = gradnoncdfmmvlogitc(a,c,mu,sig,indxcomp);
    elseif equal>0 and notequal>0;
        if e1sdf>0 and e1cdf==0;
           { ga,gc,gmu,gsig } = gradnonsdfpdfmmvlogit(a,c,mu,sig,indxeq);
        elseif e1sdf==0 and e1cdf>0;
           { ga,gc,gmu,gsig } = gradnoncdfpdfmmvlogit(a,c,mu,sig,indxeq);
        elseif e1sdf>0 and e1cdf>0;
           indxsdf = (1-indxeq).*indxcomp;      indxcdf = (1-indxeq).*(1-indxcomp);
           csdfindx = selif(seqa(1,1,e1),indxsdf);    ccdfindx = selif(seqa(1,1,e1),indxcdf);     ceqindx = selif(seqa(1,1,e1),indxeq);  
           b1 = sumc(indxcdf);
           csdf = selif(c,indxsdf);        
           gc = zeros(e1,1);    ga = zeros(erow,ecol);    gmu = gc;   gsig = gc;    
           finindx1 = ceqindx|csdfindx;    indx5 = indxeq[finindx1];
           aesdf = a[.,finindx1];    cesdf = c[finindx1];      muesdf = mu[finindx1];    sigesdf = sig[finindx1];  indx5 = indxeq[finindx1];
           { ga1,gc1,gmu1,gsig1 } = gradnonsdfpdfmmvlogit(aesdf,cesdf,muesdf,sigesdf,indx5);  ga1 = reshape(ga1,erow,rows(finindx1));  
           ga[.,finindx1]=ga1;   gc[finindx1]=gc1;    gmu[finindx1]=gmu1;   gsig[finindx1]=gsig1;        
           for i (1,b1,1);
              yi = combinate(b1,i);
              for j (1,rows(yi),1);
                  b2indx = ccdfindx[yi[j,.]];    finindx = ceqindx|csdfindx|b2indx; 
                  a10 = a[.,finindx];    c10 = c[finindx];    indxeq10 = indxeq[finindx];   mu10=mu[finindx];    sig10 = sig[finindx];
                  { ga2,gc2,gmu2,gsig2 } = gradnonsdfpdfmmvlogit(a10,c10,mu10,sig10,indxeq10);  ga2 =reshape(ga2,erow,rows(finindx)); 
                  ga[.,finindx] = ga[.,finindx]+((-1)^i)*ga2;    gc[finindx]=gc[finindx]+((-1)^i)*gc2;
                  gmu[finindx] = gmu[finindx]+((-1)^i)*gmu2;    gsig[finindx]=gsig[finindx]+((-1)^i)*gsig2;
              endfor;            
           endfor;
           ga = vecr(ga);
        endif;
    endif;
    retp(ga,gc,gmu,gsig); 
endp;      


/* Procedure below computes mean of the untruncated minlogistic univariate distribution */

/* a is a Kx1 vector of index values; parameter mu -- 1 x 1, sig of eta -- is 1 x 1 */
proc meanuntruncminlog(a,sig);
   local g,e1,g5,i,g6,g7;
   g = {};  e1 = rows(a);
   g5 = (a^(e1-1)).*ln(a);    
   for i(1,e1,1);
      g6 = a[i]-a;  g6 = (g6.*(g6.!=0))+(g6.==0);   g6 = prodc(g6);
      g = g|g6;
   endfor;
   g7 = -sumc((g5./g));   g7 = g7*sig;
   retp(g7);
endp;

/* a is a Kx1 vector of index values; parameter mu -- 1 x 1, sig of eta -- is 1 x 1;  */
/* ** Output:    z  -   1 x 1 scalar (mean of untruncated minlogistic distribution univariate distribution)
                 ga -   K x 1 vector    
                 gsig - 1 x 1 vector  
{ z,ga,gsig } =  gradmeanuntruncminlog(a,sig);  verified in test in g:\gauss\com\MDCEVtwostage\test*/

proc (3) = gradmeanuntruncminlog(a,sig);
   local g,e1,g5,i,g6,g7,g10,g8,g20,g15,ga1,indx1,indx,ga;
   g = {};  e1 = rows(a);  indx = seqa(1,1,e1);
   g5 = (a^(e1-1)).*ln(a);    
   for i(1,e1,1);
      g6 = a[i]-a;  g6 = (g6.*(g6.!=0))+(g6.==0);   g6 = prodc(g6);
      g = g|g6;
   endfor;
   g10 = g5./g;
   g7 = -sumc(g10);   g8 = g7*sig;
   ga1 = {}; 
   for i(1,e1,1);
      indx1 = notthere(indx,i);
      g15 = g10[i]+g10[indx1];  g15 = g15./(a[i]-a[indx1]);  g20=(sumc(g15));
      ga = ((g10[i]/a[i])*(e1-1))+((a[i]^(e1-2))./g[i])-g20;   
      ga1 = ga1|ga;
   endfor;
   retp(g8,-sig*ga1,g7);
endp;


/* Procedure below computes mean of the truncated minlogistic univariate distribution; that is mean of eta when eta is less than a given value c;
   essentially expected value when eta < c  */

/* a is a Kx1 vector of index values; mu is 1 x 1, c is 1 x 1 */

proc meantruncminlog(a,sig,c);
   local g,e1,g5,g6,i,g7,f;
   f = 1-(1/(prodc((1+a*exp(c/sig)))));
   g = {};  e1 = rows(a);
   g5 = (a^(e1-1)).*ln(1+a*exp(c/sig));    
   for i(1,e1,1);
      g6 = a[i]-a;  g6 = (g6.*(g6.!=0))+(g6.==0);   g6 = prodc(g6);
      g = g|g6;
   endfor;
   g7 = -sumc((g5./g));   g7 = (1/f)*g7*sig+c;
   retp(g7);
endp;

/* Procedure below computes variance of the untruncated minlogistic univariate distribution */

/* a is a Kx1 vector of index values; mu is 1 x 1, sig is 1 x 1 */
proc varuntruncminlog(a,sig);
   local g,e1,g8,g5,g6,i,g7;
   g = {};  e1 = rows(a);
   g8 = (a^(e1-1)).*ln(a);  
   g5 = (a^(e1-1)).*(3*((ln(a))^2)+pi^2);    
   for i(1,e1,1);
      g6 = a[i]-a;  g6 = (g6.*(g6.!=0))+(g6.==0);   g6 = prodc(g6);
      g = g|g6;
   endfor;
   g7 = (sumc((g5./(3*g))))-((sumc((g8./g)))^2);   g7 = g7*(sig^2);
   retp(g7);
endp;

/* Procedure below computes mean of the truncated minlogistic univariate distribution; that is mean of eta when eta is less than a given value c;
   essentially expected value when eta < c  */

/* a is a Kx1 vector of index values; mu is 1 x 1, c is 1 x 1 */

proc vartruncminlog(a,sig,c);
   local g,e1,g5,g6,g8,i,g7,f;
   f = 1-(1/(prodc((1+a*exp(c/sig)))));
   g = {};  e1 = rows(a);
   g8 = (a^(e1-1)).*ln(1+a*exp(c/sig));        
   g5 = (a^(e1-1)).*dilog(-a*exp(c/sig));    
   for i(1,e1,1);
      g6 = a[i]-a;  g6 = (g6.*(g6.!=0))+(g6.==0);   g6 = prodc(g6);
      g = g|g6;
   endfor;
   g7 = -sumc((g5./g));   g7 = 2*g7*(1/f)-(((1/f)^2)*((sumc((g8./g)))^2));   g7 = g7*(sig^2);
   retp(g7);
endp;


/* noncdfmvlogitcomp(b,mu,sig) : complement of noncdfmvlogit  

 Input:       b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)
              mu - (K) x 1 vector of location parameters of Y
              sig - (K) x 1 vector of scale parameters of Y

** Output:      w - 1 x 1 vector  Pr(Y > b). */

proc (1) = noncdfmvlogitcomp(b,mu,sig);
    local bb;
    bb = (b-mu)./sig;
    retp(cdfmvlogitcomp(bb));
endp;

/* gradnoncdfmvlogitcomp(a,b,mu,sig) : gradient of complement of noncdfmvlogit  

 { gb,gmu,gsig } = gradnoncdfmvlogitcomp(b,mu,sig) :   

Input:        b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - c to inf)
              mu - (K) x 1 vector of location parameters of Y
              sig - (K) x 1 vector of scale parameters of Y

** Output:    gb - K x 1 vector
              gmu - (K) x 1 vector
              gsig - (K) x 1 matrix of scale parameters  */


proc (3) = gradnoncdfmvlogitcomp(b,mu,sig);
    local bb,gbb,gbb1,gsig;   
    bb = (b-mu)./sig;
    { gbb } = gradcdfmvlogitcomp(bb);
    gbb1 = gbb./sig;
    gsig = (-gbb.*bb)./sig;  
    retp(gbb1,(-gbb1),(gsig));
endp;


/* noncdfmvlogit(a,mu,sig)  : non-standard multivariate logistic CDF  

 Input:       a - K x Q matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations 
             mu - K x Q matrix of location parameters, or if all Q observations have same mu, Kx1 vector
             sig - K x Q matrix of scale parameters, or if all Q observations have same sig, Kx1 vector 
**
** Output:      w - Q x 1 vector  */

proc(1) = noncdfmvlogit(a,mu,sig);
    local aa,f;
    aa = (a-mu)./sig;
    f = exp(-aa);
    retp((1+sumc(f))^(-1));
endp;



/* { ga,gmu,gsig } = gradnoncdfmvlogit(a,mu,sig) :   

 Input:       a - K x Q matrix of abscissae, where K corresponds to number of variates and Q corresponds to number of observations 
             mu - K x Q matrix of location parameters, or if all Q observations have same mu, Kx1 vector
             sig - K x Q matrix of scale parameters, or if all Q observations have same sig, Kx1 vector 

** Output:    ga - K x Q matrix  
              gmu - K x Q matrix of location parameters, or if all Q observations have same mu, Kx1 vector
              gsig - K x Q matrix of scale parameters, or if all Q observations have same sig, Kx1 vector  */

proc (3) = gradnoncdfmvlogit(a,mu,sig);
    local aa,f,h,aa1,aa2,aamu,aasig; 
    aa = (a-mu)./sig;
    aa1 = gradcdfmvlogit(aa);
    aa2 = aa1./sig;
    aamu = aa1.*(-1/sig);
    aasig = (aa1.*(-aa))./sig;
    if cols(mu)==1;
      aamu = sumc((aamu'));
    endif;
    if cols(sig)==1;
      aasig = sumc((aasig'));
    endif;
    retp(aa2,aamu,aasig);
endp;



/* cdfmvlogitcomp(b) : Complement of cdfmvlogit  

 Input:         b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)

** Output:      w - 1 x 1 vector  Pr(Y > b). */

proc (1) = cdfmvlogitcomp(b);
    local a1,b1,a2,b2,i,yi,com,b3,b4,j,com1; 
    b1 = rows(b);
    com1=0;
    for i (1,b1,1);
        com=0;
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2 = b[yi[j,.]];
            b4 = ((-1)^i).*cdfmvlogit(b2);
            com = com+b4;
        endfor;            
        com1 = com+com1;
    endfor;
    /* because of digitization issues, sometimes (a2+com1) returns a value of zero minus (that is, a value very close to zero but negative);
       in this case, simply return the value of zero */
    if (1+com1) < 0;
       retp(0);
    else;
       retp(1+com1);
    endif;        
endp;   


/* { gb } = gradcdfmvlogitcomp(b) :   

 Input:      b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)

** Output:   gb - K x 1 vector */


proc (1) = gradcdfmvlogitcomp(b);
    local a1,b1,ga1,gcombnew,gcomanew,i,gcoma,gcomb,yi,j,gcomb1,b2,gcom; 
    b1 = rows(b);
    gcombnew = zeros(b1,1); 
    for i (1,b1,1);
        gcomb = zeros(b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            gcomb1 = zeros(b1,1);
            b2 = b[yi[j,.]];
            gcom = ((-1)^i).*gradcdfmvlogit(b2);
            gcomb1[yi[j,.]]=gcom;
            gcomb = gcomb+gcomb1;
        endfor;          
        gcombnew = gcombnew+gcomb;
    endfor;
    retp(gcombnew);
endp;   


/* noncdfmvlogitcomp(b,mu,sig) : complement of noncdfmvlogit  

 Input:       b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)
              mu - (K) x 1 vector of location parameters of Y
              sig - (K) x 1 vector of scale parameters of Y

** Output:      w - 1 x 1 vector  Pr(Y > b). */

proc (1) = noncdfmvlogitcomp(b,mu,sig);
    local bb;
    bb = (b-mu)./sig;
    retp(cdfmvlogitcomp(bb));
endp;

/* gradnoncdfmvlogitcomp(a,b,mu,sig) : gradient of complement of noncdfmvlogit  

 { gb,gmu,gsig } = gradnoncdfmvlogitcomp(b,mu,sig) :   

Input:        b - K x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - c to inf)
              mu - (K) x 1 vector of location parameters of Y
              sig - (K) x 1 vector of scale parameters of Y

** Output:    gb - K x 1 vector
              gmu - (K) x 1 vector
              gsig - (K) x 1 matrix of scale parameters  */


proc (3) = gradnoncdfmvlogitcomp(b,mu,sig);
    local bb,gbb,gbb1,gsig;   
    bb = (b-mu)./sig;
    { gbb } = gradcdfmvlogitcomp(bb);
    gbb1 = gbb./sig;
    gsig = (-gbb.*bb)./sig;  
    retp(gbb1,(-gbb1),(gsig));
endp;


/* cdfmvlogitc(a,b) : combination of cdfmvlogit and complement of cdfmvlogit  

 Input:       a - K x 1 vector of abscissae (a is truncation point from above for mvlogit variable vector X- -inf to a)
              b - M x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)

**  If you want Pr(Y>b), just put a = 1000;

** Output:      w - 1 x 1 vector  Pr(X < a, Y > b). */

proc (1) = cdfmvlogitc(a,b);
    local a1,b1,a2,b2,i,yi,com,b3,b4,j,com1; 
    a1 = rows(a);
    b1 = rows(b);
    a2 = cdfmvlogit(a);
    com1=0;
    for i (1,b1,1);
        com=0;
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            b2 = b[yi[j,.]];
            b4 = ((-1)^i).*cdfmvlogit(a|b2);
            com = com+b4;
        endfor;            
        com1 = com+com1;
    endfor;
    /* because of digitization issues, sometimes (a2+com1) returns a value of zero minus (that is, a value very close to zero but negative);
       in this case, simply return the value of zero */
    if (a2+com1) < 0;
       retp(0);
    else;
       retp(a2+com1);
    endif;        
endp;   


/* { ga,gb } = gradcdfmvlogitc(a,b) :   

 Input:       a - K x 1 vector of abscissae (a is truncation point from above for mvlogit variable vector X- -inf to a)
              b - M x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)

**  If you want Pr(Y>b), just put a = 1000;

** Output:    ga - K x 1 vector
              gb - M x 1 vector */


proc (2) = gradcdfmvlogitc(a,b);
    local a1,b1,ga1,gcombnew,gcomanew,i,gcoma,gcomb,yi,j,gcomb1,b2,gcom; 
    a1 = rows(a);
    b1 = rows(b);
    ga1 = gradcdfmvlogit(a);
    gcombnew = zeros(b1,1); 
    gcomanew = zeros(a1,1);
    for i (1,b1,1);
        gcoma=zeros(a1,1);
        gcomb = zeros(b1,1);
        yi = combinate(b1,i);
        for j (1,rows(yi),1);
            gcomb1 = zeros(b1,1);
            b2 = b[yi[j,.]];
            gcom = ((-1)^i).*gradcdfmvlogit(a|b2);
            gcoma = gcoma+gcom[1:a1];
            gcomb1[yi[j,.]]=gcom[a1+1:rows(gcom)];
            gcomb = gcomb+gcomb1;
        endfor;          
        gcomanew = gcomanew+gcoma;
        gcombnew = gcombnew+gcomb;
    endfor;
    retp(gcomanew+ga1,gcombnew);
endp;   


/* noncdfmvlogitc(a,b,mu,sig) : combination of noncdfmvlogit and complement of noncdfmvlogit  

 Input:       a - K x 1 vector of abscissae (a is truncation point from above for mvlogit variable vector X- -inf to a)
              b - M x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - b to inf)
              mu - (K+M) x 1 vector of location parameters of X|Y
              sig - (K+M) x 1 vector of scale parameters of X|Y

**  If you want Pr(Y>b), just put a = 1000;

** Output:      w - 1 x 1 vector  Pr(X < a, Y > b). */

proc (1) = noncdfmvlogitc(a,b,mu,sig);
    local aa,m,h,bb;
    m = rows(a);
    h = rows(b);
    aa = (a-mu[1:m])./sig[1:m];
    bb = (b-mu[m+1:m+h])./sig[m+1:m+h];
    retp(cdfmvlogitc(aa,bb));
endp;

/* gradnoncdfmvlogitc(a,b,mu,sig) : gradient of combination of noncdfmvlogit and complement of noncdfmvlogit  

 { ga,gb,gmu,gsig } = gradnoncdfmvlogitc(a,b,mu,sig) :   

Input:        a - K x 1 vector of abscissae (a is truncation point from above for mvlogit variable vector X- -inf to b)
              b - M x 1 vector of abscissae (b is truncation point from below for mvlogit variable vector Y - c to inf)
              mu - (K+M) x 1 vector of location parameters of X|Y
              sig - (K+M) x 1 vector of scale parameters of X|Y

** Output:    ga - K x 1 vector 
              gb - M x 1 vector
              gmu - (K+M) x 1 vector
              gsig - (K+M) x 1 matrix of scale parameters  */


proc (4) = gradnoncdfmvlogitc(a,b,mu,sig);
    local m,h,mua,mub,siga,sigb,aa,bb,gaa,gbb,gaa1,gbb1,gsiga,gsigb;
    m = rows(a);
    h = rows(b);
    mua = mu[1:m];
    mub = mu[m+1:m+h];
    siga = sig[1:m];
    sigb = sig[m+1:m+h];    
    aa = (a-mua)./siga;
    bb = (b-mub)./sigb;
    { gaa, gbb } = gradcdfmvlogitc(aa,bb);
    gaa1 = gaa./siga;
    gbb1 = gbb./sigb;
    gsiga = (-gaa.*aa)./siga;
    gsigb = (-gbb.*bb)./sigb;  
    retp(gaa1,gbb1,(-gaa1|-gbb1),(gsiga|gsigb));
endp;

/*
** prodcdfmvnanl.src 
**
** Purpose: Develops the product of cumulative distribution functions for the univariate or multivariate normal 
**

** Format:      { F,s1 } = prodcdfmvnanl(mu,cov,x,s); product of MVNCDs with different mean values across occasions t (t=1,2,...T)
**
** Input:        mu is the (KxT) vector of means, T being the number of occasions about which product is taken 
                 cov is the KXK correlation matrix or KxK covariance matrix,
                 x represents the vector of points of truncation from above (integrals are -infinity to x)  - Kx1 vector
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                          Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)    
                          
** Output:      F - 1x1 
                s1 - New seed that you may need in evaluating multiple functions in estimation when using SSJ for K>4   */

proc(2) = prodcdfmvnanl(mu,cov,x,s);
  local t,c,i,f,s1;
  t = cols(mu);
  c = 1;
  s1=s;
  for i(1,t,1);
     { f,s1 } = cdfmvnanl(mu[.,i],cov,x,s1);
     c = c*f;
  endfor;
  retp(c,s);
endp;

 
/*
** gradprodcdfmvnanl.src 
**
** Purpose: Develops the gradients of prodcdfmvnanl 

** Format:      { P,gmu,gcov,gx,s1 } = gradprodcdfmvnanl(mu,cov,x,s)
**
** Input:        mu is the (KxT) vector of means
                 cov is the KXK correlation matrix if _covarr=0; and cov is KxK covariance matrix if _covarr=1,
                 x represents points of truncation from above (integrals are -infinity to x)
                 s is a seed value that is relevant only for the SSJ method (and for dimension of x>4); provide some arbitrary value such as 28989898  

**Global:        The global below is applicable only when the dimensionality of integration exceeds four. 
                 _method   =     "SSJ"                     - Switzer, Solow, and Joe Method
                                 "TG"                      - Trinh and Genz's univariate conditioning approximation procedure
                                 "ME"                      - The traditional ME approach, implemented in a new matrix-based and LDLT-based manner
                                 "OVUS"                    - One-variate univariate screening approach
                                 "OVBS"                    - One-variate bivariate screening approach
                                 "TGBME"                   - Trinh and Genz's bivariate conditioning approximation procedure
                                 "BME"                     - Bivariate ME approach
                                 "TVBS"                    - Two-variate bivariate screening approach  
                         
                 Default is TVBS and _optimal = 0 (see cdfmvnanalytic code)  
                          
                 _covarr = 1     means cov is a covariance matrix; _covarr=0 means cov is actually a correlation matrix   
                 _Cholesky = 1 if you want gradients with respect to Cholesky of cov and not cov

** Output:       P is the scalar probability value
                 gmu is the (KxT) x 1 gradient vector of F with respect to the matrix of means
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the correlation matrix elements if _covarr=0 and _cholesky=0 (K>1)
                     is the Kx(K+1)/2 gradient vector of F with respect to the covariance matrix elements if _covarr=1 and _cholesky=0; (K>1)
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to variance if _covarr=1; if _covarr=0, ignore gcov;
                 gcov is the Kx(K-1)/2 gradient vector of F with respect to the cholesky of the correlation matrix elements if _covarr=0 and _cholesky=1
                     is the Kx(K+1)/2 gradient vector of F with respect to the cholesky of the covariance matrix elements if _covarr=1 and _cholesky=1;
                     If K=1 (univariate case), gcov is a scalar with gradient with respect to standard deviation if _covarr=1; if _covarr=0, ignore gcov;                 gx represents the (Kx1) gradient vector of F with respect to the points of truncation from below (integrals are x to infinity)
                 s1 is a new seed value that is relevant only for the SSJ method (and for dimension of x>4);


                 mu  = {  mu11 mu12  
                          mu21 mu22  
                          mu31 mu32} ;      So, here you have K=3 and T =2 

                 if _covarr=1;

                 cov = { sig11    sig12   sig13,        if _cholesky=0;   chol(cov)  =  { S11       S12         S13,      if _cholesky=1
                         sig12    sig22   sig23,                                          0         S22         S23,
                         sig13    sig23   sig33   };                                      0         0           S33  }

                 if _covarr=0;

                 cov = {   1      rho12   rho13,        if _cholesky=0;   chol(cov) = {   1       S12         S13,                     if _cholesky=1
                         rho12       1    rho23,                                          0   sqrt(1-S12^2)   S23,
                         rho13    rho23      1   };                                       0         0        sqrt(1-S13^2-S23^2)  }


               gmu  =  { dF/dmu11,            /* dF/dmu11 is with respect to first dimension for 1st choice occasion */
                         dF/dmu12             /* dF/dmu12 is with respect to first dimension for 2nd choice occasion */
                         dF/dmu21,            /* dF/dmu21 is with respect to second dimension for 1st choice occasion */
                         dF/dmu22,            /* dF/dmu22 is with respect to second dimension for 2nd choice occasion */
                         dF/dmu31,            /* dF/dmu31 is with respect to third dimension for 1st choice occasion */
                         dF/dmu32 };          /* dF/dmu32 is with respect to third dimension for 2nd choice occasion */
                         
              gcov  =  { dF/dsig11,   if _cholesky=0 and __covarr=1;         
                         dF/dsig12,                               
                         dF/dsig13,                                
                         dF/dsig22,                                
                         dF/dsig23,                                      
                         dF/disg33 };                                       

              gcov  =  { dF/drho12,   if _cholesky=0 and __covarr=0;                                       
                         dF/drho13,                                                                
                         dF/drho23  };  

              gcov  =  { dF/dS11,   if _cholesky=1 and __covarr=1;         
                         dF/dS12,                               
                         dF/dS13,                                
                         dF/dS22,                                
                         dF/dS23,                                      
                         dF/dS33 };                                       

              gcov  =  { dF/dS12,   if _cholesky=1 and __covarr=0;                                       
                         dF/dS13,                                                                
                         dF/dS23  };
                         
              gx    =   { dF/dx1,
                          dF/dx2,
                          dF/dx3 }    */
                         
proc (5) = gradprodcdfmvnanl(mu,cov,x,s);   
  local t,c,i,f,s1,gcov1,gx1,c1,gmu1,gmu,gcov,gx;
  t = cols(mu);
  c1 = {};
  gmu1 = {};
  s1=s;
  for i(1,t,1);
     { f,s1 } = cdfmvnanl(mu[.,i],cov,x,s1);
     c1 = c1|f;
  endfor;
  c = prodc(c1);
  gcov1 = 0;
  gx1 = 0;
  for i(1,t,1);     
     { f,gmu,gcov,gx,s1 } = gradcdfmvnanl(mu[.,i],cov,x,s1);
     gmu = (gmu*c)/c1[i];    gcov = (gcov*c)/c1[i];     gx = (gx*c)/c1[i];
     gmu1 = gmu1~gmu;
     gcov1 = gcov1+gcov;
     gx1 = gx1+gx;
  endfor;
  retp(c,vecr(gmu1),gcov1,gx1,s1);
endp;


/* Procedures for cdf and pdf, and pdf gradients for Gumbel and reverse Gumbel  */

proc cdgumbel(x);
  retp(exp(-exp(-x)));
endp;

proc noncdgumbel(mu,sig,x);
   retp(cdgumbel((x-mu)/sig));
endp;

proc (3) = gradnoncdgumbel(mu,sig,x);
  local z,z1,z2;
  z = (x-mu)/sig;
  z1 = pdgumbel(z);
  z2 = (1/(sig))*z1;
  retp(-z2,(-z2.*z),z2);
endp;

proc pdgumbel(x);
  retp(exp(-x-exp(-x)));
endp;

proc gradpdgumbel(x);
   retp(pdgumbel(x).*(exp(-x)-1));
endp;

proc nonpdgumbel(mu,sig,x);
  retp((1/sig)*(pdgumbel(((x-mu)/sig))));
endp;

proc (3) = gradnonpdgumbel(mu,sig,x);  /* output is { gmu,gsig,gx }  */
  local z,z1,z2,z3;
  z = (x-mu)/sig;
  z1 = gradpdgumbel(z);
  z2 = (1/(sig^2))*z1;
  z3 = (1/(sig^2))*pdgumbel(z);
  retp(-z2,(-z2.*z-z3),z2);
endp;

proc cdrgumbel(x);
  retp(1-(exp(-exp(x))));
endp;

proc noncdrgumbel(mu,sig,x);
   retp(cdrgumbel((x-mu)/sig));
endp;

proc (3) = gradnoncdrgumbel(mu,sig,x);   /* output is gmu,gsig,gx */
  local z,z1,z2;
  z = (x-mu)/sig;
  z1 = pdrgumbel(z);
  z2 = (1/(sig))*z1;
  retp(-z2,(-z2.*z),z2);
endp;

proc pdrgumbel(x);
  retp(exp(x-exp(x)));
endp;

proc gradpdrgumbel(x);
   retp(pdrgumbel(x).*(1-exp(x)));
endp;

proc nonpdrgumbel(mu,sig,x);
  retp((1/sig)*(pdrgumbel(((x-mu)/sig))));
endp;

proc (3) = gradnonpdrgumbel(mu,sig,x);  /* output is { gmu,gsig,gx }  */
  local z,z1,z2,z3;
  z = (x-mu)/sig;
  z1 = gradpdrgumbel(z);
  z2 = (1/(sig^2))*z1;
  z3 = (1/(sig^2))*pdrgumbel(z);
  retp(-z2,(-z2.*z-z3),z2);
endp;

/* Survivor function for reverse Gumbel */

proc sdrgumbel(x);
  retp(exp(-exp(x)));
endp;

proc nonsdrgumbel(mu,sig,x);
   retp(sdrgumbel((x-mu)/sig));
endp;

proc (3) = gradnonsdrgumbel(mu,sig,x);
   local gmu,gsig,gx;
   { gmu,gsig,gx } = gradnoncdrgumbel(mu,sig,x);    
   retp(-gmu,-gsig,-gx);
endp;

proc sdrgumbelinverse(y);  /*  y = exp(-exp(x));   sdrgumbelinverse(y) = x= ln(-ln(y));   */
   retp(ln(-ln(y)));
endp;

proc gradsdrgumbelinverse(y);  /*  dsdrgumbelinverse(y)/dy = dx/dy= d/dy{ln(-ln(y))};   */
   retp(1/(y.*ln(y)));
endp;
   
/* Procedures for cdf and pdf, and cdf/pdf gradients for logistic distribution  */

proc cdlogit(x);
  retp(1./(1+exp(-x)));
endp;

proc noncdlogit(mu,sig,x);
  retp(cdlogit((x-mu)/sig));
endp;

proc (3) = gradnoncdlogit(mu,sig,x);
  local z,z1,z2;
  z = (x-mu)/sig;
  z1 = pdlogit(z);
  z2 = (1/(sig))*z1;
  retp(-z2,(-z2.*z),z2);
endp;

proc pdlogit(x);   /* gradcdlogit is pdlogit */
   retp(exp(-x)./((1+exp(-x))^2));
endp; 
   
proc gradpdlogit(x);
   retp(pdlogit(x).*((1-exp(-x))/(1+exp(-x))));
endp;

proc nonpdlogit(mu,sig,x);
   retp((1/sig).*pdlogit((x-mu)/sig)); 
endp;

proc (3) = gradnonpdlogit(mu,sig,x);  /* output is { gmu,gsig,gx }  */
  local z,z1,z2,z3;
  z = (x-mu)/sig;
  z1 = gradpdlogit(z);
  z2 = (1/(sig^2))*z1;
  z3 = (1/(sig^2))*pdlogit(z);
  retp(-z2,(-z2.*z-z3),z2);
endp;

proc cdlogitinverse(y);       /* y = 1/(1+e^-x), means cdlogitinverse(y)=x=-ln((1/y)-1)  */
    retp(-ln((1/y)-1));
endp;

proc gradcdlogitinverse(y);    /* This is dcdlogitinverse(y)/dy  */
  retp(1/(y.*(1-y)));
endp;

proc noncdlogitinverse(mu,sig,x);
  local z;
  z = (x-mu)/sig;
  retp(sig.*cdlogitinverse(z)+mu);
endp;    

/* Procedure to calculate multi-variate skew-normal density.

mu : column vector of mean  (K x Q; K is dimensionality, Q is number of observations)
sig : covariance matrix (K x K matrix; same across all Q )
rho   : column vector of skew parameter  (K x 1). All the elements should be between -1 and 1. 
x: a column vector of abscissa (K x Q)   */

proc(1)=nonpdfskewn(mu,sig,rho,x);
    local d,c1,omega_star,askew,z,c3,z1;
    d = rows(x);
    c1 = nonpdfmvn(mu,sig,x); 
    omega_star = corrvc(sig);
    omega_star = diagrv(omega_star,ones(d,1));
    askew    = (inv(omega_star)*rho)/((1 - (rho'*inv(omega_star)*rho))^0.5);
    z  = (x-mu)./sqrt(diag(sig));
    z1 = cdfn(askew'*z);
    c3          = 2*(c1.*(z1'));
    retp(c3);
endp;

/* Procedure to calculate multi-variate skew-normal cumulative distribution function .

INPUT

mu : column vector of mean  (K x Q or K x 1; K is dimensionality, Q is number of observations)
sig : covariance matrix (K x K matrix; same across all Q )
rho   : column vector of skew parameter  (K x 1). All the elements should be between -1 and 1 (same across all Q)
x: a column vector of abscissa (K x Q or K x 1)  
s: seed value 1x1 if using Joe approximation (needed, but relevant only if Joe approximation is selected and dimension of integration>4   

OUTPUT

F - Q x 1 vector  */

proc(1)=noncdfskewn(mu,sig,rho,x,s);
    local w,sc,covagmin,mu1,z2,z,s1,z1;
    w = sqrt(diag(sig));
    sc = -rho.*w;
    covagmin = (1~(sc'))|(sc~sig);
    z2 = {};
    if cols(mu) == 1 and cols(x) == 1;
       mu1 = 0|mu;
       z = 0|x;
      { z1,s1 } = cdfmvnanl(mu1,covagmin,z,s);
      retp(2*z1);
    elseif cols(mu) == 1 and cols(x) > 1;    
      z2 = {};  
      mu1 = 0|mu;      
      for i(1,cols(x),1);
         z = 0|x[.,i];
         { z1,s1 } = cdfmvnanl(mu1,covagmin,z,s);
         z2 = z2|z1;
      endfor;
      retp(2*z2);
    elseif cols(mu) > 1 and cols(x) > 1; 
      z2 = {};      
      for i(1,cols(x),1);
         mu1 = 0|mu[.,i];  
         z = 0|x[.,i];
         { z1,s1 } = cdfmvnanl(mu1,covagmin,z,s);
         z2 = z2|z1;
      endfor;
      retp(2*z2);        
    endif;
endp;

/* Procedure to generate multivariate skew-normal random realizations */

/* Generating random numbers from skew-normal - nobs is number of multivariate draws needed, mu is location column vector of dimension D, 
   sd is standard deviations column vector of dimension D, and omegaaug is desired augmented correlation matrix [of size (D+1) x (D+1)] */

proc rndskewn(nobs,mu,sd,omegaaug,seed);
  local omega,Z,M,MM1,MM2,ndim;
  ndim = rows(omegaaug)-1;
  omega = omegaAug[2:ndim+1,2:ndim+1];
  M = rndns(nobs,1+ndim,seed);
  M = M*chol(omegaAug);
  MM1 = M[.,1].<=0;
  MM2 = M[.,2:ndim+1];
  Z = MM1.*(-MM2)+(1-MM1).*MM2; 
  retp(mu' + sd' .* Z);
endp; 

/* Procedure to calculate univariate skew-t density.

nu :  Q x 1 degrees of freedom parameters (nu should take values > 1 ) or 1 x 1 if same degree of freedom
mu : column vector of mean  (Q x 1; Q is number of observations)
sig : variance vector (Q x 1 vector; can be 1 x 1 too )
rho   : column vector of skew parameter  (Q x 1). All the elements should be between -1 and 1. 
x: a column vector of abscissa (Q x 1)  */

proc(1)=nonpdfskewt(nu,x,mu,sig,rho);
    local c1,tau,askew,z,c3,z1;
    c1 = nonpdfstudt(nu,x,mu,sig); 
    z  = (x-mu)./sqrt(sig);
    tau = ((nu+1)./(nu+z^2))^(0.5);
    askew = (rho.*z.*tau);
    z1 = 1-cdftc(askew,nu+1);
    c3 = 2*(c1.*z1);
    retp(c3);
endp;


/* logitmod(a) : mutinomial logit model probability   

** Input:       a - K x 1  vector, where K corresponds to number of variates 
**
** Output:      w - K x 1  vector of logit model probabilities  = exp(a1)/D, exp(a2)/D, exp(a3)/D; where D = exp(a1)+exp(a2)+exp(a3) */


proc (1) = logitmod(a);
    local f; 
    f = sumc((exp(a)));
    retp(exp(a)/f);
endp;


/* { F,ga } = gradlogitmod(a) :   

 Input:       a - K x 1 vector

** Output:    ga - K x K matrix  


 a = { a1,           F = { pi1 = exp(a1)/D,     D = exp(a1)+exp(a2)+exp(a3); 
       a2,                 pi2 = exp(a2)/D,
       a3};                pi3 = exp(a3)/D };

ga = { dpi1/da1   dpi2/da1     dpi3/da1,
       dpi1/da2   dpi2/da2     dpi3/da2,
       dpi1/da3   dpi2/da3     dpi3/da3 };

So, let's say you have a function  F = f(pi1,pi2,pi3) and you have dF/dpi = { dF/dpi1,
                                                                              dF/dpi2,
                                                                              dF/dpi3 };

To get { dF/da1,      simply do ga*(dF/dpi)
         dF/da2,
         dF/da3 };  */
         
proc (2) = gradlogitmod(a);
    local f,e1,f1,d,a1,f2,f3,f4; 
    e1 = rows(a);
    f = sumc((exp(a)));
    f1 = exp(a)/f;
    d = f1.*(1-f1);
    a1 = combinate(e1,2);
    f2 = -f1[a1[.,1]].*f1[a1[.,2]];
    f3 = matndupdiagzerofull(f2);
    f4 = diagrv(f3,d);
    retp(f1,f4);
endp;



/* logsum(a) : logarithm of sum of exponentials (also labeled as logsum)   

** Input:       b - K x 1  vector, where K corresponds to number of variates 
**
** Output:      w - K x 1  vector of logsums;   

b = { b1,        w = { w1 = ln(exp(b1)),
      b2,              w2 = ln(exp(b1)+exp(b2)),
      b3 };            w3 = ln(exp(b1)+exp(b2)+exp(b3)) };  */

proc (1) = logsum(b);
    local f; 
    f = cumsumc(exp(b));
    retp(ln(f));
endp;


/* { w,gb } = gradlogsum(b) :   

 Input:       b - K x 1 vector

** Output:    gb - K x K matrix  


b =  { b1,       
       b2,                
       b3};                

w as above

gb = { dw1/db1   dw2/db1     dw3/db1,
       dw1/db2   dw2/db2     dw3/db2,
       dw1/db3   dw2/db3     dw3/db3 };

So, let's say you have a vector function F = { f1(w1,w2,w3)    and you have dF/dw =     { df1/dw1   df2/dw1   df3/dw1,
                                               f2(w1,w2,w3)                               df1/dw2   df2/dw2   df3/dw2,
                                               f3(w1,w2,w3) }                             df1/dw3   df2/dw3   df3/dw3 };

To get { df1/db1  df2/db1   df3/db1,      simply do gb*(dF/dw)
         df1/db2  df2/db2   df3/db2,
         df1/db3  df2/db3   df3/db3};  */
         
proc (2) = gradlogsum(b);
    local f1,f2,f3,f4; 
    f1 = (exp(b));
    f2 = cumsumc(f1);
    f3 = f1./(f2');
    f4 = matdup(vecdup(f3));
    retp(ln(f2),f4);
endp;


