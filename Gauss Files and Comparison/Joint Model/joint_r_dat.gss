           xup = xupord|xupcnt|xupgrp|zeros(ncont,1);
           indxcompq = ((indxup[i1,.])')|((indxupcnt[i1,.])')|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt>0 and ngrp>0 and ncont==0;
           xgg = xggord|xggcnt|xgggrp;
           xdown = xdownord|xdowncnt|xdowngrp;
           xup = xupord|xupcnt|xupgrp;
           indxcompq = ((indxup[i1,.])')|((indxupcnt[i1,.])')|((indxupgrp[i1,.])');
       elseif nord>0 and ncnt>0 and ngrp==0 and ncont>0;
           xgg = xggord|xggcnt|((ycont[i1,.])');
           xdown = xdownord|xdowncnt|zeros(ncont,1);
           xup = xupord|xupcnt|zeros(ncont,1);
           indxcompq = ((indxup[i1,.])')|((indxupcnt[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt>0 and ngrp==0 and ncont==0;
           xgg = xggord|xggcnt;
           xdown = xdownord|xdowncnt;
           xup = xupord|xupcnt;
           indxcompq = ((indxup[i1,.])')|((indxupcnt[i1,.])');
       elseif nord>0 and ncnt==0 and ngrp>0 and ncont>0;
           xgg = xggord|xgggrp|((ycont[i1,.])');
           xdown = xdownord|xdowngrp|zeros(ncont,1);
           xup = xupord|xupgrp|zeros(ncont,1);
           indxcompq = ((indxup[i1,.])')|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt==0 and ngrp>0 and ncont==0;
           xgg = xggord|xgggrp;
           xdown = xdownord|xdowngrp;
           xup = xupord|xupgrp;
           indxcompq = ((indxup[i1,.])')|((indxupgrp[i1,.])');
       elseif nord>0 and ncnt==0 and ngrp==0 and ncont>0;
           xgg = xggord|((ycont[i1,.])');
           xdown = xdownord|zeros(ncont,1);
           xup = xupord|zeros(ncont,1);
           indxcompq = ((indxup[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt==0 and ngrp==0 and ncont==0;
           xgg = xggord;
           xdown = xdownord;
           xup = xupord;
           indxcompq = ((indxup[i1,.])');
       elseif nord==0 and ncnt>0 and ngrp>0 and ncont>0;
           xgg = xggcnt|xgggrp|((ycont[i1,.])');
           xdown = xdowncnt|xdowngrp|zeros(ncont,1);
           xup = xupcnt|xupgrp|zeros(ncont,1);
           indxcompq = ((indxupcnt[i1,.])')|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord==0 and ncnt>0 and ngrp>0 and ncont==0;
           xgg = xggcnt|xgggrp;
           xdown = xdowncnt|xdowngrp;
           xup = xupcnt|xupgrp;
           indxcompq = ((indxupcnt[i1,.])')|((indxupgrp[i1,.])');
       elseif nord==0 and ncnt>0 and ngrp==0 and ncont>0;
           xgg = xggcnt|((ycont[i1,.])');
           xdown = xdowncnt|zeros(ncont,1);
           xup = xupcnt|zeros(ncont,1);
           indxcompq = ((indxupcnt[i1,.])')|zeros(ncont,1);
       elseif nord==0 and ncnt>0 and ngrp==0 and ncont==0;
           xgg = xggcnt;
           xdown = xdowncnt;
           xup = xupcnt;
           indxcompq = ((indxupcnt[i1,.])');
       elseif nord==0 and ncnt==0 and ngrp>0 and ncont>0;
           xgg = xgggrp|((ycont[i1,.])');
           xdown = xdowngrp|zeros(ncont,1);
           xup = xupgrp|zeros(ncont,1);
           indxcompq = ((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord==0 and ncnt==0 and ngrp>0 and ncont==0;
           xgg = xgggrp;
           xdown = xdowngrp;
           xup = xupgrp;
           indxcompq = ((indxupgrp[i1,.])');
       elseif nord==0 and ncnt==0 and ngrp==0 and ncont>0;
           xgg = ((ycont[i1,.])');
           xdown = zeros(ncont,1);
           xup = zeros(ncont,1);
           indxcompq = zeros(ncont,1);   
       endif;
   endif;

   seed20=seednext;

   if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
      xxj = x[rows(x)-sumnivinter+1:rows(x)];
      xxj = xxj.*onetemp;   /* sumnivinter x ncont matrix  */
      { gxxj } = gradelproduct(xxj,onetemp);     /* gxxj is sumnivinter x (sumnivinter x ncont) matrix  */
      contval = zqforlater*xcont; 
      yinterfin = yintercont[i1,.];
      yinterfin = reshape(yinterfin,totdep,sumnivinter);
      vinterfin = yinterfin*xxj*contval;      /*                yinterfin is (totdep x sumnivinter); xxj is sumnivinterx ncont;
                                                                           zqforlater is ncontxncoefcont; xcont is ncoefcontx1; 
                                                                           contval = (zqforlater*xcont) is ncontx1; 
                                                                           [yinterfin*(zqforlater*xcont)] is (hnom+hordcont)x1 vector; 
                                                                           vinterfin is [(sumc(nc)+nordcont)x1] = (wierd theta'.*xfinn')*xtilde   *(w         *alpha)   */ 
       newcov = eye(totdep);  
       newcov[.,sumc(nc)+nord+ncnt+ngrp+1:cols(newcov)]=newcov[.,sumc(nc)+nord+ncnt+ngrp+1:cols(newcov)]+yinterfin*xxj;
       _omsymmetric=0; _omdiagonal=0;
       gwtilde = yinterfin' .*. eye(cols(xxj));    /* (sumnivinter*ncont) x (totdep*ncont)  */
       gwtilde1 = gxxj*gwtilde;                     /* sumnivinter x (totdep*ncont) */
       gxfinal = gAomegaB(yinterfin,contval);      /* (sumnivinter*ncont) x (totdep*1) */ 
       gxxjfinal = gxxj*gxfinal;                    /* sumnivinter x totdep   */
       tempinter = yinterfin*xxj*zqforlater;        /* totdep x ncoefcont  */
       ginteractxcont = zeros(ncoefunord+ncoeford + ncoefgrp,(sumc(nc)+nordcont))|((tempinter)');  /* (ncoefunord+ncoeford+ncoefcont) x (totdep) matrix */ 
   
   
   
   
   
   
   
   
   
   
   
   
   
   
   
   endif;
   
   if nnom>0;
       { Msubq,indxoneq,indxeqq } = Mutodu(nnom,nc,((altchosen[i1,.])'),0,0,0,nord+ncnt+ngrp,ncont);  /* M sub q is b x a matrix ; b = nc3+nordcont ; a = sumc(nc)+nordcont  */
   else;
       Msubq = eye(nordcont);
       indxoneq = zeros(nordcont,1);
       indxeqq = zeros(nordcont,1);
       if ncont>0;
          if nordcont>ncont;
             indxeqq = zeros(nordcont-ncont,1)|ones(ncont,1);
          else;
             indxeqq = ones(ncont,1);
          endif;       
       endif;
   endif;

   Msubq = selq*Msubq;         /* For each individual, selecting only available dimensions; (M sub q is # of available dimensions-1) x a matrix; a = sumc(nc)+nordcont   */
   Vsubq = zq*xfin;    /* (sumc(nc)+nordcont)x1  */
   xisubq = (omegker);           /* xisubq is axa matrix, a = sumc(nc)+nordcont */
   if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
      Vsubq = Vsubq+vinterfin; 
      xisubq = newcov*omegker*newcov';
      _x2symmetric=1; _x1diagonal=0;_x1symmetric=0;_x2diagonal=0;_x2correlation=0; 
      { ggnewcov,ggomegker } = gbothxomegax(newcov,omegker);
      ggnewcov = ggnewcov[design1,.]|ggnewcov[designcont,.];      /* [totdep*(ncont)] x (a*(a+1)/2); a = totdep */  
      _OMEGACORR=0; _XOMEGAXT=0;
      gcovker = gomegxomegax(Msubq*newcov*convdutou);  /* convdutou is a x b matrix; gcovker is [b*(b+1)/2]x[h*(h+1)/2]; a=(sumc(nc)+nordcont), b=(nc3+nordcont) */
      gxisubq = gomegxomegax(Msubq);                   /* [a*(a+1)/2]X[h*(h+1)/2]; a=totdep, b=(nc3+nordcont) */
      ggnewcovtemp = ggnewcov*gxisubq;                  /* [totdep*ncont] x [h*(h+1)/2] matrix */
   else;
      gcovker = gomegxomegax(Msubq*convdutou);         /* [b*(b+1)/2]X[h*(h+1)/2]; a=(totdep), b=(nc3+nordcont) */
   endif;

   if nord>0;
       indxoneq[nc3+1:nc3+nord] = (indxsing[i1,.])';
   endif;
   if ncnt>0;
       indxoneq[nc3+nord+1:nc3+nord+ncnt] = (indxsingcnt[i1,.])';
   endif;
   if ngrp>0;
       indxoneq[nc3+nord+ncnt+1:nc3+nord+ncnt+ngrp] = (indxsinggrp[i1,.])';
   endif;     
   
   xgg = selq*xgg; xdown = selq*xdown;  xup = selq*xup;  indxoneq=selq*indxoneq;  indxcompq = selq*indxcompq;  indxeqq = selq*indxeqq;         
   Bsubq = Msubq*((Vsubq));    /* B sub q is (b)x1 ; M sub q is h x a matrix (h=b only when all alternatives are available in nominal and all non-nominal outcomes are available); b = nc3+nordcont ; a = sumc(nc)+nordcont  */
   newxisubq = Msubq*xisubq*Msubq';
   _covarr = 1;
   if ntotcoef==0;
      Bsubq = zeros(rows(newxisubq),1);
   endif;
   { P,gBsubq,gnewxisubq,gxg,gxdown,gxup,sss } = gradpdfrectn(Bsubq,newxisubq,xgg,xdown,xup,seed20,indxoneq,indxcompq,indxeqq);
   /* gBsubq - (h=# of available alternatives in nominal plus # of available non-nominal variables) x 1 vector */
   /* gnewxisubq - [(h)*(h+1)/2] x 1 vector  vector */
   gVsubq = Msubq';                                                      /* (totdep))x (h) matrix; i.e. a x h matrix */
   gxmu = zq';                                                           /* (ncoefunord+ncoeford+nceofcnt+ncoefgrp+ncoefcont) x (totdep)   */
   gxmufinal = gxmu*gVsubq*gBsubq;                                       /* (ncoefunord+ncoeford+ncoefcnt+ncoefgrp+ncoefcont) x 1 vector */
   if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
       gxmuintercont = gxxjfinal*gVsubq*gBsubq;                          /* [(sumnivinter)x 1 vector */
       gxmufinal = gxmufinal+ginteractxcont*gvsubq*gBsubq;               /* (ncoefunord+ncoeford+ncoefcnt+ncoefgrp+ncoefcont) x 1 vector */
       gwierdtilde = ggnewcovtemp*gnewxisubq;    /*   [totdep*ncont] x 1 vector */
       gwierdtilde1 = gwtilde1*gwierdtilde;   /* [sumnivinter] x 1 vector  */ 
       gxmuintercont = gxmuintercont+gwierdtilde1;  /* [(sumnivinter)x 1 vector */   
   endif;

   if nord>0;
       gxthreshord = selordqq*gxg[hunordq+1:hunordq+hordq];                                    /* All three below are nord X 1 vectors; hordq=nord if all ordered outcomes are available for individual */
       gxdowno = selordqq*gxdown[hunordq+1:hunordq+hordq];
       gxupo = selordqq*gxup[hunordq+1:hunordq+hordq];
       gxggord=((prepsingdown*maskupq+prepsingup*maskdownq)')*gxthreshord;
       gxdownord = ((prepdoub*maskdownq)')*gxdowno;
       gxupord = ((prepdoub*maskupq)')*gxupo;
       gxthreshfin = gxggord+gxdownord+gxupord;  /* Accumulate across all observations and remove first and last elements (-inf and +inf) */
   endif;

   gordthreshfin={};
   for j(1,nord,1);
       gthreshfini = gxthreshfin[nummask1[j]+1:nummask1[j+1]];
       gthreshfini = gthreshfini[2:ncord[j]];
       gordthreshfin = gordthreshfin|gthreshfini;
   endfor;
   if nord>0;
      gordfin = gordthreshfin|gxmufinal[ncoefunord+1:ncoefunord+ncoeford];
   else;
      gordfin = {};
   endif;
   
   if ncnt>0;
       gxthreshc = selcntqq*gxg[hunordq+hordq+1:hunordq+hordq+hcntq];                                    /* All three below are nord X 1 vectors; hordq=nord if all ordered outcomes are available for individual */
       gxdownc = selcntqq*gxdown[hunordq+hordq+1:hunordq+hordq+hcntq];
       gxupc = selcntqq*gxup[hunordq+hordq+1:hunordq+hordq+hcntq];
       gxggcnt=((prepsingdowncnt*maskupcntq+prepsingupcnt*maskdowncntq)')*gxthreshc;                   /* nummaskcnt x ncnt matrix */
       gxdowncnt = ((prepdoubcnt*maskdowncntq)')*gxdownc;                                               /* nummaskcnt x ncnt matrix */
       gxupcnt = ((prepdoubcnt*maskupcntq)')*gxupc;                                                     /* nummaskcnt x ncnt matrix */
       gxthreshfincnt1 = gxggcnt+gxdowncnt+gxupcnt;  /* nummaskcnt (sumc(ncntmax[j]+2) x 1 gradients with respect to all count thresholds (psi sub k thresholds)*/
       ytempcnt = yifincntgamma[i1,.];
       ytempcnt1 = reshape(ytempcnt,ncnt,ncoefcntgamma);
   endif;

   gxthetafincnt = {};
   gxlambdafincnt = {};
   gxalphafincnt = {};
   for j(1,ncnt,1);
       gxthreshfincnt = (gxthreshfincnt1[nummaskcnt1[j]+1:nummaskcnt1[j+1]]);   /* (ncntmax[j]+2) x 1 vector  */
       gxthreshfincnt = gxthreshfincnt[2:rows(gxthreshfincnt)];                  /* (ncntmax[j]+1) x 1 vector */
       if numcntthresh[j]>0;
          gxalphafincnt = gxalphafincnt|((galphavector1[ncntthresh1[j]+1:ncntthresh1[j+1],nummaskcntadd11[j]+1:nummaskcntadd11[j+1]])*gxthreshfincnt);
       else;
          gxalphafincnt = {}; 
       endif;
       gxthetafincnt = gxthetafincnt|((gthetafull[i1,nummaskcntadd11[j]+1:nummaskcntadd11[j+1]])*gxthreshfincnt);
       gxlambdafincnt = gxlambdafincnt|((glambdafull[i1,nummaskcntadd11[j]+1:nummaskcntadd11[j+1]])*gxthreshfincnt);      
   endfor;
 
   if ncnt>0;
      gxlambdafinfincnt = ytempcnt1'*gxlambdafincnt;
      if numcntmain>0;
         gcntfin = gxalphafincnt|gxthetafincnt|gxlambdafinfincnt|gxmufinal[ncoefunord+ncoeford+1:ncoefunord+ncoeford+ncoefcntmain];
      else;
         gcntfin = gxalphafincnt|gxthetafincnt|gxlambdafinfincnt;
      endif;
   else;
      gcntfin = {};
   endif;
   
   if ngrp>0;
       ggrpfin = gxmufinal[ncoefunord+ncoeford+ncoefcntmain+1:ncoefunord+ncoeford+ncoefcntmain+ncoefgrp];
   else;
       ggrpfin = {};
   endif;
 
   if ncont>0;
       gcontfin = gxmufinal[ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+1:ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+ncoefcont];
   else;
       gcontfin = {};
   endif;
   
   gfinW1 = gW1*gcovker*gnewxisubq;                                   /* b x 1 vector  */
   if nscale>0;
       gfinW1 = gfinW1[indxW];                                           /* number of distinct scale parameters x 1 vector */
   else;
       gfinw1 = {};
   endif;
   gfinstar = gtempstar*gcovker*gnewxisubq;                          /* [b x (b+1)/2] x 1 vector */
   
   Pcomp = pcomp|P;
   if nnom>0;
       g = ((gxmufinal[1:ncoefunord])')~(gordfin')~(gcntfin')~(ggrpfin')~(gcontfin')~(gfinstar')~(gfinW1');
   elseif nnom==0;
       g = (gordfin')~(gcntfin')~(ggrpfin')~(gcontfin')~(gfinstar')~(gfinW1');
   endif;

   if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
       g = g~gxmuintercont';
   endif;
   
   gfinal = gfinal|g;
   seednext=sss;
endfor;

w=zeros(e1,1);
if pcomp <= w;
   pcomp=pcomp-((pcomp.<=w).*(pcomp-0.0001));
endif;
g1 = gfinal./pcomp;
retp(dta[.,_weight].*g1);
endp;


proc lpr1(x,dta);
local e1,p0,popass,vunordfin,altchosen,xfinunord,yifinunord,xfinord,yifinord,yifincont,i,xunord,v2unord,j,j1,vunord,xthresh,xord,xcont,xker,xscal,
indxrearrang,indxW,W1,C,cholker,omegastar, covker,omegker,tufin,tlfin,vordfin,xordi,xthreshi,xconti,tu,tl,yiordi,vord,
vcontfin,yiconti,vcont,v,xlow,xup,seednext,seed20,vsubq,xisubq,Msubq,indxoneq,indxeqq,bsubq,newxisubq,P,Pcomp,sss,w,final,
indxcomptemp,indxonetemp,indxlotemp,indxuptemp,indxdoubtemp,indxcompq,xgg,xggtemp;
local xfin,zq,maskdownq,maskupq,ytempunord,ytempord,ytempcont,prepsing,prepsingdown,prepsingup,prepdoub;
local xdownord,xupord,capomegaindx,xggord,xdown;
local aar1,aar2,aar3,aar4,aar5,aar6,aar7,aar8,aarn1,aarn2,aarn3,aarn4,aarn5,aarn6,aarn7,aarn8,tempinter;
local xxj,l,xfinn,xnom,ma,xxj1,xx1,k,xfinal,ynominter,ynominterfin,yinterfin,yordcontinter,yordcontinterfin,vinterfin,newcov,zqforlater;
local xordcont,threshtmp,selq,newMsubq,ytempcntmain,prepdoubcnt,prepdoubgrp;
local xthreshaddcnt,xthreshtmpaddcnt,xfincntgamma,xfincntmain,xfincnttheta,yifincntgamma,yifincntmain,xthreshcntall,ytempcnt1,ytempcnt;
local cntgamma,cntlambda,xthreshcnt,tempmatrix,alphavector,countvector,xthreshcnti,maskdowncntq,maskupcntq,prepsingcnt,prepsingdowncnt;
local prepsingupcnt,xdowncnt,xupcnt,xggcnt,yifingrp,xgrp,ytempgrp,maskdowngrpq,maskupgrpq,prepsinggrp,prepsingdowngrp,prepsingupgrp,xdowngrp,xupgrp,xgggrp;
local alphavector1,alphavector5,alphavectortemp;
    
e1 = rows(dta);
p0 = zeros(e1,1);
popass = dta[.,ivobsid];
       
if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
   xxj = x[rows(x)-sumnivinter+1:rows(x)];
   xxj = xxj.*onetemp;   /* sumnivinter x ncont matrix  */
endif;

/* Obtaining index of chosen alternative in nominal variable */

altchosen = {};
xfinunord = {};
yifinunord={};
for i(1,nnom,1);
    xfinunord = xfinunord|x[numunord1[i]+1:numunord1[i+1]];
    yifinunord = yifinunord~((yiunord[.,nivunord1[i]+1:nivunord1[i+1]]));
    altchosen = altchosen~maxindc(((yunord[.,nc2[i]+1:nc2[i+1]])'));
endfor;

if nord>0;
  xfinord = x[ncoefunord+nthresh+1:ncoefunord+nthresh+ncoeford];
  yifinord = yiord;
  xthresh={};
  threshtmp = x[ncoefunord+1:ncoefunord+nthresh];
  for i(1,nord,1);
    xthreshi = minfin|threshtmp[nthresh1[i]+1:nthresh1[i+1]]|infin;
    xthresh=xthresh|xthreshi;   
  endfor; 
else;
  xfinord = {};
endif;

if ncnt>0;
  xthreshaddcnt={};     /* These are additional threshold values for spikes at specific count values */
  if ncntthresh>0;
     xthreshtmpaddcnt = x[ncoefunord+nthresh+ncoeford+1:ncoefunord+nthresh+ncoeford+ncntthresh];   /* additional threshold values */
  endif;
  xfincnttheta = x[ncoefunord+nthresh+ncoeford+ncntthresh+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt];  /* theta parameters */
  xfincntgamma = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcntgamma]; /* gamma parameters in threshold */
  if numcntmain>0;
     xfincntmain = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcntgamma+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt];  /* parameters in main latent count equation */
     yifincntmain = yicntmain;      
  else;
     xfincntmain={};
     yifincntmain = {};
  endif;
  
  alphavector1 = {};
  for j(1,ncnt,1);
     if numcntthresh[j]>0;
        tempmatrix = zeros(nccntmax[j]+1,numcntthresh[j]);   /* if 0,1,2,3,4 are counts, computing alphaadd1,alphaadd2,alphaadd3, alphaadd4, and later will add alphaadd0=0 */
        tempmatrix[((indalpha[j,1:numcntthresh[j]])'),.]=eye(numcntthresh[j]);
        alphavectortemp = tempmatrix*xthreshtmpaddcnt[ncntthresh1[j]+1:ncntthresh1[j+1]];     /* (nccntmax[j]+1)x 1 vector  */
        alphavector5 = cumsumc(alphavectortemp);
        alphavector1 = alphavector1|alphavector5;
     else;
        alphavector1 = alphavector1|seqa(0,0,nccntmax[j]+1);
     endif;
  endfor;
  
  yifincntgamma = yicntgamma;
  xthreshcntall = {};
  for i(1,e1,1);
     ytempcnt = yifincntgamma[i,.];
     ytempcnt1 = reshape(ytempcnt,ncnt,ncoefcntgamma);
     cntgamma = ytempcnt1*xfincntgamma;               /* ncnt x 1 vector */
     cntlambda = exp(cntgamma);
     xthreshcnt={};
      
     for j(1,ncnt,1);
        alphavector = alphavector1[nummaskcntadd11[j]+1:nummaskcntadd11[j+1]];      /* alpha sub -1|alpha sub 0|alpha sub 1|.....|alpha sub (maxcount); (maxcount+2)x1 vector  */
        countvector = seqa(0,1,nccntmax[j]+1);          /* (maxcount+1) x 1 (including zero count) vector */ 
        xthreshcnti = counthresh(cntlambda[j],xfincnttheta[j],countvector,alphavector,_poisson[j]); 
        xthreshcnt = xthreshcnt|(minfin|xthreshcnti);      /* [sum over all i (maxcount for each i+2)]x1 vector */        
     endfor;
     xthreshcntall = xthreshcntall~xthreshcnt;       /* [sum over all i (maxcount for each i+2)] x e1 matrix, each column being set of thresholds (across all counts) for a specific individual */
  endfor;
else;
  xfincntmain = {};
  xfincnttheta = {};
  xfincntgamma = {};
endif;

if ngrp>0;
   yifingrp = yigrp;
   xgrp = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp]; 
else;
   xgrp = {};
endif;

if ncont>0;
   yifincont = yicont;
   xcont = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+ncoefcont];
else;
   xcont = {};
endif;

if ntotcoef>0;
   xfin = xfinunord|xfinord|xfincntmain|xgrp|xcont;   /*  (ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+ncoefcont)x1 vector */ 
else;
   xfin = 0;
endif;

xker = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+ncoefcont+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+ncoefcont+nker];

