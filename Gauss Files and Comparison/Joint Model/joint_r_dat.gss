else;
   xscal=0;
endif;

{ indxrearrang,indxW, W1,C } = poscor(xker,xscal,nnom,nc,0,0,nord+ncnt,ncont+ngrp);  /* unfortunately, at start values, C has some baggage imaginary parts, is innocuous and is only to help estimation; see com/jointcsmodels/testing; so removing */

if popass[1]==1;
   seednext=seed10;
endif;

omegastar = matndupdiagonefull(xker);
covker = W1*omegastar*W1;
omegker=convdutou*(covker)*convdutou';


Pcomp={};
for i1(1,e1,1);
