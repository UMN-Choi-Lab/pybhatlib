      maskdownq[j,nummask1[j]+1:nummask1[j+1]]=maskdown[i1,nummask1[j]+1:nummask1[j+1]];
      maskupq[j,nummask1[j]+1:nummask1[j+1]]=maskup[i1,nummask1[j]+1:nummask1[j+1]];
      xdownord = prepdoub*maskdownq*xthresh;
      xupord= prepdoub*maskupq*xthresh;
      xggord = (prepsingdown*maskupq+prepsingup*maskdownq)*xthresh;
   endfor;

   if ncnt>0;
      selcntqq = ((selq[hunordq+hordq+1:hunordq+hordq+hcntq,nc3+nord+1:nc3+nord+ncnt])');   /* ncnt x hcntq matrix  */
      maskdowncntq = zeros(ncnt,nummaskcnt);                                /* ncnt x [(total number of count values+1) across all count outcomes ] */
      maskupcntq = zeros(ncnt,nummaskcnt);
      prepsingcnt=(diagrv(zeros(ncnt,ncnt),((indxsingcnt[i1,.])')));          /* All four prep matrices are nord by nord matrices */
      prepsingdowncnt = (diagrv(zeros(ncnt,ncnt),((indxdowncnt[i1,.])')));
      prepsingupcnt = (diagrv(zeros(ncnt,ncnt),((indxupcnt[i1,.])')));
