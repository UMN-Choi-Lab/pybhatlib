   endif;

   for j(1,ncnt,1);
       maskdowncntq[j,nummaskcnt1[j]+1:nummaskcnt1[j+1]]=maskdowncnt[i1,nummaskcnt1[j]+1:nummaskcnt1[j+1]];
       maskupcntq[j,nummaskcnt1[j]+1:nummaskcnt1[j+1]]=maskupcnt[i1,nummaskcnt1[j]+1:nummaskcnt1[j+1]];
       xdowncnt = prepdoubcnt*maskdowncntq*xthreshcntall[.,i1];
       xupcnt= prepdoubcnt*maskupcntq*xthreshcntall[.,i1];
