       selgrpqq = ((selq[hunordq+hordq+hcntq+1:hunordq+hordq+hcntq+hgrpq,nc3+nord+ncnt+1:nc3+nord+ncnt+ngrp])');   /* ngrp x hgrpq matrix  */
       ytempgrp = yigrp[i1,.];
