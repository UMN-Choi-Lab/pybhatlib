   else;
       Msubq = eye(nordcont);
       indxoneq = zeros(nordcont,1);
       indxeqq = zeros(nordcont,1);
       if ncont>0;
          if nordcont>ncont;
             indxeqq = zeros(nordcont-ncont,1)|ones(ncont,1);
          else;
             indxeqq = ones(ncont,1);
          endif;       
       endif;      
   endif;

   Vsubq = zq*xfin;    /* (sumc(nc)+nordcont)x1  */
   xisubq = (omegker);           /* xisubq is axa matrix, a = sumc(nc)+nordcont */
   if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
      Vsubq = Vsubq+vinterfin; 
      xisubq = newcov*omegker*newcov';
   endif;

   if nord>0;
       indxoneq[nc3+1:nc3+nord] = (indxsing[i1,.])';
   endif;
   if ncnt>0;
       indxoneq[nc3+nord+1:nc3+nord+ncnt] = (indxsingcnt[i1,.])';
   endif;
   if ngrp>0;
       indxoneq[nc3+nord+ncnt+1:nc3+nord+ncnt+ngrp] = (indxsinggrp[i1,.])';
   endif;   


   xgg = selq*xgg; xdown = selq*xdown;  xup = selq*xup;  indxoneq=selq*indxoneq;  indxcompq = selq*indxcompq;  indxeqq = selq*indxeqq;      
   
   Msubq = selq*Msubq;         /* For each individual, selecting only available dimensions; M sub q is (h=# of available dimensions-1) x a matrix; a = sumc(nc)+nordcont   */
   Bsubq = Msubq*((Vsubq));    /* B sub q is # of available dimensions (h=# of available alternatives across all nominal variables-1+# of available non-nominal variables) x 1  */
   newxisubq = Msubq*xisubq*Msubq';  /* newxisubq is hxh matrix   */
   if ntotcoef==0;
      Bsubq = zeros(rows(newxisubq),1);
   endif;
   { P,sss } = pdfrectn(Bsubq,newxisubq,xgg,xdown,xup,seed20,indxoneq,indxcompq,indxeqq);
   Pcomp = pcomp|P;
   seednext=sss;
endfor;

w=zeros(e1,1);
if pcomp > w;
   final=ln(pcomp);
else;
   print "yes";
   final=ln(pcomp-((pcomp.<=w).*(pcomp-0.0001)));
endif;
retp(dta[.,_weight].*final);
endp;



proc lgd1(x,dta);
local e1,p0,popass,vunordfin,altchosen,xfinunord,yifinunord,xfinord,yifinord,yifincont,i,xunord,v2unord,j,j1,vunord,xthresh,xord,xcont,xker,xscal,
indxrearrang,indxW,W1,C,cholker,omegastar, covker,omegker,tufin,tlfin,vordfin,xordi,xthreshi,xconti,tu,tl,yiordi,vord,
vcontfin,yiconti,vcont,v,xlow,xup,seednext,seed20,vsubq,xisubq,Msubq,indxoneq,indxeqq,bsubq,newxisubq,P,Pcomp,sss,w,final,
indxcomptemp,indxonetemp,indxlotemp,indxuptemp,indxdoubtemp,indxcompq,xgg,xggtemp;
local xfin,zq,maskdownq,maskupq,ytempunord,ytempord,ytempcont,prepsing,prepsingdown,prepsingup,prepdoub;
local xdownord,xupord,capomegaindx,xggord,xdown;
local aar1,aar2,aar3,aar4,aar5,aar6,aar7,aar8,aarn1,aarn2,aarn3,aarn4,aarn5,aarn6,aarn7,aarn8,tempinter;
local xxj,l,xfinn,xnom,ma,xxj1,xx1,k,xfinal,ynominter,ynominterfin,yinterfin,yordinter,yordcontinter,yordcontinterfin,yordinterfin,vinterfin,newcov;
local xordcont,threshtmp,contval,selq,gordthreshfin,selunordq,selordq,selcontq,selordqq,newMsubq,hunordq,hordq,hcontq,ytempcntmain,prepdoubcnt,prepdoubgrp;
local xthreshaddcnt,xthreshtmpaddcnt,xfincntgamma,xfincntmain,xfincnttheta,yifincntgamma,yifincntmain,xthreshcntall,ytempcnt1,ytempcnt;
local cntgamma,cntlambda,xthreshcnt,tempmatrix,alphavector,countvector,xthreshcnti,maskdowncntq,maskupcntq,prepsingcnt,prepsingdowncnt;
local prepsingupcnt,xdowncnt,xupcnt,xggcnt,yifingrp,xgrp,ytempgrp,maskdowngrpq,maskupgrpq,prepsinggrp,prepsingdowngrp,prepsingupgrp,xdowngrp,xupgrp,xgggrp;
local gW1,gomegastar,gcholcor,gker,gtempstar,gfinal,
gBsubq,gnewxisubq,gxg,gxdown,gxup,gVsubq,gxmu,gxmufinal,gxthreshord,gxggord,gxdownord,gxupord,gxthreshfin,
gxisubq,gfinW1,gfinstar,gordfin,gthreshfini,gxordi,g,g1,glambda,gtheta,xthreshcntfulli,gxggcnt;
local gxxj,gwtilde,gwtilde1,gxxjfinal,ginteractxcont,gxfinal,ggnewcov,ggomegker,ggnewcovtemp,gcovker,gxmuintercont,gwierdtilde,gwierdtilde1,zqforlater;
local newsdoubstar,numact,actindx,inactindx,alphavector1,alphavector5,alphavectortemp,gxthreshfincnt1,gcontfin,gscal;
local selcntq,selgrpq,hcntq,hgrpq,selcntqq,selgrpqq,selcontqq,galphavector1,galphavector5,glambdafull,gthetafull,glambdafullj,gthetafullj;
local gxthreshc,gxdowno, gxupo, gxdownc,gxupc,gxdowncnt,gxupcnt,gxthreshfincnt,gxthetafincnt,gxlambdafincnt,gxalphafincnt,gxlambdafinfincnt,gcntfin,ggrpfin;
    
e1 = rows(dta);
p0 = zeros(e1,1);
popass = dta[.,ivobsid];
       
if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
   xxj = x[rows(x)-sumnivinter+1:rows(x)];
   xxj = xxj.*onetemp;   /* sumnivinter x ncont matrix  */
endif;

/* Obtaining index of chosen alternative in nominal variable */

altchosen = {};
xfinunord = {};
yifinunord={};
for i(1,nnom,1);
    xfinunord = xfinunord|x[numunord1[i]+1:numunord1[i+1]];
    yifinunord = yifinunord~((yiunord[.,nivunord1[i]+1:nivunord1[i+1]]));
    altchosen = altchosen~maxindc(((yunord[.,nc2[i]+1:nc2[i+1]])'));
endfor;

if nord>0;
  xfinord = x[ncoefunord+nthresh+1:ncoefunord+nthresh+ncoeford];
  yifinord = yiord;
  xthresh={};
  threshtmp = x[ncoefunord+1:ncoefunord+nthresh];
  for i(1,nord,1);
    xthreshi = minfin|threshtmp[nthresh1[i]+1:nthresh1[i+1]]|infin;
    xthresh=xthresh|xthreshi;   
  endfor; 
else;
  xfinord = {};
endif;

if ncnt>0;
  xthreshaddcnt={};     /* These are additional threshold values for spikes at specific count values */
  if ncntthresh>0;
     xthreshtmpaddcnt = x[ncoefunord+nthresh+ncoeford+1:ncoefunord+nthresh+ncoeford+ncntthresh];   /* additional threshold values */
  endif;
  xfincnttheta = x[ncoefunord+nthresh+ncoeford+ncntthresh+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt];  /* theta parameters */
  xfincntgamma = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcntgamma]; /* gamma parameters in threshold */
  if numcntmain>0;
     xfincntmain = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcntgamma+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt];  /* parameters in main latent count equation */
     yifincntmain = yicntmain;
  else;
     xfincntmain={};
     yifincntmain = {};
  endif;
  alphavector1 = {};
  if ncntthresh>0;
    galphavector1 = zeros(ncntthresh,nummaskcntadd1);    /* total number of alpha parameters across count variables x sumc(nccntmax+1) */
  endif;  
  for j(1,ncnt,1);
     if numcntthresh[j]>0;
        tempmatrix = zeros(nccntmax[j]+1,numcntthresh[j]);   /* if 0,1,2,3,4 are counts, computing alphaadd1,alphaadd2,alphaadd3, alphaadd4, and later will add alphaadd0=0 */
        tempmatrix[((indalpha[j,1:numcntthresh[j]])'),.]=eye(numcntthresh[j]);
        alphavectortemp = tempmatrix*xthreshtmpaddcnt[ncntthresh1[j]+1:ncntthresh1[j+1]];     /* (nccntmax[j]+1)x 1 vector  */
        alphavector5 = cumsumc(alphavectortemp);
        galphavector5 = gcumsumc(alphavectortemp);
        galphavector1[ncntthresh1[j]+1:ncntthresh1[j+1],nummaskcntadd11[j]+1:nummaskcntadd11[j+1]]=galphavector5;
                   /* ncntthresh x sumc((maxcount[j]+1) = ncntthresh x nummaskcntadd1 */
        alphavector1 = alphavector1|alphavector5;
     else;
        alphavector1 = alphavector1|seqa(0,0,nccntmax[j]+1);    
     endif;
  endfor;
  yifincntgamma = yicntgamma;
  xthreshcntall = {};
 
  glambdafull = {};
  gthetafull = {};
  for i(1,e1,1);
     ytempcnt = yifincntgamma[i,.];
     ytempcnt1 = reshape(ytempcnt,ncnt,ncoefcntgamma);
     cntgamma = ytempcnt1*xfincntgamma;               /* ncnt x 1 vector */
     cntlambda = exp(cntgamma);
     xthreshcnt={};
     glambdafullj={};  gthetafullj={};  
     for j(1,ncnt,1);
        alphavector = alphavector1[nummaskcntadd11[j]+1:nummaskcntadd11[j+1]];      /* alpha sub -1|alpha sub 0|alpha sub 1|.....|alpha sub (maxcount); (maxcount+2)x1 vector  */
        countvector = seqa(0,1,nccntmax[j]+1);          /* (maxcount+1) x 1 (including zero count) vector */ 
        { xthreshcnti,glambda,gtheta } = gcounthresh(cntlambda[j],xfincnttheta[j],countvector,alphavector,_poisson[j]);
        if _poisson[j]==1;
            gtheta = zeros(1,rows(countvector));
        endif;
        glambdafullj = glambdafullj~(glambda*cntlambda[j]);     /* 1 x [sumc(nccntmax[j]+1)]=1 x nummaskcntadd1 vector */
        xthreshcntfulli = minfin|xthreshcnti;
        xthreshcnt = xthreshcnt|(xthreshcntfulli);      /* [sum over all i (maxcount for each i+2)]x1 vector =[sumc(nccntmax[j]+2]x 1 = nummaskcnt1 x 1 vector */        
        gthetafullj = gthetafullj~gtheta;         /* 1 x [sumc(nccntmax[j]+1)]=1 x nummaskcntadd1 vector */            
     endfor;
     glambdafull = glambdafull|glambdafullj;     /* glambdafull and gthetafull are e1 x nummasckcntadd1 matrices */
     gthetafull = gthetafull|gthetafullj;       
     xthreshcntall = xthreshcntall~xthreshcnt;       /* [sum over all i (maxcount for each i+2)] x e1 matrix, each column being set of thresholds (across all counts) for a specific individual */
  endfor;
else;
  xfincntmain = {};
  xfincnttheta = {};
  xfincntgamma = {};
endif;

if ngrp>0;
   yifingrp = yigrp;
   xgrp = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp]; 
else;
   xgrp = {};
endif;

if ncont>0;
   yifincont = yicont;
   xcont = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+ncoefcont];
else;
   xcont = {};
endif;

if ntotcoef>0;
   xfin = xfinunord|xfinord|xfincntmain|xgrp|xcont;   /*  (ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+ncoefcont)x1 vector */ 
else;
   xfin = 0;
endif;

xker = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+ncoefcont+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+ncoefcont+nker];

if nscale>0;
   xscal = x[ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+ncoefcont+nker+1:ncoefunord+nthresh+ncoeford+ncntthresh+ncnt+ncoefcnt+ncoefgrp+ncoefcont+nker+nscale];
else;
   xscal=0;
endif;

{ indxrearrang,indxW, W1,C } = poscor(xker,xscal,nnom,nc,0,0,nord+ncnt,ncont+ngrp);  /* unfortunately, at start values, C has some baggage imaginary parts, is innocuous and is only to help estimation; see com/jointcsmodels/testing; so removing */

omegastar = matndupdiagonefull(xker);
covker = W1*omegastar*W1;
omegker=convdutou*(covker)*convdutou';   /* [sumc(nc)+nordcont] x [sumc(nc)+nordcont]  */

_OMEGACORR=0; _XOMEGAXT=0;
{ gW1,gomegastar } = gradcovcor(Covker);                           /* gW1 is [b] X [a*(a+1)/2]; gomegastar is [b*(b+1)/2] X [a*(a+1)/2]; a=[sumc(nc)+nordcont],  b=(nc3+nordcont) */

/*
if _spher;
  if _correst==0;
     { gker,gscal } = gcholspherunconstcorscaled(omegastar,scal);        //gker is [(totdim*(totdim-1)/2] x [(totdim*(totdim-1)/2] matrix 
  elseif _correst==1;
     { newsdoubstar,gker,capomegaindx,numact,actindx,inactindx  } = grestcholspherunconstcorscaled(omegastar,correst,scal);
  endif;         
else;
  if _correst==0;
     { gker,gscal } = gnewcholparmcorscaled(omegastar,scal);
  elseif _correst==1;
     { newsdoubstar,gker,capomegaindx,numact,actindx,inactindx  } = grestcholunconstcorscaled(omegastar,correst,scal);
  endif;
endif;
*/ 

gtempstar = gomegastar;

if popass[1]==1;
   seednext=seed10;
endif;

Pcomp={};
gfinal = {};
for i1(1,e1,1);
   selq={};
   if nnom>0;
      selunordq = delif(((yavunord[i1,.])'),((yunord[i1,.])'));   /* Helpful later to use only available alternatives in each nominal variable for each individual  */
      selq = selq|selunordq;
      hunordq = sumc(selunordq);
   elseif nnom==0;
      hunordq = 0;
   endif;
   if nord>0 and ncnt>0 and ngrp>0 and ncont>0;       
      selordq=((yavord[i1,.])');   selcntq=((yavcnt[i1,.])');  selgrpq = ((yavgrp[i1,.])'); selcontq=((yavcont[i1,.])');         /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selordq|selcntq|selgrpq|selcontq;
      hordq = sumc(selordq);  hcntq = sumc(selcntq);   hgrpq = sumc(selgrpq);   hcontq = sumc(selcontq);
   elseif nord>0 and ncnt>0 and ngrp>0 and ncont==0;       
      selordq=((yavord[i1,.])');   selcntq=((yavcnt[i1,.])');  selgrpq = ((yavgrp[i1,.])');         /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selordq|selcntq|selgrpq;
      hordq = sumc(selordq);  hcntq = sumc(selcntq);  hgrpq = sumc(selgrpq);    hcontq=0;
   elseif nord>0 and ncnt>0 and ngrp==0 and ncont>0;       
      selordq=((yavord[i1,.])'); selcntq=((yavcnt[i1,.])'); selcontq = ((yavcont[i1,.])');                            /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selordq|selcntq|selcontq;
      hordq = sumc(selordq);  hcntq = sumc(selcntq);   hcontq = sumc(selcontq);    hgrpq=0;
   elseif nord>0 and ncnt>0 and ngrp==0 and ncont==0;       
      selordq=((yavord[i1,.])'); selcntq=((yavcnt[i1,.])');
      selq = selq|selordq|selcntq;
      hordq = sumc(selordq);  hcntq = sumc(selcntq);   hgrpq=0;  hcontq=0;
   elseif nord>0 and ncnt==0 and ngrp>0 and ncont>0;       
      selordq=((yavord[i1,.])'); selgrpq=((yavgrp[i1,.])'); selcontq=((yavcont[i1,.])');                            /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selordq|selgrpq|selcontq;
      hordq = sumc(selordq);  hgrpq = sumc(selgrpq);   hcontq = sumc(selcontq);   hcntq=0;      
   elseif nord>0 and ncnt==0 and ngrp>0 and ncont==0;       
      selordq=((yavord[i1,.])'); selgrpq=((yavgrp[i1,.])');
      selq = selq|selordq|selgrpq;
      hordq = sumc(selordq); hgrpq = sumc(selgrpq);   hcntq=0;  hcontq=0;
   elseif nord>0 and ncnt==0 and ngrp==0 and ncont>0;       
      selordq=((yavord[i1,.])'); selcontq=((yavcont[i1,.])');                            /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selordq|selcontq;
      hordq = sumc(selordq); hcontq = sumc(selcontq);   hcntq=0; hgrpq=0;
   elseif nord>0 and ncnt==0 and ngrp==0 and ncont==0;       
      selordq = ((yavord[i1,.])');
      selq = selq|selordq;
      hordq = sumc(selordq);   hcntq=0; hgrpq=0;  hcontq=0;
   elseif nord==0 and ncnt>0 and ngrp>0 and ncont>0;       
      selcntq=((yavcnt[i1,.])');  selgrpq = ((yavgrp[i1,.])'); selcontq=((yavcont[i1,.])');         /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selcntq|selgrpq|selcontq;   
      hcntq = sumc(selcntq);   hgrpq = sumc(selgrpq);   hcontq = sumc(selcontq);   hordq=0;
   elseif nord==0 and ncnt>0 and ngrp>0 and ncont==0;       
      selcntq=((yavcnt[i1,.])');  selgrpq = ((yavgrp[i1,.])');         /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selcntq|selgrpq;
      hcntq = sumc(selcntq);   hgrpq=sumc(selgrpq);   hordq=0;   hcontq=0;
   elseif nord==0 and ncnt>0 and ngrp==0 and ncont>0;       
      selcntq=((yavcnt[i1,.])'); selcontq = ((yavcont[i1,.])');                            /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selcntq|selcontq;
      hcntq = sumc(selcntq);   hcontq = sumc(selcontq);  hordq=0;   hgrpq=0;
   elseif nord==0 and ncnt>0 and ngrp==0 and ncont==0;       
      selcntq=((yavcnt[i1,.])');
      selq = selq|selcntq;
      hcntq = sumc(selcntq);   hordq=0; hgrpq=0; hcontq=0;
   elseif nord==0 and ncnt==0 and ngrp>0 and ncont>0;       
      selgrpq=((yavgrp[i1,.])'); selcontq=((yavcont[i1,.])');                            /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selgrpq|selcontq;
      hgrpq = sumc(selgrpq);   hcontq = sumc(selcontq);    hordq=0; hcntq=0;   
   elseif nord==0 and ncnt==0 and ngrp>0 and ncont==0;       
      selgrpq=((yavgrp[i1,.])');
      selq = selq|selgrpq;
      hgrpq = sumc(selgrpq);  hordq=0; hcntq=0; hcontq=0;
   elseif nord==0 and ncnt==0 and ngrp==0 and ncont>0;       
      selcontq=((yavcont[i1,.])');                            /* (nc3+nordcont) x 1 ; nc3 = sumc(nc-1) */
      selq = selq|selcontq;
      hcontq = sumc(selcontq);  hordq=0; hcntq=0; hgrpq=0;
   endif;
     
   selq = selif(eye(nc3+nordcont),selq);                   /* (h=# of available alternatives in unordered-1+# of available non-nominal variables) x (nc3+nordcont)  */    
   if ntotcoef>0;
      zq = zeros(totdep,ntotcoef);      /* (sumc(nc)+nordcont) x (ncoefunord+ncoeford+ncoefcntmain+ncoefcont)   */
   else;
      zq = 0;
   endif;
   indxcompq = zeros(nc3+nordcont,1);

   for j(1,nnom,1);
      ytempunord = ((yiunord[i1,nivunord1[j]+1:nivunord1[j+1]]));
      ytempunord = reshape(ytempunord,nc[j],numunord[j]);
      zq[nc2[j]+1:nc2[j+1],numunord1[j]+1:numunord1[j+1]]=ytempunord;
   endfor;
   
   if nord>0;
      selordqq = ((selq[hunordq+1:hunordq+hordq,nc3+1:nc3+nord])');   /* nord x hordq matrix  */
      maskdownq = zeros(nord,nummask);                                /* nord x [(total number of thresholds+2) across all ordinal outcome ] */
      maskupq = zeros(nord,nummask);
      prepsing=(diagrv(zeros(nord,nord),((indxsing[i1,.])')));          /* All four prep matrices are nord by nord matrices */
      prepsingdown = (diagrv(zeros(nord,nord),((indxdown[i1,.])')));
      prepsingup = (diagrv(zeros(nord,nord),((indxup[i1,.])')));
      prepdoub =(diagrv(zeros(nord,nord),((indxdoub[i1,.])')));
      ytempord = yiord[i1,.];
      ytempord = reshape(ytempord,nord,ncoeford);
      zq[sumc(nc)+1:sumc(nc)+nord,ncoefunord+1:ncoefunord+ncoeford]=ytempord;
   endif;

   for j(1,nord,1);
      maskdownq[j,nummask1[j]+1:nummask1[j+1]]=maskdown[i1,nummask1[j]+1:nummask1[j+1]];
      maskupq[j,nummask1[j]+1:nummask1[j+1]]=maskup[i1,nummask1[j]+1:nummask1[j+1]];
      xdownord = prepdoub*maskdownq*xthresh;
      xupord= prepdoub*maskupq*xthresh;
      xggord = (prepsingdown*maskupq+prepsingup*maskdownq)*xthresh;
   endfor;

   if ncnt>0;
      selcntqq = ((selq[hunordq+hordq+1:hunordq+hordq+hcntq,nc3+nord+1:nc3+nord+ncnt])');   /* ncnt x hcntq matrix  */
      maskdowncntq = zeros(ncnt,nummaskcnt);                                /* ncnt x [(total number of count values+1) across all count outcomes ] */
      maskupcntq = zeros(ncnt,nummaskcnt);
      prepsingcnt=(diagrv(zeros(ncnt,ncnt),((indxsingcnt[i1,.])')));          /* All four prep matrices are nord by nord matrices */
      prepsingdowncnt = (diagrv(zeros(ncnt,ncnt),((indxdowncnt[i1,.])')));
      prepsingupcnt = (diagrv(zeros(ncnt,ncnt),((indxupcnt[i1,.])')));
      prepdoubcnt =(diagrv(zeros(ncnt,ncnt),((indxdoubcnt[i1,.])')));
      if numcntmain>0;
         ytempcntmain = yicntmain[i1,.];
         ytempcntmain = reshape(ytempcntmain,ncnt,ncoefcntmain);
         zq[sumc(nc)+nord+1:sumc(nc)+nord+ncnt,ncoefunord+ncoeford+1:ncoefunord+ncoeford+ncoefcntmain]=ytempcntmain;
      endif;
   endif;

   for j(1,ncnt,1);
       maskdowncntq[j,nummaskcnt1[j]+1:nummaskcnt1[j+1]]=maskdowncnt[i1,nummaskcnt1[j]+1:nummaskcnt1[j+1]];
       maskupcntq[j,nummaskcnt1[j]+1:nummaskcnt1[j+1]]=maskupcnt[i1,nummaskcnt1[j]+1:nummaskcnt1[j+1]];
       xdowncnt = prepdoubcnt*maskdowncntq*xthreshcntall[.,i1];
       xupcnt= prepdoubcnt*maskupcntq*xthreshcntall[.,i1];
       xggcnt = (prepsingdowncnt*maskupcntq+prepsingupcnt*maskdowncntq)*xthreshcntall[.,i1];
   endfor;

   if ngrp>0;
       selgrpqq = ((selq[hunordq+hordq+hcntq+1:hunordq+hordq+hcntq+hgrpq,nc3+nord+ncnt+1:nc3+nord+ncnt+ngrp])');   /* ngrp x hgrpq matrix  */
       ytempgrp = yigrp[i1,.];
       ytempgrp = reshape(ytempgrp,ngrp,ncoefgrp);
       zq[nc4+nord+ncnt+1:nc4+nord+ncnt+ngrp,ncoefunord+ncoeford+ncoefcntmain+1:ncoefunord+ncoeford+ncoefcntmain+ncoefgrp]=ytempgrp;
       maskdowngrpq = zeros(ngrp,nummaskgrp);                            /* ngrp x [(total number of thresholds+2) across all grouped outcomes ] */
       maskupgrpq = zeros(ngrp,nummaskgrp);
       prepsinggrp=(diagrv(zeros(ngrp,ngrp),((indxsinggrp[i1,.])')));          /* All four prep matrices are ngrp by ngrp matrices */
       prepsingdowngrp = (diagrv(zeros(ngrp,ngrp),((indxdowngrp[i1,.])')));
       prepsingupgrp = (diagrv(zeros(ngrp,ngrp),((indxupgrp[i1,.])')));
       prepdoubgrp =(diagrv(zeros(ngrp,ngrp),((indxdoubgrp[i1,.])')));
   endif;

   for j(1,ngrp,1);
       maskdowngrpq[j,nummaskgrp1[j]+1:nummaskgrp1[j+1]]=maskdowngrp[i1,nummaskgrp1[j]+1:nummaskgrp1[j+1]];
       maskupgrpq[j,nummaskgrp1[j]+1:nummaskgrp1[j+1]]=maskupgrp[i1,nummaskgrp1[j]+1:nummaskgrp1[j+1]];
       xdowngrp = prepdoubgrp*maskdowngrpq*xthreshgrp;
       xupgrp= prepdoubgrp*maskupgrpq*xthreshgrp;
       xgggrp = (prepsingdowngrp*maskupgrpq+prepsingupgrp*maskdowngrpq)*xthreshgrp;
   endfor;   
   
   if ncont>0;
       selcontqq = ((selq[hunordq+hordq+hcntq+hgrpq+1:hunordq+hordq+hcntq+hgrpq+hcontq,nc3+nord+ncnt+ngrp+1:nc3+nord+ncnt+ngrp+ncont])');   /* ncont x hcontq matrix  */
       ytempcont = yicont[i1,.];
       zqforlater = reshape(ytempcont,ncont,ncoefcont);
       zq[nc4+nord+ncnt+ngrp+1:totdep,ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+1:ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+ncoefcont]=zqforlater;     /* ncont x ncoefcont */    
   endif;

   if nnom>0;
       if nord>0 and ncnt>0 and ngrp>0 and ncont>0;
           xgg = zeros(nc3,1)|xggord|xggcnt|xgggrp|((ycont[i1,.])');
           xdown = zeros(nc3,1)|xdownord|xdowncnt|xdowngrp|zeros(ncont,1);
           xup = zeros(nc3,1)|xupord|xupcnt|xupgrp|zeros(ncont,1);
           indxcompq = zeros(nc3,1)|((indxup[i1,.])')|((indxupcnt[i1,.])')|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt>0 and ngrp>0 and ncont==0;
           xgg = zeros(nc3,1)|xggord|xggcnt|xgggrp;
           xdown = zeros(nc3,1)|xdownord|xdowncnt|xdowngrp;
           xup = zeros(nc3,1)|xupord|xupcnt|xupgrp;
           indxcompq = zeros(nc3,1)|((indxup[i1,.])')|((indxupcnt[i1,.])')|((indxupgrp[i1,.])');
       elseif nord>0 and ncnt>0 and ngrp==0 and ncont>0;
           xgg = zeros(nc3,1)|xggord|xggcnt|((ycont[i1,.])');
           xdown = zeros(nc3,1)|xdownord|xdowncnt|zeros(ncont,1);
           xup = zeros(nc3,1)|xupord|xupcnt|zeros(ncont,1);
           indxcompq = zeros(nc3,1)|((indxup[i1,.])')|((indxupcnt[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt>0 and ngrp==0 and ncont==0;
           xgg = zeros(nc3,1)|xggord|xggcnt;
           xdown = zeros(nc3,1)|xdownord|xdowncnt;
           xup = zeros(nc3,1)|xupord|xupcnt;
           indxcompq = zeros(nc3,1)|((indxup[i1,.])')|((indxupcnt[i1,.])');
       elseif nord>0 and ncnt==0 and ngrp>0 and ncont>0;
           xgg = zeros(nc3,1)|xggord|xgggrp|((ycont[i1,.])');
           xdown = zeros(nc3,1)|xdownord|xdowngrp|zeros(ncont,1);
           xup = zeros(nc3,1)|xupord|xupgrp|zeros(ncont,1);
           indxcompq = zeros(nc3,1)|((indxup[i1,.])')|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt==0 and ngrp>0 and ncont==0;
           xgg = zeros(nc3,1)|xggord|xgggrp;
           xdown = zeros(nc3,1)|xdownord|xdowngrp;
           xup = zeros(nc3,1)|xupord|xupgrp;
           indxcompq = zeros(nc3,1)|((indxup[i1,.])')|((indxupgrp[i1,.])');
       elseif nord>0 and ncnt==0 and ngrp==0 and ncont>0;
           xgg = zeros(nc3,1)|xggord|((ycont[i1,.])');
           xdown = zeros(nc3,1)|xdownord|zeros(ncont,1);
           xup = zeros(nc3,1)|xupord|zeros(ncont,1);
           indxcompq = zeros(nc3,1)|((indxup[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt==0 and ngrp==0 and ncont==0;
           xgg = zeros(nc3,1)|xggord;
           xdown = zeros(nc3,1)|xdownord;
           xup = zeros(nc3,1)|xupord;
           indxcompq = zeros(nc3,1)|((indxup[i1,.])');
       elseif nord==0 and ncnt>0 and ngrp>0 and ncont>0;
           xgg = zeros(nc3,1)|xggcnt|xgggrp|((ycont[i1,.])');
           xdown = zeros(nc3,1)|xdowncnt|xdowngrp|zeros(ncont,1);
           xup = zeros(nc3,1)|xupcnt|xupgrp|zeros(ncont,1);
           indxcompq = zeros(nc3,1)|((indxupcnt[i1,.])')|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord==0 and ncnt>0 and ngrp>0 and ncont==0;
           xgg = zeros(nc3,1)|xggcnt|xgggrp;
           xdown = zeros(nc3,1)|xdowncnt|xdowngrp;
           xup = zeros(nc3,1)|xupcnt|xupgrp;
           indxcompq = zeros(nc3,1)|((indxupcnt[i1,.])')|((indxupgrp[i1,.])');
       elseif nord==0 and ncnt>0 and ngrp==0 and ncont>0;
           xgg = zeros(nc3,1)|xggcnt|((ycont[i1,.])');
           xdown = zeros(nc3,1)|xdowncnt|zeros(ncont,1);
           xup = zeros(nc3,1)|xupcnt|zeros(ncont,1);
           indxcompq = zeros(nc3,1)|((indxupcnt[i1,.])')|zeros(ncont,1);
       elseif nord==0 and ncnt>0 and ngrp==0 and ncont==0;
           xgg = zeros(nc3,1)|xggcnt;
           xdown = zeros(nc3,1)|xdowncnt;
           xup = zeros(nc3,1)|xupcnt;
           indxcompq = zeros(nc3,1)|((indxupcnt[i1,.])');
       elseif nord==0 and ncnt==0 and ngrp>0 and ncont>0;
           xgg = zeros(nc3,1)|xgggrp|((ycont[i1,.])');
           xdown = zeros(nc3,1)|xdowngrp|zeros(ncont,1);
           xup = zeros(nc3,1)|xupgrp|zeros(ncont,1);
           indxcompq = zeros(nc3,1)|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord==0 and ncnt==0 and ngrp>0 and ncont==0;
           xgg = zeros(nc3,1)|xgggrp;
           xdown = zeros(nc3,1)|xdowngrp;
           xup = zeros(nc3,1)|xupgrp;
           indxcompq = zeros(nc3,1)|((indxupgrp[i1,.])');
       elseif nord==0 and ncnt==0 and ngrp==0 and ncont>0;
           xgg = zeros(nc3,1)|((ycont[i1,.])');
           xdown = zeros(nc3,1)|zeros(ncont,1);
           xup = zeros(nc3,1)|zeros(ncont,1);
           indxcompq = zeros(nc3,1)|zeros(ncont,1);
       elseif nord==0 and ncnt==0 and ngrp==0 and ncont==0;
           xgg = zeros(nc3,1);
           xdown = zeros(nc3,1);
           xup = zeros(nc3,1);
           indxcompq = zeros(nc3,1);   
       endif;
   elseif nnom==0;
       if nord>0 and ncnt>0 and ngrp>0 and ncont>0;
           xgg = xggord|xggcnt|xgggrp|((ycont[i1,.])');
           xdown = xdownord|xdowncnt|xdowngrp|zeros(ncont,1);
           xup = xupord|xupcnt|xupgrp|zeros(ncont,1);
           indxcompq = ((indxup[i1,.])')|((indxupcnt[i1,.])')|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt>0 and ngrp>0 and ncont==0;
           xgg = xggord|xggcnt|xgggrp;
           xdown = xdownord|xdowncnt|xdowngrp;
           xup = xupord|xupcnt|xupgrp;
           indxcompq = ((indxup[i1,.])')|((indxupcnt[i1,.])')|((indxupgrp[i1,.])');
       elseif nord>0 and ncnt>0 and ngrp==0 and ncont>0;
           xgg = xggord|xggcnt|((ycont[i1,.])');
           xdown = xdownord|xdowncnt|zeros(ncont,1);
           xup = xupord|xupcnt|zeros(ncont,1);
           indxcompq = ((indxup[i1,.])')|((indxupcnt[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt>0 and ngrp==0 and ncont==0;
           xgg = xggord|xggcnt;
           xdown = xdownord|xdowncnt;
           xup = xupord|xupcnt;
           indxcompq = ((indxup[i1,.])')|((indxupcnt[i1,.])');
       elseif nord>0 and ncnt==0 and ngrp>0 and ncont>0;
           xgg = xggord|xgggrp|((ycont[i1,.])');
           xdown = xdownord|xdowngrp|zeros(ncont,1);
           xup = xupord|xupgrp|zeros(ncont,1);
           indxcompq = ((indxup[i1,.])')|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt==0 and ngrp>0 and ncont==0;
           xgg = xggord|xgggrp;
           xdown = xdownord|xdowngrp;
           xup = xupord|xupgrp;
           indxcompq = ((indxup[i1,.])')|((indxupgrp[i1,.])');
       elseif nord>0 and ncnt==0 and ngrp==0 and ncont>0;
           xgg = xggord|((ycont[i1,.])');
           xdown = xdownord|zeros(ncont,1);
           xup = xupord|zeros(ncont,1);
           indxcompq = ((indxup[i1,.])')|zeros(ncont,1);
       elseif nord>0 and ncnt==0 and ngrp==0 and ncont==0;
           xgg = xggord;
           xdown = xdownord;
           xup = xupord;
           indxcompq = ((indxup[i1,.])');
       elseif nord==0 and ncnt>0 and ngrp>0 and ncont>0;
           xgg = xggcnt|xgggrp|((ycont[i1,.])');
           xdown = xdowncnt|xdowngrp|zeros(ncont,1);
           xup = xupcnt|xupgrp|zeros(ncont,1);
           indxcompq = ((indxupcnt[i1,.])')|((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord==0 and ncnt>0 and ngrp>0 and ncont==0;
           xgg = xggcnt|xgggrp;
           xdown = xdowncnt|xdowngrp;
           xup = xupcnt|xupgrp;
           indxcompq = ((indxupcnt[i1,.])')|((indxupgrp[i1,.])');
       elseif nord==0 and ncnt>0 and ngrp==0 and ncont>0;
           xgg = xggcnt|((ycont[i1,.])');
           xdown = xdowncnt|zeros(ncont,1);
           xup = xupcnt|zeros(ncont,1);
           indxcompq = ((indxupcnt[i1,.])')|zeros(ncont,1);
       elseif nord==0 and ncnt>0 and ngrp==0 and ncont==0;
           xgg = xggcnt;
           xdown = xdowncnt;
           xup = xupcnt;
           indxcompq = ((indxupcnt[i1,.])');
       elseif nord==0 and ncnt==0 and ngrp>0 and ncont>0;
           xgg = xgggrp|((ycont[i1,.])');
           xdown = xdowngrp|zeros(ncont,1);
           xup = xupgrp|zeros(ncont,1);
           indxcompq = ((indxupgrp[i1,.])')|zeros(ncont,1);
       elseif nord==0 and ncnt==0 and ngrp>0 and ncont==0;
           xgg = xgggrp;
           xdown = xdowngrp;
           xup = xupgrp;
           indxcompq = ((indxupgrp[i1,.])');
       elseif nord==0 and ncnt==0 and ngrp==0 and ncont>0;
           xgg = ((ycont[i1,.])');
           xdown = zeros(ncont,1);
           xup = zeros(ncont,1);
           indxcompq = zeros(ncont,1);   
       endif;
   endif;

   seed20=seednext;

   if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
      xxj = x[rows(x)-sumnivinter+1:rows(x)];
      xxj = xxj.*onetemp;   /* sumnivinter x ncont matrix  */
      { gxxj } = gradelproduct(xxj,onetemp);     /* gxxj is sumnivinter x (sumnivinter x ncont) matrix  */
      contval = zqforlater*xcont; 
      yinterfin = yintercont[i1,.];
      yinterfin = reshape(yinterfin,totdep,sumnivinter);
      vinterfin = yinterfin*xxj*contval;      /*                yinterfin is (totdep x sumnivinter); xxj is sumnivinterx ncont;
                                                                           zqforlater is ncontxncoefcont; xcont is ncoefcontx1; 
                                                                           contval = (zqforlater*xcont) is ncontx1; 
                                                                           [yinterfin*(zqforlater*xcont)] is (hnom+hordcont)x1 vector; 
                                                                           vinterfin is [(sumc(nc)+nordcont)x1] = (wierd theta'.*xfinn')*xtilde   *(w         *alpha)   */ 
       newcov = eye(totdep);  
       newcov[.,sumc(nc)+nord+ncnt+ngrp+1:cols(newcov)]=newcov[.,sumc(nc)+nord+ncnt+ngrp+1:cols(newcov)]+yinterfin*xxj;
       _omsymmetric=0; _omdiagonal=0;
       gwtilde = yinterfin' .*. eye(cols(xxj));    /* (sumnivinter*ncont) x (totdep*ncont)  */
       gwtilde1 = gxxj*gwtilde;                     /* sumnivinter x (totdep*ncont) */
       gxfinal = gAomegaB(yinterfin,contval);      /* (sumnivinter*ncont) x (totdep*1) */ 
       gxxjfinal = gxxj*gxfinal;                    /* sumnivinter x totdep   */
       tempinter = yinterfin*xxj*zqforlater;        /* totdep x ncoefcont  */
       ginteractxcont = zeros(ncoefunord+ncoeford + ncoefgrp,(sumc(nc)+nordcont))|((tempinter)');  /* (ncoefunord+ncoeford+ncoefcont) x (totdep) matrix */ 
   endif;
   
   if nnom>0;
       { Msubq,indxoneq,indxeqq } = Mutodu(nnom,nc,((altchosen[i1,.])'),0,0,0,nord+ncnt+ngrp,ncont);  /* M sub q is b x a matrix ; b = nc3+nordcont ; a = sumc(nc)+nordcont  */
   else;
       Msubq = eye(nordcont);
       indxoneq = zeros(nordcont,1);
       indxeqq = zeros(nordcont,1);
       if ncont>0;
          if nordcont>ncont;
             indxeqq = zeros(nordcont-ncont,1)|ones(ncont,1);
          else;
             indxeqq = ones(ncont,1);
          endif;       
       endif;
   endif;

   Msubq = selq*Msubq;         /* For each individual, selecting only available dimensions; (M sub q is # of available dimensions-1) x a matrix; a = sumc(nc)+nordcont   */
   Vsubq = zq*xfin;    /* (sumc(nc)+nordcont)x1  */
   xisubq = (omegker);           /* xisubq is axa matrix, a = sumc(nc)+nordcont */
   if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
      Vsubq = Vsubq+vinterfin; 
      xisubq = newcov*omegker*newcov';
      _x2symmetric=1; _x1diagonal=0;_x1symmetric=0;_x2diagonal=0;_x2correlation=0; 
      { ggnewcov,ggomegker } = gbothxomegax(newcov,omegker);
      ggnewcov = ggnewcov[design1,.]|ggnewcov[designcont,.];      /* [totdep*(ncont)] x (a*(a+1)/2); a = totdep */  
      _OMEGACORR=0; _XOMEGAXT=0;
      gcovker = gomegxomegax(Msubq*newcov*convdutou);  /* convdutou is a x b matrix; gcovker is [b*(b+1)/2]x[h*(h+1)/2]; a=(sumc(nc)+nordcont), b=(nc3+nordcont) */
      gxisubq = gomegxomegax(Msubq);                   /* [a*(a+1)/2]X[h*(h+1)/2]; a=totdep, b=(nc3+nordcont) */
      ggnewcovtemp = ggnewcov*gxisubq;                  /* [totdep*ncont] x [h*(h+1)/2] matrix */
   else;
      gcovker = gomegxomegax(Msubq*convdutou);         /* [b*(b+1)/2]X[h*(h+1)/2]; a=(totdep), b=(nc3+nordcont) */
   endif;

   if nord>0;
       indxoneq[nc3+1:nc3+nord] = (indxsing[i1,.])';
   endif;
   if ncnt>0;
       indxoneq[nc3+nord+1:nc3+nord+ncnt] = (indxsingcnt[i1,.])';
   endif;
   if ngrp>0;
       indxoneq[nc3+nord+ncnt+1:nc3+nord+ncnt+ngrp] = (indxsinggrp[i1,.])';
   endif;     
   
   xgg = selq*xgg; xdown = selq*xdown;  xup = selq*xup;  indxoneq=selq*indxoneq;  indxcompq = selq*indxcompq;  indxeqq = selq*indxeqq;         
   Bsubq = Msubq*((Vsubq));    /* B sub q is (b)x1 ; M sub q is h x a matrix (h=b only when all alternatives are available in nominal and all non-nominal outcomes are available); b = nc3+nordcont ; a = sumc(nc)+nordcont  */
   newxisubq = Msubq*xisubq*Msubq';
   _covarr = 1;
   if ntotcoef==0;
      Bsubq = zeros(rows(newxisubq),1);
   endif;
   { P,gBsubq,gnewxisubq,gxg,gxdown,gxup,sss } = gradpdfrectn(Bsubq,newxisubq,xgg,xdown,xup,seed20,indxoneq,indxcompq,indxeqq);
   /* gBsubq - (h=# of available alternatives in nominal plus # of available non-nominal variables) x 1 vector */
   /* gnewxisubq - [(h)*(h+1)/2] x 1 vector  vector */
   gVsubq = Msubq';                                                      /* (totdep))x (h) matrix; i.e. a x h matrix */
   gxmu = zq';                                                           /* (ncoefunord+ncoeford+nceofcnt+ncoefgrp+ncoefcont) x (totdep)   */
   gxmufinal = gxmu*gVsubq*gBsubq;                                       /* (ncoefunord+ncoeford+ncoefcnt+ncoefgrp+ncoefcont) x 1 vector */
   if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
       gxmuintercont = gxxjfinal*gVsubq*gBsubq;                          /* [(sumnivinter)x 1 vector */
       gxmufinal = gxmufinal+ginteractxcont*gvsubq*gBsubq;               /* (ncoefunord+ncoeford+ncoefcnt+ncoefgrp+ncoefcont) x 1 vector */
       gwierdtilde = ggnewcovtemp*gnewxisubq;    /*   [totdep*ncont] x 1 vector */
       gwierdtilde1 = gwtilde1*gwierdtilde;   /* [sumnivinter] x 1 vector  */ 
       gxmuintercont = gxmuintercont+gwierdtilde1;  /* [(sumnivinter)x 1 vector */   
   endif;

   if nord>0;
       gxthreshord = selordqq*gxg[hunordq+1:hunordq+hordq];                                    /* All three below are nord X 1 vectors; hordq=nord if all ordered outcomes are available for individual */
       gxdowno = selordqq*gxdown[hunordq+1:hunordq+hordq];
       gxupo = selordqq*gxup[hunordq+1:hunordq+hordq];
       gxggord=((prepsingdown*maskupq+prepsingup*maskdownq)')*gxthreshord;
       gxdownord = ((prepdoub*maskdownq)')*gxdowno;
       gxupord = ((prepdoub*maskupq)')*gxupo;
       gxthreshfin = gxggord+gxdownord+gxupord;  /* Accumulate across all observations and remove first and last elements (-inf and +inf) */
   endif;

   gordthreshfin={};
   for j(1,nord,1);
       gthreshfini = gxthreshfin[nummask1[j]+1:nummask1[j+1]];
       gthreshfini = gthreshfini[2:ncord[j]];
       gordthreshfin = gordthreshfin|gthreshfini;
   endfor;
   if nord>0;
      gordfin = gordthreshfin|gxmufinal[ncoefunord+1:ncoefunord+ncoeford];
   else;
      gordfin = {};
   endif;
   
   if ncnt>0;
       gxthreshc = selcntqq*gxg[hunordq+hordq+1:hunordq+hordq+hcntq];                                    /* All three below are nord X 1 vectors; hordq=nord if all ordered outcomes are available for individual */
       gxdownc = selcntqq*gxdown[hunordq+hordq+1:hunordq+hordq+hcntq];
       gxupc = selcntqq*gxup[hunordq+hordq+1:hunordq+hordq+hcntq];
       gxggcnt=((prepsingdowncnt*maskupcntq+prepsingupcnt*maskdowncntq)')*gxthreshc;                   /* nummaskcnt x ncnt matrix */
       gxdowncnt = ((prepdoubcnt*maskdowncntq)')*gxdownc;                                               /* nummaskcnt x ncnt matrix */
       gxupcnt = ((prepdoubcnt*maskupcntq)')*gxupc;                                                     /* nummaskcnt x ncnt matrix */
       gxthreshfincnt1 = gxggcnt+gxdowncnt+gxupcnt;  /* nummaskcnt (sumc(ncntmax[j]+2) x 1 gradients with respect to all count thresholds (psi sub k thresholds)*/
       ytempcnt = yifincntgamma[i1,.];
       ytempcnt1 = reshape(ytempcnt,ncnt,ncoefcntgamma);
   endif;
    
   gxthetafincnt = {};
   gxlambdafincnt = {};
   gxalphafincnt = {};
   for j(1,ncnt,1);
       gxthreshfincnt = (gxthreshfincnt1[nummaskcnt1[j]+1:nummaskcnt1[j+1]]);   /* (ncntmax[j]+2) x 1 vector  */
       gxthreshfincnt = gxthreshfincnt[2:rows(gxthreshfincnt)];                  /* (ncntmax[j]+1) x 1 vector */
       if numcntthresh[j]>0;
          gxalphafincnt = gxalphafincnt|((galphavector1[ncntthresh1[j]+1:ncntthresh1[j+1],nummaskcntadd11[j]+1:nummaskcntadd11[j+1]])*gxthreshfincnt);
       else;
          gxalphafincnt = {};
       endif;
       gxthetafincnt = gxthetafincnt|((gthetafull[i1,nummaskcntadd11[j]+1:nummaskcntadd11[j+1]])*gxthreshfincnt);
       gxlambdafincnt = gxlambdafincnt|((glambdafull[i1,nummaskcntadd11[j]+1:nummaskcntadd11[j+1]])*gxthreshfincnt);      
   endfor;
 
   if ncnt>0;
      gxlambdafinfincnt = ytempcnt1'*gxlambdafincnt;
      if numcntmain>0;
         gcntfin = gxalphafincnt|gxthetafincnt|gxlambdafinfincnt|gxmufinal[ncoefunord+ncoeford+1:ncoefunord+ncoeford+ncoefcntmain];
      else;
         gcntfin = gxalphafincnt|gxthetafincnt|gxlambdafinfincnt;
      endif;       
   else;
      gcntfin = {};
   endif;
   
   if ngrp>0;
       ggrpfin = gxmufinal[ncoefunord+ncoeford+ncoefcntmain+1:ncoefunord+ncoeford+ncoefcntmain+ncoefgrp];
   else;
       ggrpfin = {};
   endif;
 
   if ncont>0;
       gcontfin = gxmufinal[ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+1:ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+ncoefcont];
   else;
       gcontfin = {};
   endif;
   
   gfinW1 = gW1*gcovker*gnewxisubq;                                   /* b x 1 vector  */
   if nscale>0;
       gfinW1 = gfinW1[indxW];                                           /* number of distinct scale parameters x 1 vector */
   else;
       gfinw1 = {};
   endif;
   gfinstar = gtempstar*gcovker*gnewxisubq;                          /* [b x (b+1)/2] x 1 vector */
   
   Pcomp = pcomp|P;
   if nnom>0;
       g = ((gxmufinal[1:ncoefunord])')~(gordfin')~(gcntfin')~(ggrpfin')~(gcontfin')~(gfinstar')~(gfinW1');
   elseif nnom==0;
       g = (gordfin')~(gcntfin')~(ggrpfin')~(gcontfin')~(gfinstar')~(gfinW1');
   endif;

   if _nomcont or _ordcont or _cntcont or _grpcont or _contcont;
       g = g~gxmuintercont';
   endif;
   
   gfinal = gfinal|g;
   seednext=sss;
endfor;

w=zeros(e1,1);
if pcomp <= w;
   pcomp=pcomp-((pcomp.<=w).*(pcomp-0.0001));
endif;
g1 = gfinal./pcomp;
retp(dta[.,_weight].*g1);
endp;

proc (2) = init(dataset,dvv);
  local fin,dta,obs,c,ncon,i,j,st,p,s,n;
  open fin = ^dataset;
  do until eof(fin);
    dta = readr(fin,nobs);
    obs = rows(dvv);
    c = unique(dvv,1);
    n = rows(c);
    ncon = n-1;
    i = 0;
    s = zeros(n,1);
    do until i == n;
       i=i+1;
       s[i]=sumc(dta[.,_weight].*(dvv .== i));
    endo;
  endo;
  fin = close(fin);
  clear p;
  j=1;
  do until j == n+1;
    p=p|s[j]+p[rows(p)];
    j=j+1;
  endo;
  p=trimr(p,1,1)/p[rows(p)];
  st = cdfni(p);
  retp(n,st);
endp;

proc (4) = initcnt(dataset,dvv);
  local fin,nmax,nmin,dta,obs,c,ncon,i,j,st,p,s,n,smin,sminplus1,gammaconst;
  open fin = ^dataset;
  do until eof(fin);
    dta = readr(fin,nobs);
    obs = rows(dvv);
    c = unique(dvv,1);
    nmax = maxc(c);
    nmin = minc(c);
    n = rows(c);
    i = 0;
    s = zeros(2,1);
    smin = sumc(dta[.,_weight].*(dvv .== (nmin)));
    sminplus1 = sumc(dta[.,_weight].*(dvv .== (nmin+1)));
    gammaconst = (sminplus1/smin)*(nmin+1); 
  endo;
  fin = close(fin);
  retp(nmin,nmax,n,gammaconst);
endp;

proc (3) = initgrp(dataset,dvv,grptemp);    /* grptemp is number of thresholds (ncon) x 1 vector  */
  local fin,dta,obs,c,ncon,i,j,st,p,s,n,grpmed,grpmean,grpstd;
  open fin = ^dataset;
  do until eof(fin);
    dta = readr(fin,nobs);
    obs = rows(dvv);
    c = unique(dvv,1);
    n = rows(c);
    ncon=n-1;
    i = 0;
    if n>2;
       grpmed = ((trimr(grptemp,1,0))+grptemp[1:ncon-1])/2; 
       grpmed = (grptemp[1]/2)|grpmed|(2*grptemp[ncon]-grptemp[ncon-1]);  /* "midpoint" values for each grouped outcome */
    else;
       grpmed = (grptemp[1]/2)|(grptemp[1]*3/2);
    endif;
    s = zeros(n,1);
    do until i == n;
       i=i+1;
       s[i]=sumc(dta[.,_weight].*(dvv .== (i)));
    endo;
  endo;
  fin = close(fin);
  grpmean = (sumc((s.*grpmed)))/(sumc(s));
  grpstd = sqrt((sumc((s.*((grpmed-grpmean)^2))))/(sumc(s)));
  retp(n,grpmean,grpstd);    /* n is total number of windows, grpmean is imputed mean, grpstd is imputed sd, grptemp is the set of threshold values */
endp;



proc (1) = init1(dataset,dvv);
  local fin,dta,obs,c,i,j,st,p,s,n;
  open fin = ^dataset;
  do until eof(fin);
    dta = readr(fin,nobs);
    obs = rows(dta);
    c = sumc(dvv);
    c = ln(c/c[1]);
    c = c[2:rows(c)];
    c = (sqrt(3)*c)/(pi);
  endo;
  fin = close(fin);
  retp(c);
endp;
