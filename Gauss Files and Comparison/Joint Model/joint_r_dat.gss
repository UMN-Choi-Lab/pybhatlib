      selq = selq|selcontq;
      hcontq = sumc(selcontq);  hordq=0; hcntq=0; hgrpq=0;
   endif;
     
   selq = selif(eye(nc3+nordcont),selq);                   /* (h=# of available alternatives in unordered-1+# of available non-nominal variables) x (nc3+nordcont)  */    
