       zqforlater = reshape(ytempcont,ncont,ncoefcont);
       zq[nc4+nord+ncnt+ngrp+1:totdep,ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+1:ncoefunord+ncoeford+ncoefcntmain+ncoefgrp+ncoefcont]=zqforlater;     /* ncont x ncoefcont */    
   endif;

