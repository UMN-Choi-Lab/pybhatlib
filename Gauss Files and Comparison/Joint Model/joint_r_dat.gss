       maskupgrpq[j,nummaskgrp1[j]+1:nummaskgrp1[j+1]]=maskupgrp[i1,nummaskgrp1[j]+1:nummaskgrp1[j+1]];
       xdowngrp = prepdoubgrp*maskdowngrpq*xthreshgrp;
