       maskdowngrpq = zeros(ngrp,nummaskgrp);                            /* ngrp x [(total number of thresholds+2) across all grouped outcomes ] */
       maskupgrpq = zeros(ngrp,nummaskgrp);
       prepsinggrp=(diagrv(zeros(ngrp,ngrp),((indxsinggrp[i1,.])')));          /* All four prep matrices are ngrp by ngrp matrices */
       prepsingdowngrp = (diagrv(zeros(ngrp,ngrp),((indxdowngrp[i1,.])')));
       prepsingupgrp = (diagrv(zeros(ngrp,ngrp),((indxupgrp[i1,.])')));
       prepdoubgrp =(diagrv(zeros(ngrp,ngrp),((indxdoubgrp[i1,.])')));
